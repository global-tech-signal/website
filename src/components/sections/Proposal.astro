---
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Section from "./Section.astro";

import propImg from "../../assets/pics/proposal-pic.png";
---

<Section>
  <Card>
    <div
      class="flex bg-[#F3F3F3] rounded-[45px] p-[60px] relative mt-[123px] mb-[163px]"
    >
      <div class="w-full md:w-[40%] flex flex-col gap-[26px]">
        <h2 class="text-3xl font-medium">Need custom software for your business?</h2>
        <p>
          From AI automation and CRM systems to full SaaS platforms, our engineering team turns ideas into production-grade software.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/#contact" class="btn-primary text-center">Book a Demo</a>
          <a href="/#contact" class="btn-secondary text-center">Start a Project</a>
        </div>
      </div>
      <picture
        class="hidden md:flex absolute right-[-10%] lg:right-0 top-[-15%] h-[450px] items-center justify-center"
      >
        <Image
          src={propImg}
          alt="This is an illustration"
          class="hidden md:flex lg:h-full lg:w-auto"
        />
      </picture>
    </div>
  </Card>
</Section>
