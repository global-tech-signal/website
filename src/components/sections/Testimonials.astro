---
import SectionTitle from "../ui/SectionTitle.astro";
import SwiperSlider from "../ui/SwiperSlider.astro";
import Section from "./Section.astro";
---

<Section id="testimonials">
  <div class="mt-20">
    <SectionTitle
      sectionTitle="Testimonials"
      description="What founders and operators say about working with our engineering team on AI, SaaS and automation projects."
    />
    <div class="rounded-[45px] bg-dark mb-12 md:mb-[150px] text-gray">
      <SwiperSlider />
    </div>
  </div>
</Section>
