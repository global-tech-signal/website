---
import Section from "./Section.astro";
import HeroIlust from "../../assets/pics/hero.svg?raw";
---

<Section id="home">
<div class="relative flex flex-col-reverse items-center md:flex-row" id="hero">
    <div class="row items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <div class="text-left space-y-3">
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-gray text-xs font-medium text-dark">
                <span class="w-2 h-2 rounded-full bg-accent"></span>
                Operational Intelligence &middot; Business Systems &middot; AI
            </span>
            <h1 class="text-4xl font-medium leading-tight md:text-6xl text-center md:text-left tracking-tight">
                Build Intelligent <span class="redhead">Business Systems</span> That Scale
            </h1>
            <p class="mt-6 mb-12 text-lg font-normal leading-7 sm:mb-12 text-center md:text-left md:pr-12 text-dark/70">
                Growing businesses eventually outgrow disconnected tools, manual processes, spreadsheets and siloed software. We design intelligent business systems powered by AI, automation and connected technology that eliminate operational friction and help organizations scale.
            </p>
            <div class="w-full flex flex-col sm:flex-row gap-4 justify-center md:justify-start items-center">
                <a href="/contact" class="px-8 py-4 bg-dark hover:bg-accent rounded-xl text-center text-white text-base font-medium transition-colors">
                    Operational Assessment
                </a>
                <a href="/services" class="px-8 py-4 bg-white hover:bg-dark hover:text-white rounded-xl text-center text-dark border border-dark/20 text-base font-medium transition-colors">
                    Explore Solutions
                </a>
            </div>
        </div>
    </div>
    <div class="flex items-center justify-center w-full max-w-[280px] sm:max-w-[360px] md:max-w-none md:w-6/12 md:pb-20 pt-5 md:pt-10 mx-auto md:mx-0">
        <div class="w-full hero-svg-wrap">
            <Fragment set:html={HeroIlust} />
        </div>
    </div>
</div>
</Section>

<style>
    .hero-svg-wrap :global(svg) {
        width: 100%;
        height: auto;
    }
</style>