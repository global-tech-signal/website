---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import HeroIlust from "../../assets/pics/hero.svg";
---

<Section id="home">
<div class="relative flex flex-col-reverse items-center md:flex-row" id="hero">
    <div class="row items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <div class="text-left space-y-3">
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-gray text-xs font-medium text-dark">
                <span class="w-2 h-2 rounded-full bg-accent"></span>
                Tech News &middot; Case Studies &middot; Engineering
            </span>
            <h1 class="text-4xl font-medium leading-tight md:text-6xl text-center md:text-left tracking-tight">
                Global Tech News, <br/> Insights & <span class="text-accent">Engineering</span>
            </h1>
            <p class="mt-6 mb-8 text-lg font-normal leading-7 sm:mb-12 text-center md:text-left md:pr-12 text-dark/70">
                AI, SaaS, automation, and software solutions for modern businesses.
            </p>
            <div class="w-full flex flex-col sm:flex-row gap-4 justify-center md:justify-start items-center">
                <a href="/case-studies" class="px-8 py-4 bg-dark hover:bg-accent rounded-xl text-center text-white text-base font-medium transition-colors">
                    Case Studies
                </a>
                <a href="/#contact" class="px-8 py-4 bg-white hover:bg-dark hover:text-white rounded-xl text-center text-dark border border-dark/20 text-base font-medium transition-colors">
                    Start a Project
                </a>
            </div>
        </div>
    </div>
    <div class="flex items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <Image src={HeroIlust} alt="GlobalTechSignal hero illustration" loading="eager" />
    </div>
</div>
</Section>