---
import { Image } from "astro:assets";
import s1 from "../../assets/company/company-logo1.svg";
import s3 from "../../assets/company/company-logo3.svg";
import s4 from "../../assets/company/company-logo4.svg";
import s6 from "../../assets/company/company-logo6.svg";
import Section from "./Section.astro";

const logoTools = [
  { logo: s4, alt: "HubSpot" },
  { logo: s3, alt: "Notion" },
  { logo: s1, alt: "Zoom" },
  { logo: s6, alt: "AWS" },
];

// Platforms we wire into business systems. Framed as capability /
// expertise — not as official partner certifications.
const platforms = [
  "Salesforce",
  "Microsoft 365",
  "Google Cloud",
  "OpenAI",
  "Anthropic",
  "Stripe",
  "Twilio",
  "Slack",
  "Zapier",
  "Make",
  "n8n",
  "Airtable",
  "Pipedrive",
  "Zoho",
  "Intercom",
  "ServiceNow",
];
---

<Section id="sponsors">
  <div class="flex-col items-center">
    <p class="text-center text-xs sm:text-sm font-mono uppercase tracking-widest text-dark/60 mb-6">
      Platforms we wire into your business systems
    </p>
    <div class="flex justify-center gap-8 items-center flex-wrap mb-7">
      {logoTools.map((tool) => (
        <div class="p-4 grayscale transition duration-200 hover:grayscale-0">
          <Image src={tool.logo} class="h-10 w-auto mx-auto" alt={tool.alt} loading="lazy" />
        </div>
      ))}
    </div>
    <div class="flex justify-center gap-2.5 flex-wrap max-w-4xl mx-auto">
      {platforms.map((tool) => (
        <span class="px-3.5 py-1.5 rounded-full border border-dark/10 bg-white text-xs sm:text-sm font-medium text-dark/70 hover:border-dark hover:text-dark transition-colors">{tool}</span>
      ))}
    </div>
    <p class="mt-5 text-center text-xs text-dark/45 max-w-xl mx-auto">
      Capabilities and integration experience. We connect the stack you already run on — not a stack we resell.
    </p>
  </div>
</Section>
