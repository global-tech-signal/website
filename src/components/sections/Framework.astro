---
import Section from "./Section.astro";

const layers = [
  {
    num: "01",
    title: "People",
    desc: "Map the roles, responsibilities and decisions that drive outcomes.",
  },
  {
    num: "02",
    title: "Processes",
    desc: "Document and redesign the operational workflows behind the work.",
  },
  {
    num: "03",
    title: "Technology",
    desc: "Pick \u2014 or build \u2014 the connected stack that supports those processes.",
  },
  {
    num: "04",
    title: "Data",
    desc: "Unify customer, operational and revenue data into one source of truth.",
  },
  {
    num: "05",
    title: "AI",
    desc: "Embed intelligence where it removes work and improves decisions.",
  },
  {
    num: "06",
    title: "Business Outcomes",
    desc: "Measure success in revenue, retention, response time and hours saved.",
  },
];
---

<Section id="operational-intelligence">
  <div class="mt-10 md:mt-[140px]">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
      <div class="flex flex-col gap-5 max-w-2xl">
        <span class="inline-flex items-center gap-2 text-sm font-medium w-fit">
          <span class="h-2 w-2 rounded-full bg-red"></span>
          <span class="font-mono uppercase tracking-widest text-xs text-dark/60">Operational Intelligence Framework</span>
        </span>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-tight">
          How intelligent business
          <span class="text-accent">systems are built</span>.
        </h2>
      </div>
      <p class="lg:max-w-sm text-base sm:text-lg text-dark/80">
        We design every engagement across six connected layers &mdash; because technology alone never solves an operational problem.
      </p>
    </div>

    <div class="relative">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {layers.map((layer, i) => (
          <div class:list={[
            "group relative p-7 rounded-[28px] border border-dark transition-all duration-300 hover:-translate-y-1 shadow-[0px_4px_0px_#191a23]",
            i === layers.length - 1 ? "bg-dark text-white" : i % 2 === 0 ? "bg-white text-dark" : "bg-gray text-dark",
          ]}>
            <div class="flex items-center justify-between mb-6">
              <span class:list={["text-xs font-mono tracking-widest", i === layers.length - 1 ? "text-white/50" : "text-dark/40"]}>LAYER {layer.num}</span>
              <span class:list={[
                "inline-flex h-9 w-9 items-center justify-center rounded-full text-xs font-bold",
                i === layers.length - 1 ? "bg-accent text-white" : "bg-dark text-white",
              ]}>
                {layer.num}
              </span>
            </div>
            <h3 class="text-2xl font-extrabold tracking-tight mb-2">{layer.title}</h3>
            <p class:list={["text-sm leading-snug", i === layers.length - 1 ? "text-white/75" : "text-dark/65"]}>{layer.desc}</p>
            {i < layers.length - 1 && (
              <div class="hidden lg:flex absolute -bottom-3 left-1/2 -translate-x-1/2 w-7 h-7 items-center justify-center rounded-full bg-white border border-dark shadow-[0px_2px_0px_#191a23]" aria-hidden="true">
                <svg class="w-3 h-3 text-dark" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</Section>
