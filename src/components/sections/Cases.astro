---
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Section from "./Section.astro";

const cards = [
  {
    index: 0,
    title:
      "For a regional roofing company, we shipped an AI-powered lead routing and CRM workflow that cut response time from hours to minutes and increased booked inspections by 38%.",
    link: "/case-studies#ai-lead-routing-roofing",
  },
  {
    index: 1,
    title:
      "For a multi-location clinic group, we built a SaaS scheduling platform with automated reminders and intake, reducing no-shows by 27% and saving the front-desk team 15+ hours per week.",
    link: "/case-studies#saas-scheduling-clinic",
  },
  {
    index: 1,
    title:
      "For a B2B real-estate firm, we automated lead enrichment and pipeline syncing across CRM and email tools, doubling qualified opportunities without adding headcount.",
    link: "/case-studies#lead-enrichment-real-estate",
  },
];

import larrow from "../../assets/icon3.svg";
import SectionTitle from "../ui/SectionTitle.astro";
---

<Section id="case-studies">
  <div class="mt-24">
    <SectionTitle
      sectionTitle="Case Studies"
      description="Real engineering work — AI automation, SaaS systems and CRM platforms shipped to production for growing businesses."
    />
    <div class="flex flex-col lg:flex-row justify-between rounded-[45px] p-1">
      {
        cards.map((card) => (
          <Card>
            <div class="flex p-[60px] h-full bg-dark text-gray rounded-[45px] m-[1px]">
              <div class="flex flex-col gap-5">
                <p>{card.title}</p>
                  <a href={card.link} class="flex items-center gap-[15px]">
                  <span class="text-red">Read case study</span>
                  <picture>
                    <Image src={larrow} alt="Arrow pointing up right" />
                  </picture>
                </a>
              </div>
            </div>
          </Card>
        ))
      }
    </div>
  </div>
</Section>
