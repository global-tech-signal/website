---
import SectionTitle from "../ui/SectionTitle.astro";
import Section from "./Section.astro";

const cards = [
  {
    num: "01",
    title: "Revenue Systems",
    description: "CRM, lead management and sales automation built around how your team actually wins business.",
    link: "/services/revenue-systems",
    variant: "dark",
  },
  {
    num: "02",
    title: "Operations Systems",
    description: "Connected workflows that replace manual handoffs across the tools you already use.",
    link: "/services/operations-systems",
    variant: "accent",
  },
  {
    num: "03",
    title: "Customer Systems",
    description: "A single source of truth for every customer interaction — from first touch to ongoing success.",
    link: "/services/customer-systems",
    variant: "light",
  },
  {
    num: "04",
    title: "Business Intelligence",
    description: "Real-time dashboards and reporting leadership can actually trust.",
    link: "/services/business-intelligence",
    variant: "light",
  },
  {
    num: "05",
    title: "Digital Experience",
    description: "High-performance websites and SaaS surfaces wired into your business systems.",
    link: "/services/digital-experience",
    variant: "accent",
  },
  {
    num: "06",
    title: "AI Operations",
    description: "AI agents, copilots and intelligent automations embedded in how your business runs.",
    link: "/services/ai-operations",
    variant: "dark",
  },
];

const variantStyles = {
  dark: "bg-dark text-white",
  accent: "bg-accent text-white",
  light: "bg-gray text-dark",
};

const arrowStyles = {
  dark: "border-white/20 text-white group-hover:bg-white group-hover:text-dark",
  accent: "border-white/20 text-white group-hover:bg-white group-hover:text-accent",
  light: "border-dark/20 text-dark group-hover:bg-dark group-hover:text-white",
};

const description =
  "Six connected business systems that eliminate operational friction and drive predictable, measurable outcomes for growing companies.";
---

<Section id="business-systems" class="mb-15">
  <div class="mt-5 md:mt-[140px] mb-5">
    <SectionTitle sectionTitle="Business Systems" description={description} />
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        cards.map((card) => (
          <a
            href={card.link}
            class:list={[
              "group relative flex flex-col justify-between p-7 sm:p-8 rounded-[28px] min-h-[220px] border border-dark/10 shadow-[0px_4px_0px_#191a23] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0px_8px_0px_#191a23]",
              variantStyles[card.variant as keyof typeof variantStyles],
            ]}
          >
            <div class="flex items-start justify-between">
              <span class="text-sm font-mono opacity-50">{card.num}</span>
              <span
                class:list={[
                  "inline-flex h-9 w-9 items-center justify-center rounded-full border transition-all duration-300 group-hover:rotate-[-45deg]",
                  arrowStyles[card.variant as keyof typeof arrowStyles],
                ]}
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </span>
            </div>
            <div class="mt-auto">
              <h3 class="text-xl font-extrabold tracking-tight mb-2">{card.title}</h3>
              <p class:list={[
                "text-sm leading-relaxed",
                card.variant === "light" ? "text-dark/60" : "text-white/70",
              ]}>
                {card.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Section>
