---
import Section from "./Section.astro";

const services = [
  {
    num: "01",
    title: "Revenue Systems",
    tag: "Featured",
    description:
      "CRM, lead management and sales automation built around how your team actually wins business. Pipeline visibility, faster speed-to-lead and predictable revenue motion.",
    bullets: [
      "Custom & HubSpot/Salesforce CRMs",
      "Lead capture, scoring & routing",
      "Sales automation & sequences",
    ],
    link: "/services/revenue-systems",
    variant: "featured",
    span: "lg:col-span-2",
  },
  {
    num: "02",
    title: "Operations Systems",
    description:
      "Connected workflows that replace manual handoffs across CRM, email, billing and back-office tools.",
    bullets: ["Workflow automation", "Internal tooling", "API & data integrations"],
    link: "/services/operations-systems",
    variant: "light",
    span: "lg:col-span-1",
  },
  {
    num: "03",
    title: "Customer Systems",
    description:
      "A single source of truth for every customer interaction \u2014 from first touch to ongoing success.",
    bullets: ["Unified customer record", "Support & success ops", "Onboarding & retention"],
    link: "/services/customer-systems",
    variant: "outline",
    span: "lg:col-span-1",
  },
  {
    num: "04",
    title: "Business Intelligence",
    description:
      "Dashboards and reporting leadership can actually trust \u2014 in real time, not after a week of spreadsheet wrangling.",
    bullets: ["Executive dashboards", "Operational KPIs", "Revenue & pipeline analytics"],
    link: "/services/business-intelligence",
    variant: "light",
    span: "lg:col-span-1",
  },
  {
    num: "05",
    title: "Digital Experience",
    description:
      "High-performance websites and product surfaces engineered for conversion and wired into your business systems.",
    bullets: ["Astro & Next.js builds", "SaaS product UI", "CRM & analytics integration"],
    link: "/services/digital-experience",
    variant: "dark",
    span: "lg:col-span-1",
  },
  {
    num: "06",
    title: "AI Operations",
    tag: "End-to-end",
    description:
      "AI agents, copilots and intelligent automations embedded into the way your business runs \u2014 not isolated demos.",
    bullets: [
      "LLM workflows & document automation",
      "AI copilots on your data & SOPs",
      "Operational intelligence & insights",
    ],
    link: "/services/ai-operations",
    variant: "red",
    span: "lg:col-span-3",
  },
];

const variantClasses = {
  featured:
    "bg-dark text-white border-dark shadow-[0px_5px_0px_#191a23]",
  dark: "bg-dark text-white border-dark shadow-[0px_5px_0px_#191a23]",
  red: "bg-red-soft text-white border-dark shadow-[0px_5px_0px_#191a23]",
  light: "bg-gray text-black border-dark shadow-[0px_5px_0px_#191a23]",
  outline: "bg-white text-black border-dark shadow-[0px_5px_0px_#191a23]",
};
---

<Section id="business-systems">
  <div class="mt-10 md:mt-[140px] mb-5">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
      <div class="flex flex-col gap-5 max-w-2xl">
        <span class="inline-flex items-center gap-2 text-sm font-medium w-fit">
          <span class="h-2 w-2 rounded-full bg-red"></span>
          Business Systems
        </span>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-tight">
          Connected systems that
          <span class="text-accent">scale your operations</span>
        </h2>
      </div>
      <p class="lg:max-w-sm text-base sm:text-lg text-dark/80">
        We package proven technology &mdash; CRM, automation, AI, integrations and custom software &mdash; into business systems that solve real operational problems.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-7">
      {
        services.map((s) => (
          <a
            href={s.link}
            class:list={[
              "service-card group relative flex flex-col justify-between p-7 sm:p-9 rounded-[36px] border min-h-[320px] transition-all duration-300 hover:-translate-y-1",
              s.span,
              variantClasses[s.variant as keyof typeof variantClasses],
            ]}
          >
            <div class="flex items-start justify-between gap-4">
              <div class="flex items-center gap-3">
                <span
                  class:list={[
                    "text-sm font-mono opacity-70",
                  ]}
                >
                  {s.num}
                </span>
                {s.tag && (
                  <span
                    class:list={[
                      "text-[11px] uppercase tracking-wider px-2.5 py-1 rounded-full border",
                      s.variant === "featured" || s.variant === "dark" || s.variant === "red"
                        ? "border-white/30 text-white/90"
                        : "border-current/30",
                    ]}
                  >
                    {s.tag}
                  </span>
                )}
              </div>
              <span
                class:list={[
                  "service-arrow inline-flex h-10 w-10 items-center justify-center rounded-full border transition-transform duration-300 group-hover:rotate-[-45deg]",
                  s.variant === "featured" || s.variant === "dark" || s.variant === "red"
                    ? "border-white/30 text-white"
                    : "border-dark/30 text-dark",
                ]}
                aria-hidden="true"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </span>
            </div>

            <div class="mt-10 flex flex-col gap-4">
              <h3
                class:list={[
                  "font-extrabold leading-tight tracking-tight",
                  s.variant === "featured"
                    ? "text-3xl sm:text-4xl lg:text-5xl"
                    : s.variant === "red"
                      ? "text-3xl sm:text-4xl"
                      : "text-2xl sm:text-3xl",
                ]}
              >
                {s.title}
              </h3>
              <p
                class:list={[
                  "text-sm sm:text-base max-w-xl",
                  s.variant === "featured" || s.variant === "dark" || s.variant === "red"
                    ? "text-white/75"
                    : "text-current/80",
                ]}
              >
                {s.description}
              </p>
              <ul
                class:list={[
                  "mt-2 flex flex-wrap gap-2",
                ]}
              >
                {s.bullets.map((b) => (
                  <li
                    class:list={[
                      "text-xs sm:text-sm px-3 py-1.5 rounded-full border",
                      s.variant === "featured" || s.variant === "dark" || s.variant === "red"
                        ? "border-white/20 text-white/85 bg-white/5"
                        : "border-dark/20 text-dark bg-dark/[0.03]",
                    ]}
                  >
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Section>

<style>
  .service-card {
    will-change: transform;
  }
  .service-card:hover {
    box-shadow: 0px 10px 0px #191a23;
  }
</style>
