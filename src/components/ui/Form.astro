---
---

<div
  class="flex relative justify-start items-center p-[60px] bg-[#F3F3F3] rounded-[45px] overflow-hidden"
>
  <form id="contact-form" class="bg-gray sm:p-6 h-full w-full lg:max-w-lg">
    <div class="flex flex-col sm:flex-row gap-[35px] sm:items-center mb-10">
      <div class="flex items-center gap-[14px]">
        <input
          type="checkbox"
          id="checkbox1"
          name="checkbox1"
          class="form-checkbox text-black"
        />
        <label for="checkbox1" class="text-black">Book a Demo</label>
      </div>
      <div class="flex items-center gap-[14px]">
        <input
          type="checkbox"
          id="checkbox2"
          name="checkbox2"
          class="form-checkbox text-black"
        />
        <label for="checkbox2" class="flex items-center text-black"
          >Start a Project</label
        >
      </div>
    </div>

    <div class="mb-4">
      <label for="name" class="block text-black mb-2">Name*</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Name"
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none"
      />
    </div>

    <div class="mb-4">
      <label for="email" class="block text-black mb-2">Email*</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="Email"
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none"
      />
    </div>

    <div class="mb-4">
      <label for="message" class="block text-black mb-2">Message*</label>
      <textarea
        id="message"
        name="message"
        required
        placeholder="Message"
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none"
      ></textarea>
    </div>

    <button type="submit" name="submit" class="btn-primary w-full">Send</button>
    <p id="contact-status" class="mt-4 text-center text-sm hidden"></p>
  </form>

  <!-- Decorative side panel -->
  <div class="absolute right-8 top-[5%] bottom-[5%] w-[320px] hidden lg:flex flex-col items-center justify-center gap-5">
    <!-- Accent glow -->
    <div class="absolute inset-0 rounded-[32px] bg-accent/5 blur-3xl"></div>

    <!-- Response time card -->
    <div class="form-float-card relative bg-dark text-white rounded-2xl p-5 w-full shadow-[0px_4px_0px_#191a23] border border-dark/80">
      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center h-10 w-10 rounded-full bg-accent/20 shrink-0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-accent" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <div>
          <span class="text-xl font-extrabold leading-none">&lt; 24h</span>
          <p class="text-[11px] text-white/50 mt-0.5">Average response time</p>
        </div>
      </div>
    </div>

    <!-- What happens next card -->
    <div class="form-float-card relative bg-white rounded-2xl p-5 w-full shadow-[0px_4px_0px_#191a23] border border-dark" style="animation-delay: 0.6s;">
      <div class="flex items-center gap-2 mb-3">
        <span class="h-2 w-2 rounded-full bg-accent"></span>
        <span class="text-[11px] font-medium uppercase tracking-wider text-dark/50">What happens next</span>
      </div>
      <ol class="space-y-2.5">
        <li class="flex items-start gap-2.5">
          <span class="flex items-center justify-center h-5 w-5 rounded-full bg-dark text-white text-[10px] font-bold shrink-0 mt-0.5">1</span>
          <span class="text-[12px] text-dark/80 leading-snug">We review your request & prep questions</span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="flex items-center justify-center h-5 w-5 rounded-full bg-dark text-white text-[10px] font-bold shrink-0 mt-0.5">2</span>
          <span class="text-[12px] text-dark/80 leading-snug">30-min discovery call to scope the project</span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="flex items-center justify-center h-5 w-5 rounded-full bg-dark text-white text-[10px] font-bold shrink-0 mt-0.5">3</span>
          <span class="text-[12px] text-dark/80 leading-snug">You get a detailed proposal within 48h</span>
        </li>
      </ol>
    </div>

    <!-- Trust badge -->
    <div class="form-float-card relative bg-accent text-white rounded-2xl p-4 w-full shadow-[0px_4px_0px_#191a23] border border-accent" style="animation-delay: 1.2s;">
      <div class="flex items-center gap-3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        </svg>
        <div>
          <span class="text-sm font-bold leading-none">No obligation</span>
          <p class="text-[10px] text-white/70 mt-0.5">Free consultation · NDA available</p>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .form-checkbox {
    appearance: none;
    width: 28px;
    height: 28px;
    border: 1px solid #000;
    border-radius: 50%;
    outline: none;
    cursor: pointer;
    position: relative;
  }

  .form-checkbox:before {
    content: "";
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    position: absolute;
    top: 0;
    left: 0;
    background: var(--green);
    transform: scale(0);
    transition: transform 0.1s ease-in-out;
  }

  .form-checkbox:checked:before {
    transform: scale(0.6);
  }

  @keyframes form-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .form-float-card {
    animation: form-float 4s ease-in-out infinite;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('contact-status') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';
    status.classList.add('hidden');

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });
      const json = await res.json();

      if (res.ok) {
        status.textContent = "Message sent! We'll get back to you soon.";
        status.className = 'mt-4 text-center text-sm text-green';
        form.reset();
      } else {
        status.textContent = json.error || 'Something went wrong.';
        status.className = 'mt-4 text-center text-sm text-red-500';
      }
    } catch {
      status.textContent = 'Network error. Please try again.';
      status.className = 'mt-4 text-center text-sm text-red-500';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send';
    }
  });
</script>
<script>
  function formSetup() {
    var cb1 = document.getElementById("checkbox1") as HTMLInputElement;
    var cb2 = document.getElementById("checkbox2") as HTMLInputElement;
    var message = document.getElementById("message") as HTMLInputElement;

    if (cb1 && cb2) {
      cb1.checked = true;

      cb2.addEventListener("change", function () {
        if (cb2.checked) {
          cb1.checked = false;
          message.value =
            "We'd like to start a software project with GlobalTechSignal. Here's what we're trying to build:";
        } else {
          message.value = "";
          cb1.checked = true;
        }
      });
      cb1.addEventListener("change", function () {
        if (cb1.checked) {
          cb2.checked = false;
          message.value = "";
        } else {
          cb2.checked = true;
          message.value =
            "We'd like to start a software project with GlobalTechSignal. Here's what we're trying to build:";
        }
      });
    }
  }

  formSetup();
  document.addEventListener("astro:after-swap", formSetup);
</script>
