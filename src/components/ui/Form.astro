---
type Props = {
  qualify?: boolean;
};

const { qualify = false } = Astro.props;

const inputClass =
  "w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none bg-white";
const labelClass = "block text-black mb-2";

const companySizes = [
  "Just me / Founder",
  "2-10",
  "11-50",
  "51-200",
  "201-1,000",
  "1,000+",
];

const industries = [
  "Real Estate",
  "Professional Services",
  "Healthcare",
  "Financial Services",
  "Technology / SaaS",
  "Manufacturing",
  "Retail / E-commerce",
  "Construction / Trades",
  "Education",
  "Other",
];

const challenges = [
  "Manual Processes",
  "CRM",
  "Sales Operations",
  "Customer Experience",
  "Reporting & Visibility",
  "AI",
  "Integrations",
  "Custom Software",
  "Other",
];

const timelines = [
  "Exploring options",
  "Within 1-3 months",
  "Within 3-6 months",
  "6+ months",
];

const currentSystems = [
  "HubSpot",
  "Salesforce",
  "Zoho",
  "Microsoft",
  "Google Workspace",
  "Other",
];
---

<div
  class:list={[
    "flex relative justify-start items-center p-7 md:p-[60px] bg-[#F3F3F3] rounded-[45px] overflow-hidden",
    qualify && "lg:items-start",
  ]}
>
  <form
    id="contact-form"
    class:list={[
      "bg-gray sm:p-6 h-full w-full",
      !qualify && "lg:max-w-lg",
    ]}
  >
    {/* Selected-assessment banner — shown when ?type=<slug> is in the URL */}
    <div
      id="assessment-banner"
      class="hidden mb-6 rounded-2xl border border-dark/15 bg-white p-4 flex items-start gap-3"
    >
      <span class="flex items-center justify-center h-8 w-8 rounded-full bg-accent/10 shrink-0">
        <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </span>
      <div class="flex-1 min-w-0">
        <span class="block text-[10px] font-mono uppercase tracking-widest text-dark/50">You're requesting</span>
        <span id="assessment-label" class="block text-sm font-semibold text-dark mt-0.5"></span>
      </div>
      <a
        id="assessment-clear"
        href="/contact"
        class="text-[11px] font-mono uppercase tracking-widest text-dark/50 hover:text-accent shrink-0"
      >Change</a>
    </div>
    {/* Hidden input — populated client-side when ?type= is present.
        Maps to the existing `challenge` field so /api/contact picks it up
        in the email subject as the inquiry type. */}
    <input type="hidden" id="assessment-type-input" name="assessmentType" value="" />

    {!qualify && (
      <div class="mb-6 inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-white text-xs font-medium text-dark">
        <span class="w-2 h-2 rounded-full bg-accent"></span>
        Operational Assessment · Free first conversation
      </div>
    )}

    {qualify ? (
      <div class="grid sm:grid-cols-2 gap-x-5 gap-y-4 mb-4">
        <div>
          <label for="name" class={labelClass}>Name*</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Your full name"
            class={inputClass}
          />
        </div>
        <div>
          <label for="company" class={labelClass}>Company*</label>
          <input
            type="text"
            id="company"
            name="company"
            required
            placeholder="Company name"
            class={inputClass}
          />
        </div>
        <div>
          <label for="email" class={labelClass}>Business Email*</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@company.com"
            class={inputClass}
          />
        </div>
        <div>
          <label for="phone" class={labelClass}>Phone (Optional)</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="+1 (555) 555-5555"
            class={inputClass}
          />
        </div>
        <div>
          <label for="companySize" class={labelClass}>Company Size*</label>
          <select
            id="companySize"
            name="companySize"
            required
            class={inputClass}
          >
            <option value="">Select size</option>
            {companySizes.map((size) => (
              <option value={size}>{size}</option>
            ))}
          </select>
        </div>
        <div>
          <label for="industry" class={labelClass}>Industry*</label>
          <select id="industry" name="industry" required class={inputClass}>
            <option value="">Select industry</option>
            {industries.map((industry) => (
              <option value={industry}>{industry}</option>
            ))}
          </select>
        </div>
        <div>
          <label for="challenge" class={labelClass}>
            Biggest Operational Challenge*
          </label>
          <select id="challenge" name="challenge" required class={inputClass}>
            <option value="">Select the area causing the most friction</option>
            {challenges.map((challenge) => (
              <option value={challenge}>{challenge}</option>
            ))}
          </select>
        </div>
        <div>
          <label for="timeline" class={labelClass}>Preferred Timeline</label>
          <select id="timeline" name="timeline" class={inputClass}>
            <option value="">Select timeline</option>
            {timelines.map((timeline) => (
              <option value={timeline}>{timeline}</option>
            ))}
          </select>
        </div>
        <div class="sm:col-span-2">
          <label for="message" class={labelClass}>Tell us more*</label>
          <textarea
            id="message"
            name="message"
            required
            rows={5}
            placeholder="Describe the operational bottleneck, the outcome you want, or the system you'd like to improve."
            class={inputClass}
          ></textarea>
        </div>
        <fieldset class="sm:col-span-2 mt-2">
          <legend class={labelClass}>Current Systems (Optional)</legend>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2">
            {currentSystems.map((system) => (
              <label class="flex items-center gap-2 text-sm text-black bg-white border border-black rounded-[10px] px-3 py-2 cursor-pointer">
                <input
                  type="checkbox"
                  name="currentSystems"
                  value={system}
                  class="accent-red"
                />
                {system}
              </label>
            ))}
          </div>
        </fieldset>
      </div>
    ) : (
      <>
        <div class="mb-4">
          <label for="name" class={labelClass}>Name*</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Your full name"
            class={inputClass}
          />
        </div>

        <div class="mb-4">
          <label for="company" class={labelClass}>Company</label>
          <input
            type="text"
            id="company"
            name="company"
            placeholder="Company name"
            class={inputClass}
          />
        </div>

        <div class="mb-4">
          <label for="email" class={labelClass}>Business Email*</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@company.com"
            class={inputClass}
          />
        </div>

        <div class="mb-4">
          <label for="challenge" class={labelClass}>
            Biggest Operational Challenge
          </label>
          <select id="challenge" name="challenge" class={inputClass}>
            <option value="">Where is operations breaking down?</option>
            {challenges.map((c) => (
              <option value={c}>{c}</option>
            ))}
          </select>
        </div>

        <div class="mb-4">
          <label for="message" class={labelClass}>Message*</label>
          <textarea
            id="message"
            name="message"
            required
            rows={4}
            placeholder="Tell us where revenue is leaking, where teams are duplicating work, or where reporting takes days."
            class={inputClass}
          ></textarea>
        </div>
      </>
    )}

    <button type="submit" name="submit" class="btn-primary w-full">
      {qualify ? "Schedule an Operational Assessment" : "Request Operational Assessment"}
    </button>
    {!qualify && (
      <p class="mt-4 text-center text-xs text-dark/50">
        Need to share more context?
        <a href="/contact" class="underline hover:text-accent">
          Use the full assessment form
        </a>
      </p>
    )}
    <p id="contact-status" class="mt-4 text-center text-sm hidden"></p>
  </form>

  {!qualify && (
  <!-- Decorative side panel -->
  <div class="absolute right-8 top-[5%] bottom-[5%] w-[320px] hidden lg:flex flex-col items-center justify-center gap-5">
    <!-- Accent glow -->
    <div class="absolute inset-0 rounded-[32px] bg-accent/5 blur-3xl"></div>

    <!-- Response time card -->
    <div class="form-float-card relative bg-dark text-white rounded-2xl p-5 w-full shadow-[0px_4px_0px_#191a23] border border-dark/80">
      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center h-10 w-10 rounded-full bg-accent/20 shrink-0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-accent" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <div>
          <span class="text-xl font-extrabold leading-none">&lt; 24h</span>
          <p class="text-[11px] text-white/50 mt-0.5">Average response time</p>
        </div>
      </div>
    </div>

    <!-- What happens next card -->
    <div class="form-float-card relative bg-white rounded-2xl p-5 w-full shadow-[0px_4px_0px_#191a23] border border-dark" style="animation-delay: 0.6s;">
      <div class="flex items-center gap-2 mb-3">
        <span class="h-2 w-2 rounded-full bg-accent"></span>
        <span class="text-[11px] font-medium uppercase tracking-wider text-dark/50">What happens next</span>
      </div>
      <ol class="space-y-2.5">
        <li class="flex items-start gap-2.5">
          <span class="flex items-center justify-center h-5 w-5 rounded-full bg-dark text-white text-[10px] font-bold shrink-0 mt-0.5">1</span>
          <span class="text-[12px] text-dark/80 leading-snug">We review your request & prep questions</span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="flex items-center justify-center h-5 w-5 rounded-full bg-dark text-white text-[10px] font-bold shrink-0 mt-0.5">2</span>
          <span class="text-[12px] text-dark/80 leading-snug">30-min discovery call to scope the project</span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="flex items-center justify-center h-5 w-5 rounded-full bg-dark text-white text-[10px] font-bold shrink-0 mt-0.5">3</span>
          <span class="text-[12px] text-dark/80 leading-snug">You get a detailed proposal within 48h</span>
        </li>
      </ol>
    </div>

    <!-- Trust badge -->
    <div class="form-float-card relative bg-accent text-white rounded-2xl p-4 w-full shadow-[0px_4px_0px_#191a23] border border-accent" style="animation-delay: 1.2s;">
      <div class="flex items-center gap-3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        </svg>
        <div>
          <span class="text-sm font-bold leading-none">No obligation</span>
          <p class="text-[10px] text-white/70 mt-0.5">Free consultation · NDA available</p>
        </div>
      </div>
    </div>
  </div>
  )}
</div>
<style>
  @keyframes form-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .form-float-card {
    animation: form-float 4s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .form-float-card { animation: none; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('contact-status') as HTMLParagraphElement;

  // Map assessment / engagement slugs → human-readable labels.
  // Keep in sync with /src/pages/assessments.astro and /src/pages/scorecard.astro.
  const ASSESSMENT_LABELS: Record<string, string> = {
    'operational-assessment': 'Operational Assessment',
    'operational-roadmap': 'Operational Roadmap Session',
    'ai-readiness': 'AI Readiness Workshop',
    'workflow-audit': 'Workflow Audit',
    'revenue-systems': 'Revenue Systems Assessment',
    'executive-strategy': 'Executive Strategy Session',
    'crm-architecture-review': 'CRM Architecture Review',
    'systems-integration-review': 'Systems Integration Review',
    'data-architecture-assessment': 'Data Architecture Assessment',
    'integration-blueprint': 'Integration Blueprint',
    'automation-opportunity-review': 'Automation Opportunity Review',
    'process-engineering-session': 'Process Engineering Session',
    'business-intelligence-review': 'Business Intelligence Review',
    'decision-intelligence-assessment': 'Decision Intelligence Assessment',
    'executive-kpi-review': 'Executive KPI Review',
    'continuous-improvement-plan': 'Continuous Improvement Plan',
    'operational-performance-workshop': 'Operational Performance Workshop',
  };

  // Read ?type=<slug> from URL and decorate the form.
  try {
    const params = new URLSearchParams(window.location.search);
    const type = params.get('type');
    if (type && ASSESSMENT_LABELS[type]) {
      const banner = document.getElementById('assessment-banner');
      const label = document.getElementById('assessment-label');
      const hidden = document.getElementById('assessment-type-input') as HTMLInputElement | null;
      if (banner) banner.classList.remove('hidden');
      if (label) label.textContent = ASSESSMENT_LABELS[type];
      if (hidden) hidden.value = ASSESSMENT_LABELS[type];

      // Also pre-fill the visible "challenge" select if it exists on the page,
      // so the chosen offer flows into the existing inquiry pipeline.
      const challengeSelect = document.getElementById('challenge') as HTMLSelectElement | null;
      if (challengeSelect) {
        const exists = Array.from(challengeSelect.options).some((o) => o.value === ASSESSMENT_LABELS[type]);
        if (!exists) {
          const opt = document.createElement('option');
          opt.value = ASSESSMENT_LABELS[type];
          opt.textContent = ASSESSMENT_LABELS[type];
          challengeSelect.appendChild(opt);
        }
        challengeSelect.value = ASSESSMENT_LABELS[type];
      }
    }
  } catch {}

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalLabel = btn.textContent || 'Send';
    btn.disabled = true;
    btn.textContent = 'Sending...';
    status.classList.add('hidden');

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });
      const json = await res.json();

      if (res.ok) {
        status.textContent = "Message sent! We'll get back to you soon.";
        status.className = 'mt-4 text-center text-sm text-red';
        form.reset();
      } else {
        status.textContent = json.error || 'Something went wrong.';
        status.className = 'mt-4 text-center text-sm text-red-500';
      }
    } catch {
      status.textContent = 'Network error. Please try again.';
      status.className = 'mt-4 text-center text-sm text-red-500';
    } finally {
      btn.disabled = false;
      btn.textContent = originalLabel;
    }
  });
</script>
