---
import { Astronav, MenuItems, MenuIcon, Dropdown, DropdownItems } from "astro-navbar";

type MenuItem = {
  href?: string;
  label: string;
  children?: { href: string; label: string; description?: string }[];
};

const menuitems: MenuItem[] = [
  {
    label: 'Business Systems',
    children: [
      { href: '/operational-intelligence', label: 'Operational Intelligence', description: 'The category — and how the six systems fit together.' },
      { href: '/services#revenue-systems', label: 'Revenue Systems', description: 'CRM, sales automation & lead management built around how you sell.' },
      { href: '/services#operations-systems', label: 'Operations Systems', description: 'Connected workflows that eliminate manual handoffs.' },
      { href: '/services#customer-systems', label: 'Customer Systems', description: 'One source of truth for every customer interaction.' },
      { href: '/services#business-intelligence', label: 'Business Intelligence', description: 'Dashboards & reporting leadership can actually trust.' },
      { href: '/services#ai-operations', label: 'AI Operations', description: 'AI agents and copilots that remove operational work.' },
      { href: '/services#digital-experience', label: 'Digital Experience', description: 'Web & product surfaces wired into your business systems.' },
    ],
  },
  {
    label: 'Solutions',
    children: [
      { href: '/solutions/outgrowing-spreadsheets', label: 'Outgrowing Spreadsheets', description: 'Centralize sales & operations as you scale.' },
      { href: '/solutions/sales-operations', label: 'Sales Operations Breaking Down', description: 'Lost leads, poor CRM adoption, manual follow-up.' },
      { href: '/solutions/manual-processes', label: 'Too Many Manual Processes', description: 'Repetitive work and operational bottlenecks.' },
      { href: '/solutions/disconnected-systems', label: 'Disconnected Business Systems', description: 'CRM, email, chat and docs that don\u2019t talk.' },
      { href: '/solutions/reporting', label: 'Reporting Takes Days', description: 'Real-time visibility for leadership decisions.' },
      { href: '/solutions/scaling-operations', label: 'Scaling Operations', description: 'Systems that scale without adding headcount.' },
      { href: '/solutions/customer-information', label: 'Customer Info Everywhere', description: 'A unified customer record across your stack.' },
      { href: '/solutions/ai-without-roi', label: 'AI Without ROI', description: 'Operational intelligence over isolated AI demos.' },
    ],
  },
  {
    label: 'Industries',
    children: [
      { href: '/industries', label: 'All Industries', description: 'See every industry we serve.' },
      { href: '/industries/real-estate', label: 'Real Estate', description: 'CRM & automation for brokerages and agents.' },
      { href: '/industries/roofing', label: 'Roofing', description: 'Sales, dispatch & claims for contractors.' },
      { href: '/industries/clinics', label: 'Clinics', description: 'Patient ops for medical & dental practices.' },
      { href: '/industries/construction', label: 'Construction', description: 'Project & field operations for GCs.' },
      { href: '/industries/legal', label: 'Legal', description: 'Intake to billing for modern firms.' },
      { href: '/industries/insurance', label: 'Insurance', description: 'Quote, bind & renew for agencies.' },
      { href: '/industries/home-services', label: 'Home Services', description: 'Dispatch & sales for HVAC, plumbing, electrical.' },
      { href: '/industries/ecommerce', label: 'E-Commerce', description: 'Orders, inventory, CX & growth for DTC brands.' },
      { href: '/industries/logistics', label: 'Logistics', description: 'Dispatch, POD & settlement for fleets.' },
      { href: '/industries/finance', label: 'Finance', description: 'Client lifecycle for RIAs & wealth firms.' },
      { href: '/industries/education', label: 'Education', description: 'Inquiry → enrolled → completed lifecycle.' },
      { href: '/industries/agencies', label: 'Agencies', description: 'New business, delivery & profitability.' },
    ],
  },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/assessments', label: 'Assessments' },
  { href: '/scorecard', label: 'Scorecard' },
  { href: '/articles', label: 'Insights' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const navButton = { href: '/contact', label: 'Operational Assessment' };
---

<div class="mt-20">
  <nav class="w-full top-0 left-0 z-50 fixed bg-white">
    <header class="flex flex-col lg:flex-row justify-between items-center my-5 px-6 md:px-32">
      <Astronav>
        <div class="flex w-full lg:w-auto items-center justify-between">
          <a href="/" class="flex items-center">
            <img src="/Logo.svg" class="h-8 w-auto" alt="GlobalTechSignal" />
          </a>
          <div class="block lg:hidden">
            <div id="menu-icon" class="w-8 h-8 text-black cursor-pointer">
              <!-- Open (hamburger) icon -->
              <svg id="open-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-8 h-8">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
              <!-- Close (X) icon -->
              <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-8 h-8 hidden">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </div>
          </div>
        </div>
        
        <nav class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0" id="menu-items">
          <ul class="font-medium flex flex-col p-4 lg:p-0 mt-4 border rounded-lg lg:flex-row lg:items-center lg:space-x-8 lg:mt-0 lg:border-0">
            {menuitems.map((item) => (
              item.children ? (
                <li class="relative">
                  <Dropdown class="group m-0 p-0 list-none">
                    <button
                      type="button"
                      class="mobile-nav-link flex items-center gap-1 py-2 px-3 text-black rounded lg:bg-transparent lg:p-0 w-full lg:w-auto"
                    >
                      <span>{item.label}</span>
                      <svg class="w-4 h-4 transition-transform duration-200 group-aria-expanded:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </button>
                    <DropdownItems class="lg:absolute lg:top-full lg:left-0 lg:mt-3 lg:w-72 lg:bg-white lg:rounded-2xl lg:border lg:border-zinc-200 lg:shadow-[0px_4px_0px_#191a23] lg:p-2 lg:z-50">
                      <ul class="flex flex-col gap-1">
                        {item.children.map((child) => (
                          <li>
                            <a
                              href={child.href}
                              class="mobile-nav-link block px-4 py-3 rounded-xl text-black hover:bg-zinc-100 transition-colors"
                              data-close-menu="true"
                            >
                              <span class="block font-semibold">{child.label}</span>
                              {child.description && (
                                <span class="block text-sm text-zinc-500 mt-0.5">{child.description}</span>
                              )}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </DropdownItems>
                  </Dropdown>
                </li>
              ) : (
                <li>
                  <a
                    href={item.href}
                    class="mobile-nav-link block py-2 px-3 text-black rounded lg:bg-transparent lg:p-0"
                    data-close-menu="true"
                  >
                    {item.label}
                  </a>
                </li>
              )
            ))}
            <div class="lg:hidden flex items-center justify-center mt-3 gap-4">
              <a 
                class="mobile-nav-link px-9 py-5 rounded-2xl border border-zinc-900 bg-white hover:bg-black text-black hover:text-white inline-flex" 
                href={navButton.href}
                data-close-menu="true"
              >
                <h2 class="text-center text-xl font-normal leading-7">{navButton.label}</h2>
              </a>
            </div>
          </ul>
        </nav>
      </Astronav>

      <div>
        <div class="hidden lg:flex items-center gap-4">
          <a class="px-9 py-5 rounded-2xl border border-zinc-900 bg-white hover:bg-black text-black hover:text-white inline-flex" href={navButton.href}>
            <h2 class="text-center text-xl font-normal leading-7">{navButton.label}</h2>
          </a>
        </div>
      </div>
    </header>
  </nav>
</div>

<script is:inline>
  // Get references to the menu icon, open/close icons, and menu items
  const menuIcon = document.getElementById('menu-icon');
  const openIcon = document.getElementById('open-icon');
  const closeIcon = document.getElementById('close-icon');
  const menuItems = document.getElementById('menu-items');
  const closeMenuItems = document.querySelectorAll('[data-close-menu="true"]');  // Select all items with the 'data-close-menu' attribute

  // Toggle the menu visibility and icon when the menu icon is clicked
  menuIcon.addEventListener('click', () => {
    menuItems.classList.toggle('hidden');  // Toggle the 'hidden' class on the menu

    // Toggle between open and close icons
    openIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
  });

  // Close the menu when any item is clicked
  closeMenuItems.forEach(item => {
    item.addEventListener('click', () => {
      menuItems.classList.add('hidden');  // Add the 'hidden' class to hide the menu
      openIcon.classList.remove('hidden');  // Show the open (hamburger) icon
      closeIcon.classList.add('hidden');  // Hide the close (X) icon
    });
  });
</script>