---
import MainLayout from "../layouts/MainLayout.astro";
import Sponsors from "../components/sections/Sponsors.astro";
import Services from "../components/sections/Services.astro";
---

<MainLayout
    title="About | GlobalTechSignal"
    description="Global Tech Signal is an operational intelligence studio. We design intelligent business systems — connecting people, processes, data and AI — to help growing companies scale."
>
	<main class="space-y-10 mb-10">
        <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-3">
            <div class="relative flex flex-col items-center" id="hero">
                <div class="row items-center py-5 md:pb-20 md:pt-10">
                    <div class="text-center space-y-8 max-w-3xl mx-auto">
                        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-gray text-xs font-medium text-dark">
                            <span class="w-2 h-2 rounded-full bg-accent"></span>
                            About GlobalTechSignal
                        </span>
                        <h1 class="text-4xl font-medium leading-tight md:text-6xl tracking-tight">
                            An operational intelligence studio <br/> for <span class="redhead">growing businesses</span>.
                        </h1>
                        <p class="text-lg font-normal leading-7 text-dark/70">
                            Global Tech Signal designs intelligent business systems that help companies scale. We start with the operational problem — not the technology — and connect people, processes, data and AI into a system that produces measurable business outcomes.
                        </p>
                        <div class="flex flex-col sm:flex-row gap-3 justify-center">
                            <a href="/contact" class="px-8 py-4 bg-dark hover:bg-accent text-white rounded-xl text-base font-medium transition-colors">Operational Assessment</a>
                            <a href="/services" class="px-8 py-4 bg-white hover:bg-dark hover:text-white text-dark border border-dark/20 rounded-xl text-base font-medium transition-colors">Explore Business Systems</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid md:grid-cols-3 gap-6 mt-10">
                <div class="p-8 bg-gray rounded-2xl border border-dark/5">
                    <h3 class="text-xl font-medium mb-2">Problem first</h3>
                    <p class="text-dark/70">Every engagement begins with an operational assessment — mapping where revenue, time and visibility are leaking before any tool is chosen.</p>
                </div>
                <div class="p-8 bg-gray rounded-2xl border border-dark/5">
                    <h3 class="text-xl font-medium mb-2">Systems, not silos</h3>
                    <p class="text-dark/70">We design connected business systems across CRM, automation, data and AI — so workflows, teams and reporting all share one source of truth.</p>
                </div>
                <div class="p-8 bg-gray rounded-2xl border border-dark/5">
                    <h3 class="text-xl font-medium mb-2">Outcomes we measure</h3>
                    <p class="text-dark/70">Pipeline, retention, response time, hours saved — every system we ship is judged on the business outcome it moves, not the technology behind it.</p>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6 mt-10">
                <div class="p-8 bg-white rounded-2xl border border-dark/10">
                    <h3 class="text-xl font-medium mb-2">Engineering studio</h3>
                    <p class="text-dark/70">A senior team of engineers, operators and designers shipping production-grade CRM, SaaS, automation and AI systems for modern businesses.</p>
                </div>
                <div class="p-8 bg-white rounded-2xl border border-dark/10">
                    <h3 class="text-xl font-medium mb-2">Tech newsroom</h3>
                    <p class="text-dark/70">We also publish operational intelligence — AI, CRM strategy, workflow architecture and BI — written by the engineers building these systems for clients.</p>
                </div>
            </div>
        </div>
        <Sponsors />
        <Services />
	</main>
</MainLayout>