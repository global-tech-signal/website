---
import MainLayout from "../layouts/MainLayout.astro";
import Section from "../components/sections/Section.astro";

interface Option { label: string; points: number; }
interface Question {
  id: string;
  dimension: 'capture' | 'connect' | 'automate' | 'intelligence' | 'optimize';
  prompt: string;
  options: Option[];
}

const dimensions = [
  { key: 'capture',      label: 'Capture',      desc: 'Where lead, customer, order and operational signal actually lands.' },
  { key: 'connect',      label: 'Connect',      desc: 'How well your systems exchange the same trusted record.' },
  { key: 'automate',     label: 'Automate',     desc: 'Repetitive handoffs running as systems, not human checklists.' },
  { key: 'intelligence', label: 'Intelligence', desc: 'AI, scoring and decision support embedded in real workflows.' },
  { key: 'optimize',     label: 'Optimize',     desc: 'Live KPIs and telemetry so leadership can see and act.' },
];

const questions: Question[] = [
  {
    id: 'q1', dimension: 'capture',
    prompt: 'When a new lead or customer signal arrives, where does it land?',
    options: [
      { label: 'A shared inbox, spreadsheet or someone\'s head', points: 0 },
      { label: 'Sometimes the CRM, sometimes not — depends on the rep', points: 1 },
      { label: 'In the CRM, but key context lives elsewhere', points: 2 },
      { label: 'In one system, fully attributed, every time', points: 3 },
    ],
  },
  {
    id: 'q2', dimension: 'capture',
    prompt: 'A customer just contacted support — can the AE see it within a minute?',
    options: [
      { label: 'They\'ll find out next quarter, if at all', points: 0 },
      { label: 'Only if support remembers to forward it', points: 1 },
      { label: 'Yes, via a manual lookup in another tool', points: 2 },
      { label: 'Yes — it surfaces on their pipeline view automatically', points: 3 },
    ],
  },
  {
    id: 'q3', dimension: 'connect',
    prompt: 'How many tools hold pieces of the same customer or order record?',
    options: [
      { label: '5+ and none agree', points: 0 },
      { label: '3–4, with a weekly reconciliation job', points: 1 },
      { label: '2–3, but kept in sync by integrations', points: 2 },
      { label: 'One source of truth, others read from it', points: 3 },
    ],
  },
  {
    id: 'q4', dimension: 'connect',
    prompt: 'Can a non-engineer get a real-time cross-system answer in 5 minutes?',
    options: [
      { label: 'No — even with help, it takes days', points: 0 },
      { label: 'Only the analyst can, and they\'re booked out', points: 1 },
      { label: 'Mostly — for the questions we anticipated', points: 2 },
      { label: 'Yes — anyone can self-serve any cross-system view', points: 3 },
    ],
  },
  {
    id: 'q5', dimension: 'automate',
    prompt: 'What share of customer & operational handoffs run automatically?',
    options: [
      { label: 'Almost none — handoffs are Slack, email and memory', points: 0 },
      { label: 'A few "happy path" automations, the rest manual', points: 1 },
      { label: 'Most core flows automated, edges are manual', points: 2 },
      { label: 'Automated end-to-end with clear ownership at each step', points: 3 },
    ],
  },
  {
    id: 'q6', dimension: 'automate',
    prompt: 'When an automated process fails, who finds out first?',
    options: [
      { label: 'The customer, in a complaint email', points: 0 },
      { label: 'The team, once someone spots the gap', points: 1 },
      { label: 'A dashboard flags it within the day', points: 2 },
      { label: 'An alert fires the moment a SLA is at risk', points: 3 },
    ],
  },
  {
    id: 'q7', dimension: 'intelligence',
    prompt: 'Where does AI live in your operations today?',
    options: [
      { label: 'Nowhere yet — or only in personal ChatGPT use', points: 0 },
      { label: 'A few isolated demos, none in production', points: 1 },
      { label: 'In 1–2 production workflows with measurable impact', points: 2 },
      { label: 'Embedded across pipeline, support and ops, with guardrails', points: 3 },
    ],
  },
  {
    id: 'q8', dimension: 'intelligence',
    prompt: 'How are operational decisions made?',
    options: [
      { label: 'Gut and the loudest voice in the room', points: 0 },
      { label: 'A monthly report nobody fully trusts', points: 1 },
      { label: 'Live dashboards, manually reviewed', points: 2 },
      { label: 'Models / scoring trigger or recommend actions in the workflow', points: 3 },
    ],
  },
  {
    id: 'q9', dimension: 'optimize',
    prompt: 'Can leadership see real-time operational KPIs without asking anyone?',
    options: [
      { label: 'KPIs are assembled in a deck each quarter', points: 0 },
      { label: 'A weekly export goes to leadership', points: 1 },
      { label: 'Live dashboards exist but data quality is uneven', points: 2 },
      { label: 'Yes — trusted live dashboards by team and by outcome', points: 3 },
    ],
  },
  {
    id: 'q10', dimension: 'optimize',
    prompt: 'How often do you retire workflows that no longer earn their keep?',
    options: [
      { label: 'Never — every workflow accumulates', points: 0 },
      { label: 'Once a year, in an ops cleanup', points: 1 },
      { label: 'Quarterly — but only the most visible ones', points: 2 },
      { label: 'Continuously, against measurable operational KPIs', points: 3 },
    ],
  },
];

const stages = [
  { idx: 1, min: 0,  max: 6,  name: 'Patchwork Ops',   short: 'Patchwork',   blurb: 'Disconnected systems. Heavy manual work. Knowledge lives with people.' },
  { idx: 2, min: 7,  max: 12, name: 'Connected Ops',   short: 'Connected',   blurb: 'Core systems communicate. Processes remain partially manual.' },
  { idx: 3, min: 13, max: 18, name: 'Automated Ops',   short: 'Automated',   blurb: 'Routine operational work runs automatically. Humans focus on exceptions.' },
  { idx: 4, min: 19, max: 24, name: 'Intelligent Ops', short: 'Intelligent', blurb: 'AI supports decisions. Insights are proactive. Leaders trust real-time visibility.' },
  { idx: 5, min: 25, max: 30, name: 'Autonomous Ops',  short: 'Autonomous',  blurb: 'Systems continuously optimize. AI recommends and orchestrates actions. Operations scale with minimal manual intervention.' },
];

// What this layer covers in the GTS service catalog
const layerServices = [
  { key: 'capture',      label: 'Capture',      items: ['CRM', 'Lead Capture', 'Forms', 'Sales Intake'] },
  { key: 'connect',      label: 'Connect',      items: ['Integrations', 'APIs', 'ERP', 'HubSpot · Salesforce'] },
  { key: 'automate',     label: 'Automate',     items: ['Workflow Automation', 'Approvals', 'AI Agents', 'Orchestration'] },
  { key: 'intelligence', label: 'Intelligence', items: ['Dashboards', 'Reporting', 'AI Insights', 'Decision Support'] },
  { key: 'optimize',     label: 'Optimize',     items: ['Continuous Improvement', 'KPI Reviews', 'Process Optimization', 'Operational Consulting'] },
];
---

<MainLayout
  title="Business Operations Index™ | GlobalTechSignal"
  description="A 10-question self-serve diagnostic that scores your business across the five layers of Operational Intelligence — and shows you the next stage of operational maturity."
>
  <!-- HERO -->
  <Section id="sc-hero">
    <div class="pt-10 pb-12">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7 space-y-6">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-dark/10 bg-gray text-xs font-mono uppercase tracking-widest text-dark">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
            Business Operations Index™
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-tight">
            Where are you on the <span class="text-accent">maturity ladder</span>?
          </h1>
          <p class="text-lg text-dark/70 leading-relaxed max-w-2xl">
            Ten honest questions. Two minutes. You walk out with your Business Operations Index™ across five layers — and the stage you're in today, the stage you're closest to, and how to get there.
          </p>
          <ul class="flex flex-wrap gap-x-6 gap-y-3 text-sm text-dark/70 pt-2">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>10 questions</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>~2 minutes</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>No email required</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>Instant result</li>
          </ul>
        </div>
        <div class="lg:col-span-5">
          <div class="relative">
            <div class="absolute inset-0 bg-accent/5 blur-3xl rounded-[45px]"></div>
            <div class="relative p-5 rounded-[28px] bg-white border border-dark shadow-[0px_4px_0px_#191a23]">
              <div class="font-mono text-[10px] uppercase tracking-widest text-dark/50 mb-3">5 stages of operational maturity</div>
              <div class="space-y-2">
                {stages.map((s, i) => (
                  <div class={`sc-float-card flex items-center gap-3 p-3 rounded-xl border ${i === 4 ? 'bg-accent text-white border-accent' : i === 3 ? 'bg-dark text-white border-dark' : 'bg-gray text-dark border-dark/10'}`} style={`animation-delay: ${i * 0.12}s;`}>
                    <span class={`font-mono text-[10px] ${i >= 3 ? 'text-white/60' : 'text-dark/50'} shrink-0`}>STAGE {s.idx}</span>
                    <span class="text-sm font-bold tracking-tight">{s.name}</span>
                    <div class={`ml-auto h-1.5 w-1.5 rounded-full ${i === 4 ? 'bg-white animate-pulse' : i >= 3 ? 'bg-accent' : 'bg-dark/20'}`}></div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- FORM + RESULTS -->
  <Section id="sc-tool">
    <div class="pb-24">
      <div class="rounded-[32px] bg-gray border border-dark/10 p-6 md:p-10 lg:p-14 relative overflow-hidden">
        <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-accent/10 blur-3xl"></div>

        <!-- Form -->
        <form id="sc-form" class="relative space-y-8" data-questions={JSON.stringify(questions.map(q => ({ id: q.id, dim: q.dimension })))}>
          <div class="flex flex-wrap items-end justify-between gap-4 mb-6">
            <div>
              <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Business Operations Index™</span>
              <h2 class="mt-2 text-2xl md:text-3xl font-extrabold tracking-tight">Answer honestly. Nobody sees this but you.</h2>
            </div>
            <div class="flex items-center gap-3 text-sm text-dark/60">
              <span id="sc-progress-label">0 / {questions.length} answered</span>
              <div class="w-32 h-1.5 bg-dark/10 rounded-full overflow-hidden">
                <div id="sc-progress-bar" class="h-full bg-accent transition-all duration-300" style="width: 0%"></div>
              </div>
            </div>
          </div>

          {questions.map((q, idx) => (
            <fieldset class="sc-q rounded-2xl bg-white border border-dark/10 p-6 md:p-7" data-qid={q.id} data-dim={q.dimension}>
              <legend class="px-3 py-1 rounded-full bg-dark text-white text-[10px] font-mono uppercase tracking-widest">
                Q{idx + 1} · {dimensions.find(d => d.key === q.dimension)?.label}
              </legend>
              <p class="text-base md:text-lg font-semibold text-dark mt-3 mb-5">{q.prompt}</p>
              <div class="grid sm:grid-cols-2 gap-3">
                {q.options.map((opt) => (
                  <label class="sc-opt flex items-start gap-3 p-4 rounded-xl border border-dark/10 hover:border-dark cursor-pointer transition-all has-[input:checked]:border-dark has-[input:checked]:bg-dark has-[input:checked]:text-white">
                    <input type="radio" name={q.id} value={opt.points} class="sc-input mt-1 accent-accent shrink-0" required />
                    <span class="text-sm leading-relaxed">{opt.label}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          ))}

          <div class="flex flex-col sm:flex-row gap-3 items-center justify-between pt-4">
            <p class="text-sm text-dark/50">Answer all 10 to reveal your score.</p>
            <button type="submit" id="sc-submit" class="px-8 py-4 bg-dark text-white rounded-xl font-medium hover:bg-accent transition-colors disabled:opacity-40 disabled:cursor-not-allowed" disabled>
              Compute my score
            </button>
          </div>
        </form>

        <!-- Results (hidden until submit) -->
        <div id="sc-results" class="hidden relative">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-8">
            <div>
              <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Your Business Operations Index™</span>
              <div class="mt-2 inline-flex items-center gap-2 px-3 py-1 rounded-full bg-dark text-white text-[10px] font-mono uppercase tracking-widest">
                <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
                Stage <span id="sc-stage-idx">—</span> of 5
              </div>
              <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight">
                You are <span id="sc-tier-name" class="text-accent">—</span>.
              </h2>
              <p id="sc-tier-blurb" class="mt-4 max-w-2xl text-base md:text-lg text-dark/70 leading-relaxed"></p>
            </div>
            <div class="rounded-[24px] bg-dark text-white border border-dark p-6 text-center min-w-[180px] shadow-[0px_5px_0px_#191a23]">
              <span class="block text-[10px] font-mono uppercase tracking-widest text-white/60">Total score</span>
              <span class="block mt-2"><span id="sc-total" class="text-6xl font-extrabold leading-none">0</span><span class="text-white/40 text-2xl"> / 30</span></span>
            </div>
          </div>

          <!-- Current → Next Stage progression -->
          <div id="sc-progression" class="rounded-[28px] bg-white border border-dark/10 p-6 md:p-8 mb-10 shadow-[0px_4px_0px_#191a23]">
            <span class="text-[10px] font-mono uppercase tracking-widest text-dark/50">Where you are → where you're going</span>
            <div class="mt-4 grid md:grid-cols-12 gap-5 items-stretch">
              <div class="md:col-span-5 rounded-2xl bg-gray border border-dark/10 p-5">
                <span class="text-[10px] font-mono uppercase tracking-widest text-dark/50">Current stage</span>
                <h3 id="sc-current-stage" class="mt-2 text-2xl font-extrabold tracking-tight">—</h3>
                <p id="sc-current-blurb" class="mt-2 text-sm text-dark/70 leading-relaxed"></p>
              </div>
              <div class="md:col-span-2 flex items-center justify-center">
                <div class="hidden md:flex items-center justify-center h-10 w-10 rounded-full bg-accent text-white">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
                <div class="md:hidden text-accent font-mono text-xs uppercase tracking-widest">↓ Next ↓</div>
              </div>
              <div class="md:col-span-5 rounded-2xl bg-dark text-white border border-dark p-5">
                <span class="text-[10px] font-mono uppercase tracking-widest text-accent">Next stage</span>
                <h3 id="sc-next-stage" class="mt-2 text-2xl font-extrabold tracking-tight">—</h3>
                <p id="sc-next-blurb" class="mt-2 text-sm text-white/75 leading-relaxed"></p>
              </div>
            </div>
            <div class="mt-6">
              <span class="text-[10px] font-mono uppercase tracking-widest text-dark/50">Progress required</span>
              <ul id="sc-progress-actions" class="mt-3 grid sm:grid-cols-3 gap-3"></ul>
            </div>
          </div>

          <!-- Dimension breakdown -->
          <div class="grid md:grid-cols-2 gap-4 mb-10">
            {dimensions.map((d) => (
              <div class="rounded-2xl bg-white border border-dark/10 p-5" data-dim-card={d.key}>
                <div class="flex items-center justify-between mb-3">
                  <div>
                    <span class="text-[10px] font-mono uppercase tracking-widest text-dark/50">Layer</span>
                    <h3 class="text-lg font-extrabold tracking-tight">{d.label}</h3>
                  </div>
                  <span class="text-sm font-mono"><span class="sc-dim-score font-bold text-dark">0</span><span class="text-dark/40"> / 6</span></span>
                </div>
                <div class="h-2 bg-dark/5 rounded-full overflow-hidden">
                  <div class="sc-dim-bar h-full bg-accent transition-all duration-500" style="width: 0%"></div>
                </div>
                <p class="mt-3 text-xs text-dark/60 leading-relaxed">{d.desc}</p>
              </div>
            ))}
          </div>

          <!-- Strongest / weakest -->
          <div class="grid md:grid-cols-2 gap-4 mb-10">
            <div class="rounded-2xl bg-accent text-white p-6 border border-accent shadow-[0px_4px_0px_#191a23]">
              <span class="text-[10px] font-mono uppercase tracking-widest text-white/70">Strongest layer</span>
              <h3 id="sc-strong-name" class="text-2xl font-extrabold tracking-tight mt-1">—</h3>
              <p id="sc-strong-text" class="mt-3 text-sm text-white/85 leading-relaxed"></p>
            </div>
            <div class="rounded-2xl bg-dark text-white p-6 border border-dark shadow-[0px_4px_0px_#191a23]">
              <span class="text-[10px] font-mono uppercase tracking-widest text-accent">Biggest leverage</span>
              <h3 id="sc-weak-name" class="text-2xl font-extrabold tracking-tight mt-1">—</h3>
              <p id="sc-weak-text" class="mt-3 text-sm text-white/75 leading-relaxed"></p>
            </div>
          </div>

          <!-- Recommended next steps -->
          <div class="rounded-[28px] bg-white border border-dark/10 p-6 md:p-8 mb-10">
            <span class="text-[10px] font-mono uppercase tracking-widest text-dark/50">Recommended next steps</span>
            <h3 class="mt-2 text-xl md:text-2xl font-extrabold tracking-tight mb-5">Based on where you scored lowest.</h3>
            <ul id="sc-recs" class="space-y-3"></ul>
          </div>

          <!-- CTA -->
          <div class="rounded-[28px] bg-dark text-white p-8 md:p-10 relative overflow-hidden border border-dark shadow-[0px_5px_0px_#191a23]">
            <div class="absolute -top-20 -right-20 h-60 w-60 rounded-full bg-accent/20 blur-3xl"></div>
            <div class="relative grid lg:grid-cols-12 gap-8 items-start">
              <div class="lg:col-span-7">
                <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/15 text-[10px] font-mono uppercase tracking-widest text-white/70 mb-5">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
                  Next step · Operational Roadmap
                </span>
                <h3 class="text-2xl md:text-3xl font-extrabold tracking-tight leading-[1.15] mb-3">
                  Your score identifies the bottlenecks. <span class="text-accent">Your roadmap</span> shows you how to remove them.
                </h3>
                <p class="text-white/70 leading-relaxed mb-6">
                  During a 60-minute Operational Roadmap session a senior practitioner will:
                </p>
                <ul class="space-y-3 mb-2">
                  <li class="flex items-start gap-3 text-white/85">
                    <span class="mt-1 h-5 w-5 rounded-full bg-accent flex items-center justify-center shrink-0"><svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
                    <span class="text-sm leading-relaxed">Review your Business Operations Index™ in detail</span>
                  </li>
                  <li class="flex items-start gap-3 text-white/85">
                    <span class="mt-1 h-5 w-5 rounded-full bg-accent flex items-center justify-center shrink-0"><svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
                    <span class="text-sm leading-relaxed">Prioritize your highest-impact operational bottlenecks</span>
                  </li>
                  <li class="flex items-start gap-3 text-white/85">
                    <span class="mt-1 h-5 w-5 rounded-full bg-accent flex items-center justify-center shrink-0"><svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
                    <span class="text-sm leading-relaxed">Design your first 90-day operational roadmap</span>
                  </li>
                  <li class="flex items-start gap-3 text-white/85">
                    <span class="mt-1 h-5 w-5 rounded-full bg-accent flex items-center justify-center shrink-0"><svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
                    <span class="text-sm leading-relaxed">Recommend the systems, automation and AI that deliver the greatest impact at your stage</span>
                  </li>
                </ul>
              </div>
              <div class="lg:col-span-5 space-y-3">
                <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
                  <span class="text-[10px] font-mono uppercase tracking-widest text-accent">Free · 60 minutes</span>
                  <p class="mt-2 text-sm text-white/70 leading-relaxed">No prep required. No obligation. Walk out with a roadmap whether or not you work with us.</p>
                </div>
                <a id="sc-roadmap-cta" href="/contact?type=operational-roadmap" class="flex items-center justify-center gap-2 px-8 py-4 bg-accent text-white rounded-xl hover:bg-white hover:text-dark transition-colors font-medium w-full">
                  Get My Operational Roadmap
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
                <button type="button" id="sc-restart" class="px-8 py-4 bg-transparent text-white border border-white/30 rounded-xl hover:bg-white hover:text-dark transition-colors font-medium w-full">Retake the Index</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- 5 MATURITY STAGES (educational, always visible) -->
  <Section id="sc-stages">
    <div class="pb-24">
      <div class="max-w-3xl mb-10">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">The maturity model</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
          The 5 stages of <span class="text-accent">operational maturity</span>.
        </h2>
        <p class="mt-5 text-lg text-dark/70 leading-relaxed">
          Every business runs on an operating model. The Business Operations Index™ places you on one of five stages — and shows you what the next one looks like.
        </p>
      </div>
      <div class="grid md:grid-cols-5 gap-3">
        {stages.map((s, i) => (
          <div class={`relative rounded-[24px] p-6 border border-dark shadow-[0px_4px_0px_#191a23] ${i === 4 ? 'bg-accent text-white' : i === 3 ? 'bg-dark text-white' : 'bg-gray text-dark'}`}>
            <div class={`font-mono text-[10px] uppercase tracking-widest ${i >= 3 ? 'text-white/60' : 'text-dark/50'} mb-2`}>Stage {s.idx}</div>
            <h3 class="text-lg font-extrabold tracking-tight mb-3">{s.name}</h3>
            <p class={`text-sm leading-relaxed ${i >= 3 ? 'text-white/80' : 'text-dark/70'}`}>{s.blurb}</p>
            {i < 4 && (
              <div class="hidden md:flex absolute top-1/2 -right-2.5 -translate-y-1/2 items-center justify-center h-5 w-5 rounded-full bg-white border border-dark/20 z-10">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-dark"><polyline points="9 18 15 12 9 6"/></svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- 5 LAYERS → SERVICES MAP -->
  <Section id="sc-layers">
    <div class="pb-24">
      <div class="grid lg:grid-cols-12 gap-10 mb-10">
        <div class="lg:col-span-5">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">The framework</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
            Every system <span class="text-accent">maps to a layer</span>.
          </h2>
        </div>
        <div class="lg:col-span-7">
          <p class="text-lg text-dark/70 leading-relaxed">
            The five layers aren't abstract — every Global Tech Signal service plugs into one of them. The Business Operations Index™ tells you which layer is your weakest, and which services move you to the next stage.
          </p>
        </div>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-3">
        {layerServices.map((l, i) => (
          <div class="rounded-[24px] bg-white border border-dark/10 p-6 shadow-[0px_4px_0px_#191a23]">
            <div class="flex items-center justify-between mb-4">
              <span class="font-mono text-[10px] uppercase tracking-widest text-dark/50">Layer 0{i + 1}</span>
              <span class={`h-2 w-2 rounded-full ${i === 4 ? 'bg-accent animate-pulse' : 'bg-dark/20'}`}></span>
            </div>
            <h3 class="text-xl font-extrabold tracking-tight mb-4">{l.label}</h3>
            <ul class="space-y-1.5">
              {l.items.map((item) => (
                <li class="flex items-start gap-2 text-sm text-dark/70">
                  <span class="mt-1.5 h-1 w-1 rounded-full bg-dark/30 shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- WHAT'S NEXT -->
  <Section id="sc-next">
    <div class="pb-28">
      <div class="grid lg:grid-cols-3 gap-5">
        <a href="/operational-intelligence" class="group rounded-[24px] bg-gray border border-dark/10 p-7 hover:-translate-y-1 hover:border-dark transition-all shadow-[0px_4px_0px_#191a23]">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Read more</span>
          <h3 class="mt-3 text-xl font-extrabold tracking-tight">The Operational Intelligence category</h3>
          <p class="mt-3 text-sm text-dark/70 leading-relaxed">Understand the framework behind the Index.</p>
          <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-dark group-hover:text-accent transition-colors">
            Read the playbook
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
        <a href="/assessments" class="group rounded-[24px] bg-gray border border-dark/10 p-7 hover:-translate-y-1 hover:border-dark transition-all shadow-[0px_4px_0px_#191a23]">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Go deeper</span>
          <h3 class="mt-3 text-xl font-extrabold tracking-tight">Pick a focused assessment</h3>
          <p class="mt-3 text-sm text-dark/70 leading-relaxed">AI Readiness, Workflow Audit, Revenue Systems or Executive Strategy.</p>
          <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-dark group-hover:text-accent transition-colors">
            See assessments
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
        <a href="/case-studies" class="group rounded-[24px] bg-dark text-white border border-dark p-7 hover:-translate-y-1 transition-all shadow-[0px_5px_0px_#191a23]">
          <span class="text-xs font-mono uppercase tracking-widest text-accent">See outcomes</span>
          <h3 class="mt-3 text-xl font-extrabold tracking-tight">Real systems we've shipped</h3>
          <p class="mt-3 text-sm text-white/70 leading-relaxed">Revenue, time and visibility recovered — measured and named.</p>
          <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-accent">
            Browse case studies
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </Section>
</MainLayout>

<style>
  @keyframes sc-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .sc-float-card {
    animation: sc-float 5s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .sc-float-card { animation: none; }
  }
  /* Hide native radio dot since the whole label becomes the indicator */
  .sc-input { appearance: none; -webkit-appearance: none; width: 14px; height: 14px; border-radius: 50%; border: 2px solid #d4d4d4; background: transparent; }
  .sc-opt:has(.sc-input:checked) .sc-input { border-color: #fff; background: #fff; }
</style>

<script>
  type Dim = 'capture' | 'connect' | 'automate' | 'intelligence' | 'optimize';

  interface Stage { idx: number; min: number; max: number; name: string; blurb: string; }

  const STAGES: Stage[] = [
    { idx: 1, min: 0,  max: 6,  name: 'Patchwork Ops',   blurb: 'Disconnected systems, heavy manual work, knowledge lives with people. Normal at the start — and the single biggest leverage point for the next year of growth.' },
    { idx: 2, min: 7,  max: 12, name: 'Connected Ops',   blurb: "Core systems communicate. Processes remain partially manual. Connecting them into a real operating system unlocks compounding gains." },
    { idx: 3, min: 13, max: 18, name: 'Automated Ops',   blurb: 'Routine operational work runs automatically. Humans focus on exceptions. The next chapter is putting intelligence on top.' },
    { idx: 4, min: 19, max: 24, name: 'Intelligent Ops', blurb: 'AI supports decisions. Operational insights are proactive. Leaders trust real-time visibility.' },
    { idx: 5, min: 25, max: 30, name: 'Autonomous Ops',  blurb: 'Systems continuously optimize. AI recommends and orchestrates actions. Operations scale with minimal manual intervention.' },
  ];

  const NEXT_STAGE_ACTIONS: Record<number, string[]> = {
    1: ['Centralize where every customer & operational signal lands', 'Integrate your top 3 systems so they share one record', 'Document your top 3 workflows end-to-end'],
    2: ['Automate your highest-leverage workflows', 'Add alerting so you find process failures first', 'Move team handoffs into systems instead of Slack threads'],
    3: ['Add trusted live dashboards for leadership', 'Embed AI in 1–2 production workflows with guardrails', 'Introduce next-best-action recommendations in the workflow'],
    4: ['Add anomaly detection across operational KPIs', 'Orchestrate AI agents across multiple workflows', 'Run continuous improvement against measurable KPIs'],
    5: ['Run quarterly score reviews to stay at the frontier', 'Benchmark against industry leaders annually', 'Publish your operating model as a competitive asset'],
  };

  const DIM_LABELS: Record<Dim, string> = {
    capture: 'Capture',
    connect: 'Connect',
    automate: 'Automate',
    intelligence: 'Intelligence',
    optimize: 'Optimize',
  };

  // Strength callouts when this layer is strongest
  const STRONG_TEXT: Record<Dim, string> = {
    capture: 'You catch operational signal cleanly. The leverage now is what you do with it downstream.',
    connect: 'Your systems exchange data well. The leverage now is automating the handoffs you can already see.',
    automate: 'Your workflows run without heroics. The leverage now is putting intelligence on top of them.',
    intelligence: 'AI is already moving real business metrics for you. The leverage now is governance and reach.',
    optimize: 'You measure what you ship and retire what doesn\'t work. The leverage now is intelligence + reach.',
  };

  // Dynamic recommendations, keyed off the weakest layer
  const RECS: Record<Dim, { title: string; desc: string; href: string }[]> = {
    capture: [
      { title: 'Workflow Audit', desc: 'Map your highest-leakage capture flow end-to-end and design the connected replacement.', href: '/contact?type=workflow-audit' },
      { title: 'Revenue Systems Assessment', desc: 'When the worst capture leak is sales-side — start with a full lead-to-cash review.', href: '/contact?type=revenue-systems' },
      { title: 'CRM Architecture Review', desc: 'Re-think the data model and capture surface so every signal lands cleanly the first time.', href: '/contact?type=crm-architecture-review' },
    ],
    connect: [
      { title: 'Systems Integration Review', desc: 'Audit every system pair that should share data — and what currently fails between them.', href: '/contact?type=systems-integration-review' },
      { title: 'Data Architecture Assessment', desc: 'Design the truth layer so every tool, dashboard and AI agent agrees on the record.', href: '/contact?type=data-architecture-assessment' },
      { title: 'Integration Blueprint', desc: 'A prioritized integration roadmap with cost, complexity and ROI per connection.', href: '/contact?type=integration-blueprint' },
    ],
    automate: [
      { title: 'Automation Opportunity Review', desc: 'Map every manual handoff and rank it by hours-saved per quarter.', href: '/contact?type=automation-opportunity-review' },
      { title: 'Workflow Audit', desc: 'Pick the workflow that costs you the most hours and design the automated version.', href: '/contact?type=workflow-audit' },
      { title: 'Process Engineering Session', desc: 'Working session to redesign one operational process from first principles.', href: '/contact?type=process-engineering-session' },
    ],
    intelligence: [
      { title: 'AI Readiness Workshop', desc: 'Where AI will actually move business metrics in your stack — and where it won\'t.', href: '/contact?type=ai-readiness' },
      { title: 'Business Intelligence Review', desc: 'Audit your reporting layer and design the dashboards leadership can actually trust.', href: '/contact?type=business-intelligence-review' },
      { title: 'Decision Intelligence Assessment', desc: 'Identify the decisions that should be model-driven — not gut-driven.', href: '/contact?type=decision-intelligence-assessment' },
    ],
    optimize: [
      { title: 'Executive KPI Review', desc: 'Align leadership on the 5–10 numbers that should drive the next 12 months.', href: '/contact?type=executive-kpi-review' },
      { title: 'Continuous Improvement Plan', desc: 'Design the cadence and instrumentation that keeps your operating model improving.', href: '/contact?type=continuous-improvement-plan' },
      { title: 'Operational Performance Workshop', desc: 'Working session to retire workflows that no longer earn their keep.', href: '/contact?type=operational-performance-workshop' },
    ],
  };

  const form = document.getElementById('sc-form') as HTMLFormElement;
  const submitBtn = document.getElementById('sc-submit') as HTMLButtonElement;
  const progressBar = document.getElementById('sc-progress-bar') as HTMLDivElement;
  const progressLabel = document.getElementById('sc-progress-label') as HTMLSpanElement;
  const results = document.getElementById('sc-results') as HTMLDivElement;

  const allQuestions = Array.from(document.querySelectorAll<HTMLFieldSetElement>('.sc-q'));

  // Lenis-aware scroller. Falls back to native window.scrollTo if Lenis isn’t mounted.
  // The offset (-120) clears the sticky navbar so the target lands below it instead of behind it.
  function scrollToElement(el: HTMLElement) {
    const NAV_OFFSET = 120;
    const lenis = (window as any).__lenis;
    if (lenis && typeof lenis.scrollTo === 'function') {
      lenis.scrollTo(el, { offset: -NAV_OFFSET });
      return;
    }
    const y = el.getBoundingClientRect().top + window.scrollY - NAV_OFFSET;
    window.scrollTo({ top: y < 0 ? 0 : y, behavior: 'smooth' });
  }

  function updateProgress() {
    const answered = allQuestions.filter((q) => q.querySelector<HTMLInputElement>('input:checked')).length;
    const total = allQuestions.length;
    progressLabel.textContent = `${answered} / ${total} answered`;
    progressBar.style.width = `${(answered / total) * 100}%`;
    submitBtn.disabled = answered < total;
  }

  form?.addEventListener('change', updateProgress);

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const byDim: Record<Dim, number> = { capture: 0, connect: 0, automate: 0, intelligence: 0, optimize: 0 };

    allQuestions.forEach((q) => {
      const dim = (q.dataset.dim as Dim);
      const selected = q.querySelector<HTMLInputElement>('input:checked');
      if (selected && dim) byDim[dim] += parseInt(selected.value, 10);
    });

    const total = Object.values(byDim).reduce((a, b) => a + b, 0);
    const stage = STAGES.find((s) => total >= s.min && total <= s.max) || STAGES[0];
    const nextStage = STAGES.find((s) => s.idx === stage.idx + 1) || stage;

    // Find strongest + weakest (deterministic — first match in declaration order)
    const dimEntries = Object.entries(byDim) as [Dim, number][];
    let strongest = dimEntries[0];
    let weakest = dimEntries[0];
    for (const e of dimEntries) {
      if (e[1] > strongest[1]) strongest = e;
      if (e[1] < weakest[1]) weakest = e;
    }

    // Sort layers ascending by score so we can pick the 2 weakest for personalized progress actions
    const sortedAsc = [...dimEntries].sort((a, b) => a[1] - b[1]);

    // Populate score + tier
    (document.getElementById('sc-total') as HTMLSpanElement).textContent = String(total);
    (document.getElementById('sc-tier-name') as HTMLSpanElement).textContent = stage.name;
    (document.getElementById('sc-tier-blurb') as HTMLParagraphElement).textContent = stage.blurb;
    (document.getElementById('sc-stage-idx') as HTMLSpanElement).textContent = String(stage.idx);

    // Current → Next stage card
    (document.getElementById('sc-current-stage') as HTMLHeadingElement).textContent = `Stage ${stage.idx} · ${stage.name}`;
    (document.getElementById('sc-current-blurb') as HTMLParagraphElement).textContent = stage.blurb;
    if (stage.idx === 5) {
      (document.getElementById('sc-next-stage') as HTMLHeadingElement).textContent = 'You\u2019re at the frontier.';
      (document.getElementById('sc-next-blurb') as HTMLParagraphElement).textContent = 'There is no next stage — only the discipline of staying here. Quarterly score reviews and benchmarking keep your operating model ahead of the market.';
    } else {
      (document.getElementById('sc-next-stage') as HTMLHeadingElement).textContent = `Stage ${nextStage.idx} · ${nextStage.name}`;
      (document.getElementById('sc-next-blurb') as HTMLParagraphElement).textContent = nextStage.blurb;
    }

    // Progress required: 2 layer-personalized + 1 stage-generic
    const progressActions: string[] = [];
    if (stage.idx < 5) {
      // Personalize first 2 with the user's lowest layers
      progressActions.push(`Improve <strong>${DIM_LABELS[sortedAsc[0][0]]}</strong> — your weakest layer today.`);
      if (sortedAsc[1][1] < 5) {
        progressActions.push(`Reinforce <strong>${DIM_LABELS[sortedAsc[1][0]]}</strong> alongside it.`);
      } else {
        progressActions.push(NEXT_STAGE_ACTIONS[stage.idx][0]);
      }
      progressActions.push(NEXT_STAGE_ACTIONS[stage.idx][1]);
    } else {
      progressActions.push(...NEXT_STAGE_ACTIONS[5]);
    }

    const actionsList = document.getElementById('sc-progress-actions') as HTMLUListElement;
    actionsList.innerHTML = '';
    progressActions.forEach((text, i) => {
      const li = document.createElement('li');
      li.className = 'flex items-start gap-3 p-4 rounded-xl bg-gray border border-dark/10';
      li.innerHTML = `
        <span class="flex items-center justify-center h-7 w-7 rounded-full bg-dark text-white text-[10px] font-mono shrink-0">${String(i + 1).padStart(2, '0')}</span>
        <span class="text-sm text-dark leading-relaxed">${text}</span>
      `;
      actionsList.appendChild(li);
    });

    // Per-dimension cards
    dimEntries.forEach(([dim, score]) => {
      const card = document.querySelector<HTMLDivElement>(`[data-dim-card="${dim}"]`);
      if (!card) return;
      const scoreEl = card.querySelector<HTMLSpanElement>('.sc-dim-score');
      const barEl = card.querySelector<HTMLDivElement>('.sc-dim-bar');
      if (scoreEl) scoreEl.textContent = String(score);
      if (barEl) barEl.style.width = `${(score / 6) * 100}%`;
    });

    (document.getElementById('sc-strong-name') as HTMLHeadingElement).textContent = DIM_LABELS[strongest[0]];
    (document.getElementById('sc-strong-text') as HTMLParagraphElement).textContent = STRONG_TEXT[strongest[0]];

    (document.getElementById('sc-weak-name') as HTMLHeadingElement).textContent = DIM_LABELS[weakest[0]];
    (document.getElementById('sc-weak-text') as HTMLParagraphElement).textContent = `Strengthening your ${DIM_LABELS[weakest[0]]} layer is where you\u2019ll get the most leverage next. Below are three focused engagements to start.`;

    // Recommendations
    const recsList = document.getElementById('sc-recs') as HTMLUListElement;
    recsList.innerHTML = '';
    RECS[weakest[0]].forEach((r, i) => {
      const li = document.createElement('li');
      li.innerHTML = `
        <a href="${r.href}" class="group flex items-start gap-4 p-4 rounded-xl border border-dark/10 hover:border-dark hover:-translate-y-0.5 transition-all">
          <span class="flex items-center justify-center h-9 w-9 rounded-xl bg-dark text-white text-xs font-mono shrink-0">${String(i + 1).padStart(2, '0')}</span>
          <div class="flex-1">
            <h4 class="text-base font-extrabold tracking-tight text-dark">${r.title}</h4>
            <p class="mt-1 text-sm text-dark/70 leading-relaxed">${r.desc}</p>
          </div>
          <svg class="w-5 h-5 text-dark/30 group-hover:text-accent group-hover:translate-x-1 transition-all shrink-0 mt-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      `;
      recsList.appendChild(li);
    });

    // Decorate the roadmap CTA with the user's stage so the form can show context
    const roadmapCta = document.getElementById('sc-roadmap-cta') as HTMLAnchorElement | null;
    if (roadmapCta) {
      roadmapCta.href = `/contact?type=operational-roadmap&stage=${stage.idx}&weak=${weakest[0]}`;
    }

    // Hide form, show results
    form.classList.add('hidden');
    results.classList.remove('hidden');
    scrollToElement(results);
  });

  document.getElementById('sc-restart')?.addEventListener('click', () => {
    form.reset();
    results.classList.add('hidden');
    form.classList.remove('hidden');
    updateProgress();
    scrollToElement(form);
  });

  // Initial state
  updateProgress();
</script>

