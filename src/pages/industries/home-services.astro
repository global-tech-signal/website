    { tone: "accent", icon: "message", title: "Booking — AC Not Cooling", subtitle: "Routed to Same-day · Mike ETA 2:15" },
    { tone: "blue", icon: "wrench", title: "Tech Dispatched — Job #2841", subtitle: "Parts pre-staged · GPS en route" },
    { tone: "amber", icon: "doc", title: "Estimate Sent — $1,840", subtitle: "Customer texted · 1-click approve" },
