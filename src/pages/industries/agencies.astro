  heroIntro="New business, project management, time tracking, financials and client reporting shouldn't be 8 disconnected tools and a Slack channel. We design a connected operations system that takes a client from pitch to onboarded to retained — with live utilization, project profitability and clear next steps for every account."
  feedTitle="Live Agency Pulse"
  feedBadge="14 Active Engagements"
  feedItems={[
    { tone: "blue", icon: "briefcase", title: "New Lead — Mid-market SaaS", subtitle: "Qualified · routed to New Business" },
    { tone: "amber", icon: "doc", title: "Proposal Sent — $48K project", subtitle: "DocuSign opened · followed up" },
    { tone: "accent", icon: "check", title: "Project Kicked Off — Q4 Brand", subtitle: "Team staffed · client portal live" },
