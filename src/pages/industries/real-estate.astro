---
import MainLayout from "../../layouts/MainLayout.astro";
import Section from "../../components/sections/Section.astro";
import SectionTitle from "../../components/ui/SectionTitle.astro";
---

<MainLayout
  title="CRM & Automation for Real Estate — GlobalTechSignal"
  description="Close more deals, automate follow-ups, and manage your pipeline effortlessly. Custom CRM and automation solutions built for real estate teams."
>
  <!-- ═══════════════════════════════════════════ HERO ═══════════════════════════════════════════ -->
  <Section id="real-estate-hero">
    <div class="relative flex flex-col-reverse items-center md:flex-row pt-10 pb-10" id="hero">
      <div class="items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <div class="text-left space-y-3">
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-gray text-xs font-medium text-dark">
            <span class="w-2 h-2 rounded-full bg-accent"></span>
            Real Estate &middot; CRM &middot; Automation
          </span>
          <h1 class="text-4xl font-medium leading-tight md:text-6xl text-center md:text-left tracking-tight">
            Stop Losing Leads. <span class="redhead">Automate Your Real Estate CRM.</span>
          </h1>
          <p class="mt-6 mb-12 text-lg font-normal leading-7 sm:mb-12 text-center md:text-left md:pr-12 text-dark/70">
            Purpose-built CRM and workflow automation that helps agents and brokerages capture every lead, nurture prospects automatically, and close deals faster.
          </p>
          <div class="w-full flex flex-col sm:flex-row gap-4 justify-center md:justify-start items-center">
            <a href="#lead-form" class="px-8 py-4 bg-dark hover:bg-accent rounded-xl text-center text-white text-base font-medium transition-colors">
              Get a Free Consultation
            </a>
            <a href="#features" class="px-8 py-4 bg-white hover:bg-dark hover:text-white rounded-xl text-center text-dark border border-dark/20 text-base font-medium transition-colors">
              See How It Works
            </a>
          </div>
        </div>
      </div>
      <div class="flex items-center justify-center w-full max-w-[280px] sm:max-w-[360px] md:max-w-none md:w-6/12 md:pb-20 pt-5 md:pt-10 mx-auto md:mx-0">
        <div class="w-full space-y-3">
          <!-- Dashboard mockup — light theme -->
          <div class="bg-gray border border-dark/10 rounded-2xl p-5 space-y-3">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-semibold text-dark">Live Pipeline</span>
              <span class="text-[11px] px-2.5 py-0.5 rounded-full bg-accent/10 text-accent font-medium">12 Active Deals</span>
            </div>
            <div class="re-float-card bg-white border border-dark/10 rounded-xl p-3 flex items-center gap-3 shadow-sm">
              <div class="w-9 h-9 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-accent" stroke-width="2.2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-dark truncate">New Lead — Zillow</p>
                <p class="text-xs text-dark/40">Auto-assigned to Sarah · 3s ago</p>
              </div>
              <span class="shrink-0 w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            </div>
            <div class="re-float-card bg-white border border-dark/10 rounded-xl p-3 flex items-center gap-3 shadow-sm" style="animation-delay:.3s">
              <div class="w-9 h-9 rounded-full bg-green-100 flex items-center justify-center shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-green-600" stroke-width="2.2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-dark truncate">Follow-up Sent</p>
                <p class="text-xs text-dark/40">Drip email #2 · automated</p>
              </div>
            </div>
            <div class="re-float-card bg-white border border-dark/10 rounded-xl p-3 flex items-center gap-3 shadow-sm" style="animation-delay:.6s">
              <div class="w-9 h-9 rounded-full bg-blue-100 flex items-center justify-center shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-blue-600" stroke-width="2.2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-dark truncate">Showing Booked</p>
                <p class="text-xs text-dark/40">Tomorrow at 2:00 PM · 3 bed</p>
              </div>
            </div>
            <div class="re-float-card bg-accent text-white rounded-xl p-3 flex items-center gap-3" style="animation-delay:.9s">
              <div class="w-9 h-9 rounded-full bg-white/20 flex items-center justify-center shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-white" stroke-width="2.2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold truncate">Deal Closed — $425K</p>
                <p class="text-xs text-white/70">Commission logged ✓</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pb-12 md:pb-20 text-white">
      <div class="bg-dark border border-dark rounded-2xl p-5 text-center shadow-[0px_4px_0px_#191a23]">
        <span class="text-3xl sm:text-4xl font-extrabold text-accent">2x</span>
        <p class="text-xs text-white/50 mt-1">Avg. conversion lift</p>
      </div>
      <div class="bg-dark border border-dark rounded-2xl p-5 text-center shadow-[0px_4px_0px_#191a23]">
        <span class="text-3xl sm:text-4xl font-extrabold text-white">&lt;2m</span>
        <p class="text-xs text-white/50 mt-1">Lead response time</p>
      </div>
      <div class="bg-dark border border-dark rounded-2xl p-5 text-center shadow-[0px_4px_0px_#191a23]">
        <span class="text-3xl sm:text-4xl font-extrabold text-white">8h+</span>
        <p class="text-xs text-white/50 mt-1">Saved per agent / week</p>
      </div>
      <div class="bg-dark border border-dark rounded-2xl p-5 text-center shadow-[0px_4px_0px_#191a23]">
        <span class="text-3xl sm:text-4xl font-extrabold text-white">50+</span>
        <p class="text-xs text-white/50 mt-1">CRM projects shipped</p>
      </div>
    </div>
  </Section>

  <!-- ═══════════════════════════════════════ PAIN POINTS ═══════════════════════════════════════ -->
  <Section id="pain-points">
    <div class="pb-20 md:pb-32">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
        <div class="flex flex-col gap-5 max-w-2xl">
          <span class="inline-flex items-center gap-2 text-sm font-medium w-fit">
            <span class="h-2 w-2 rounded-full bg-accent"></span>
            The problem
          </span>
          <h2 class="text-4xl sm:text-5xl font-extrabold leading-[1.08] tracking-tight">
            Sound <span class="text-accent">familiar?</span>
          </h2>
        </div>
        <p class="max-w-md text-dark/60">Challenges real estate teams face every day without proper CRM and automation.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 pb-2">
        <div class="bg-gray rounded-2xl p-6 md:p-7 border border-dark shadow-[0px_4px_0px_#191a23] group hover:-translate-y-1 transition-transform duration-300">
          <span class="text-3xl font-extrabold text-dark/5 group-hover:text-accent/10 transition-colors">01</span>
          <h3 class="text-lg font-bold mt-3 mb-2">Leads Slipping Through&nbsp;Cracks</h3>
          <p class="text-dark/60 leading-relaxed text-sm">Inquiries from Zillow, Realtor.com, your website, and social media land in different inboxes. Hot prospects go cold before anyone follows up.</p>
        </div>
        <div class="bg-dark text-white rounded-2xl p-6 md:p-7 border border-dark shadow-[0px_4px_0px_#191a23] group hover:-translate-y-1 transition-transform duration-300">
          <span class="text-3xl font-extrabold text-white/5 group-hover:text-accent/20 transition-colors">02</span>
          <h3 class="text-lg font-bold mt-3 mb-2">Hours Wasted on Manual&nbsp;Tasks</h3>
          <p class="text-white/60 leading-relaxed text-sm">Copying data between spreadsheets, sending the same emails over and over, and manually updating listing statuses eats into selling time.</p>
        </div pt-10>
        <div class="bg-gray rounded-2xl p-6 md:p-7 border border-dark shadow-[0px_4px_0px_#191a23] group hover:-translate-y-1 transition-transform duration-300">
          <span class="text-3xl font-extrabold text-dark/5 group-hover:text-accent/10 transition-colors">03</span>
          <h3 class="text-lg font-bold mt-3 mb-2">No Visibility Across Your&nbsp;Team</h3>
          <p class="text-dark/60 leading-relaxed text-sm">Agents work in silos. Managers can't see pipeline status, and deals get duplicated or neglected — no single source of truth.</p>
        </div>
        <div class="bg-accent text-white rounded-2xl p-6 md:p-7 border border-dark shadow-[0px_4px_0px_#191a23] group hover:-translate-y-1 transition-transform duration-300">
          <span class="text-3xl font-extrabold text-white/10 group-hover:text-white/20 transition-colors">04</span>
          <h3 class="text-lg font-bold mt-3 mb-2">Generic Tools That Don't&nbsp;Fit</h3>
          <p class="text-white/80 leading-relaxed text-sm">Off-the-shelf CRMs weren't built for real estate — property stages, showing schedules, commission splits, and MLS integrations are missing.</p>
        </div>
        <div class="bg-dark text-white rounded-2xl p-6 md:p-7 border border-dark shadow-[0px_4px_0px_#191a23] group hover:-translate-y-1 transition-transform duration-300">
          <span class="text-3xl font-extrabold text-white/5 group-hover:text-accent/20 transition-colors">05</span>
          <h3 class="text-lg font-bold mt-3 mb-2">Can't Measure What's&nbsp;Working</h3>
          <p class="text-white/60 leading-relaxed text-sm">You don't know which lead sources convert, which agents perform best, or where deals stall in your pipeline.</p>
        </div>
        <div class="bg-gray rounded-2xl p-6 md:p-7 border border-dark shadow-[0px_4px_0px_#191a23] group hover:-translate-y-1 transition-transform duration-300">
          <span class="text-3xl font-extrabold text-dark/5 group-hover:text-accent/10 transition-colors">06</span>
          <h3 class="text-lg font-bold mt-3 mb-2">Inconsistent Client&nbsp;Communication</h3>
          <p class="text-dark/60 leading-relaxed text-sm">Buyers and sellers expect fast, personalized updates. Without automation, response times suffer and clients feel ignored.</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- ════════════════════════════════════════ FEATURES ════════════════════════════════════════ -->
  <Section id="features">
    <div class="pb-20 md:pb-32">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
        <div class="flex flex-col gap-5 max-w-2xl">
          <span class="inline-flex items-center gap-2 text-sm font-medium w-fit">
            <span class="h-2 w-2 rounded-full bg-accent"></span>
            What you get
          </span>
          <h2 class="text-4xl sm:text-5xl font-extrabold leading-[1.08] tracking-tight">
            Built for <span class="text-accent">real estate</span>
          </h2>
        </div>
        <p class="max-w-md text-dark/60">Everything your team needs to capture, nurture, and close — on autopilot.</p>
      </div>

      <!-- Bento grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 md:gap-6 pb-2">
        <!-- Feature 1 — wide -->
        <div class="lg:col-span-2 bg-dark text-white rounded-2xl p-6 md:p-8 border border-dark shadow-[0px_4px_0px_#191a23] relative overflow-hidden">
          <div class="absolute top-0 right-0 w-48 h-48 bg-accent/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          <span class="inline-block px-3 py-1 rounded-full bg-accent/20 text-accent text-xs font-semibold mb-4">Core</span>
          <h3 class="text-xl sm:text-2xl font-bold mb-3">Lead Capture & Routing</h3>
          <p class="text-white/60 leading-relaxed max-w-xl mb-5 text-sm">Automatically pull leads from Zillow, Realtor.com, Facebook Ads, your website, and more into one pipeline. Round-robin or rule-based assignment ensures every lead gets an owner instantly.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[11px] px-3 py-1.5 rounded-full bg-white/10 text-white/70">Multi-source aggregation</span>
            <span class="text-[11px] px-3 py-1.5 rounded-full bg-white/10 text-white/70">Instant assignment</span>
            <span class="text-[11px] px-3 py-1.5 rounded-full bg-white/10 text-white/70">Duplicate detection</span>
            <span class="text-[11px] px-3 py-1.5 rounded-full bg-accent/20 text-accent">Zillow + MLS ready</span>
          </div>
        </div>

        <!-- Feature 2 — narrow -->
        <div class="bg-accent text-white rounded-2xl p-6 md:p-7 border border-dark shadow-[0px_4px_0px_#191a23] flex flex-col justify-between">
          <div>
            <span class="inline-block px-3 py-1 rounded-full bg-white/20 text-white text-xs font-semibold mb-4">Automation</span>
            <h3 class="text-xl font-bold mb-3">Automated Follow-Ups</h3>
            <p class="text-white/80 leading-relaxed mb-5 text-sm">Drip email sequences, SMS reminders, and task triggers fire automatically. Speed-to-lead goes from hours to seconds.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="text-[11px] px-3 py-1.5 rounded-full bg-white/20 text-white/90">Email & SMS drips</span>
            <span class="text-[11px] px-3 py-1.5 rounded-full bg-white/20 text-white/90">Behavior triggers</span>
          </div>
        </div>

        <!-- Feature 3 — narrow -->
        <div class="bg-gray rounded-2xl p-6 md:p-7 border border-dark shadow-[0px_4px_0px_#191a23] flex flex-col justify-between">
          <div>
            <span class="inline-block px-3 py-1 rounded-full bg-dark/10 text-dark text-xs font-semibold mb-4">Pipeline</span>
            <h3 class="text-xl font-bold mb-3">Deal Management</h3>
            <p class="text-dark/60 leading-relaxed mb-5 text-sm">Visual Kanban tailored to real estate stages — inquiry → showing → offer → contract → closed. Drag-and-drop with full audit trails.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="text-[11px] px-3 py-1.5 rounded-full bg-dark text-white">Custom stages</span>
            <span class="text-[11px] px-3 py-1.5 rounded-full bg-dark text-white">Commission splits</span>
          </div>
        </div>

        <!-- Feature 4 — wide -->
        <div class="lg:col-span-2 bg-dark text-white rounded-2xl p-6 md:p-8 border border-dark shadow-[0px_4px_0px_#191a23] relative overflow-hidden">
          <div class="absolute bottom-0 left-0 w-48 h-48 bg-accent/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
          <div class="relative flex flex-col md:flex-row md:items-center md:justify-between gap-5">
            <div class="max-w-md">
              <span class="inline-block px-3 py-1 rounded-full bg-accent/20 text-accent text-xs font-semibold mb-4">Analytics</span>
              <h3 class="text-xl sm:text-2xl font-bold mb-3">Reporting & Dashboards</h3>
              <p class="text-white/60 leading-relaxed text-sm">Real-time dashboards showing lead source ROI, agent performance, conversion rates, and revenue forecasts. Know exactly where your business stands.</p>
            </div>
            <div class="flex flex-row md:flex-col gap-3 shrink-0">
              <div class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-center">
                <span class="text-xl font-extrabold text-accent">ROI</span>
                <p class="text-[10px] text-white/40 mt-0.5">per lead source</p>
              </div>
              <div class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-center">
                <span class="text-xl font-extrabold text-white">#1</span>
                <p class="text-[10px] text-white/40 mt-0.5">agent ranking</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- ═══════════════════════════════════════ TESTIMONIALS ═══════════════════════════════════════ -->
  <Section id="testimonials">
    <div class="pb-20 md:pb-32">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
        <div class="flex flex-col gap-5 max-w-2xl">
          <span class="inline-flex items-center gap-2 text-sm font-medium w-fit">
            <span class="h-2 w-2 rounded-full bg-accent"></span>
            Social proof
          </span>
          <h2 class="text-4xl sm:text-5xl font-extrabold leading-[1.08] tracking-tight">
            Trusted by <span class="text-accent">real estate</span> teams
          </h2>
        </div>
      </div>

      <div class="rounded-2xl bg-dark p-6 md:p-10 border border-dark shadow-[0px_4px_0px_#191a23] mb-2">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-white">
          <div class="relative">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-accent/30 mb-4"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-white/80 leading-relaxed mb-8">"We went from losing 40% of our web leads to responding within 2 minutes. Our conversion rate <span class="text-accent font-semibold">doubled in 3 months</span>. This CRM paid for itself in the first week."</p>
            <div class="flex items-center gap-3">
              <div class="w-11 h-11 rounded-full bg-accent/20 flex items-center justify-center text-sm font-bold text-accent">MR</div>
              <div>
                <p class="text-sm font-semibold text-white">Michael Rodriguez</p>
                <p class="text-xs text-white/40">Broker, Summit Realty Group</p>
              </div>
            </div>
          </div>
          <div class="relative">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-accent/30 mb-4"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-white/80 leading-relaxed mb-8">"The automated drip campaigns alone saved each agent <span class="text-accent font-semibold">8+ hours per week</span>. Now they focus on showings and closing instead of chasing follow-ups."</p>
            <div class="flex items-center gap-3">
              <div class="w-11 h-11 rounded-full bg-accent/20 flex items-center justify-center text-sm font-bold text-accent">JT</div>
              <div>
                <p class="text-sm font-semibold text-white">Jessica Torres</p>
                <p class="text-xs text-white/40">Team Lead, Prestige Properties</p>
              </div>
            </div>
          </div>
          <div class="relative">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-accent/30 mb-4"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-white/80 leading-relaxed mb-8">"Finally a CRM that understands real estate. The pipeline stages match our actual workflow, and the <span class="text-accent font-semibold">commission tracking eliminated spreadsheet headaches</span> entirely."</p>
            <div class="flex items-center gap-3">
              <div class="w-11 h-11 rounded-full bg-accent/20 flex items-center justify-center text-sm font-bold text-accent">DK</div>
              <div>
                <p class="text-sm font-semibold text-white">David Kim</p>
                <p class="text-xs text-white/40">Owner, Keystone Real Estate</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- ═══════════════════════════════════════════ FAQ ═══════════════════════════════════════════ -->
  <Section id="faq">
    <div class="pb-20 md:pb-20">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
        <div class="flex flex-col gap-5 max-w-2xl">
          <span class="inline-flex items-center gap-2 text-sm font-medium w-fit">
            <span class="h-2 w-2 rounded-full bg-accent"></span>
            FAQ
          </span>
          <h2 class="text-4xl sm:text-5xl font-extrabold leading-[1.08] tracking-tight">
            Got <span class="text-accent">questions?</span>
          </h2>
        </div>
      </div>

      <div class="space-y-4 pb-2">
        <details class="group bg-gray rounded-2xl border border-dark shadow-[0px_4px_0px_#191a23] overflow-hidden">
          <summary class="flex items-center justify-between cursor-pointer px-6 md:px-8 py-5 font-bold text-base md:text-lg">
            <div class="flex items-center gap-4">
              <span class="hidden sm:block text-2xl text-dark/10 group-open:text-accent/30 transition-colors">01</span>
              How long does it take to set up the CRM?
            </div>
            <div class="bg-white w-9 h-9 flex justify-center items-center rounded-full border border-dark shrink-0 ml-4">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-dark group-open:rotate-180 transition-transform duration-300" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </div>
          </summary>
          <div class="px-6 md:px-8 pb-6 text-dark/70 leading-relaxed text-sm border-t border-dark/10 pt-4 sm:ml-12">
            Most real estate teams are fully onboarded within 2–4 weeks. This includes data migration, custom pipeline setup, automation configuration, and team training. Simple setups can go live in as little as 5 business days.
          </div>
        </details>
        <details class="group bg-gray rounded-2xl border border-dark shadow-[0px_4px_0px_#191a23] overflow-hidden">
          <summary class="flex items-center justify-between cursor-pointer px-6 md:px-8 py-5 font-bold text-base md:text-lg">
            <div class="flex items-center gap-4">
