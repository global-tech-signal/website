  <script>
    const form = document.getElementById('re-lead-form') as HTMLFormElement;
    const status = document.getElementById('re-lead-status') as HTMLParagraphElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Sending...';
      status.classList.add('hidden');

      try {
        const fd = new FormData(form);
        // Compose extra fields into the message so the API receives everything
        const company = fd.get('company')?.toString().trim();
        const teamSize = fd.get('team_size')?.toString().trim();
        let msg = fd.get('message')?.toString() || '';
        if (company) msg += `\n\nBrokerage: ${company}`;
        if (teamSize) msg += `\nTeam size: ${teamSize}`;
        msg += '\n\n[Source: Real Estate Landing Page]';
        fd.set('message', msg);

        const res = await fetch('/api/contact', {
          method: 'POST',
          body: fd,
        });
        const json = await res.json();

        if (res.ok) {
          status.textContent = 'Thank you! We\'ll reach out within 1 business day.';
          status.className = 'mt-3 text-center text-sm text-green-600';
          status.classList.remove('hidden');
          form.reset();
        } else {
          status.textContent = json.error || 'Something went wrong. Please try again.';
          status.className = 'mt-3 text-center text-sm text-red-500';
          status.classList.remove('hidden');
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.className = 'mt-3 text-center text-sm text-red-500';
        status.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Book My Free Consultation';
      }
    });
  </script>
