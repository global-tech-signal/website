<script>
  // Lite YouTube facade — replaces a thumbnail with a privacy-friendly iframe on click.
  // Hides YouTube branding pre-click and minimizes it during playback via nocookie domain
  // and modestbranding/rel/showinfo/iv_load_policy params.
  document.querySelectorAll<HTMLElement>('.lite-yt').forEach((el) => {
    const thumb = el.querySelector<HTMLImageElement>('.lite-yt-thumb');
    if (thumb) {
      const swapToFallback = () => {
        const fb = thumb.dataset.fallback;
        if (fb && thumb.src !== fb) {
          thumb.src = fb;
          // hqdefault has 4:3 letterboxing — scale to crop the black bars
          thumb.classList.add('lite-yt-thumb--fallback');
        }
      };
      // YouTube returns a 120x90 placeholder (HTTP 200) when maxresdefault is missing,
      // so we check naturalWidth instead of relying on the error event alone.
      thumb.addEventListener('load', () => {
        if (thumb.naturalWidth > 0 && thumb.naturalWidth <= 120) swapToFallback();
      });
      thumb.addEventListener('error', swapToFallback);
      // If already loaded (cached) before listener attached, check immediately
      if (thumb.complete && thumb.naturalWidth > 0 && thumb.naturalWidth <= 120) {
        swapToFallback();
      }
    }

    const activate = () => {
      const id = el.dataset.videoId;
      if (!id) return;
      const params = 'autoplay=1&rel=0&modestbranding=1&showinfo=0&iv_load_policy=3&playsinline=1&color=white';
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?${params}`;
      iframe.title = el.getAttribute('aria-label') ?? 'Video player';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.setAttribute('allowfullscreen', '');
      iframe.className = 'absolute inset-0 w-full h-full';
      el.replaceChildren(iframe);
      el.classList.remove('cursor-pointer', 'group');
    };

    el.addEventListener('click', activate);
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        activate();
      }
    });

    // Warm the connection on hover for faster click-to-play
    const warm = () => {
      ['https://www.youtube-nocookie.com', 'https://i.ytimg.com', 'https://www.google.com'].forEach((href) => {
        if (document.head.querySelector(`link[rel="preconnect"][href="${href}"]`)) return;
        const link = document.createElement('link');
        link.rel = 'preconnect';
        link.href = href;
        document.head.appendChild(link);
      });
    };
    el.addEventListener('pointerover', warm, { once: true });
    el.addEventListener('focus', warm, { once: true });
  });
</script>

<style>
  @keyframes hero-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .hero-float-card {
    animation: hero-float 4s ease-in-out infinite;
  }
  /* Thumbnail hover scale (kept in CSS so it composes cleanly with the fallback transform). */
  .lite-yt-thumb {
    transition: transform 500ms ease;
    transform: scale(1);
  }
  .lite-yt:hover .lite-yt-thumb {
    transform: scale(1.05);
  }
  /* When falling back to hqdefault.jpg (4:3), scale to crop the black letterbox bars. */
  .lite-yt-thumb--fallback {
    transform: scale(1.36);
  }
  .lite-yt:hover .lite-yt-thumb--fallback {
    transform: scale(1.43);
  }
</style>
