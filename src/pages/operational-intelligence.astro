---
import MainLayout from "../layouts/MainLayout.astro";
import Section from "../components/sections/Section.astro";

const definition = {
  title: "Operational Intelligence",
  blurb:
    "The practice of designing, connecting, automating and continuously improving the way a business operates — using AI, integrated systems and live data — so that revenue, customer experience and decision-making compound over time instead of fragmenting.",
};

const competitors = [
  { tag: "AI Consultancies", owns: "Models & demos", missing: "Operational integration. Most AI never reaches a real business workflow." },
  { tag: "CRM Agencies", owns: "Pipelines in a single tool", missing: "Everything outside the CRM — finance, fulfilment, support, ops." },
  { tag: "RevOps Firms", owns: "Sales & marketing ops", missing: "Delivery, customer success, finance and the rest of the operating model." },
  { tag: "Digital Transformation", owns: "Big roadmaps & frameworks", missing: "Working systems shipped in weeks, not 18-month programmes." },
];

const framework = [
  {
    n: "01",
    name: "Capture",
    desc: "Lead, customer, order, support and operational signal lands in one trusted place — not five tools, three spreadsheets and a Slack thread.",
  },
  {
    n: "02",
    name: "Connect",
    desc: "CRM, finance, support, ops and product platforms exchange data through governed integrations so every team sees the same record.",
  },
  {
    n: "03",
    name: "Automate",
    desc: "Repetitive handoffs — qualification, follow-up, routing, reporting, billing — run as systems with clear ownership, not human ticking lists.",
  },
  {
    n: "04",
    name: "Intelligence",
    desc: "AI agents, scoring and decision support are embedded inside the workflows that already exist — not bolted on as isolated demos.",
  },
  {
    n: "05",
    name: "Optimize",
    desc: "Live dashboards, KPIs and operational telemetry close the loop — so leadership sees what changed, what worked and where to invest next.",
  },
];

const systems = [
  { name: "Revenue Systems", desc: "Custom CRM, lead capture, scoring, routing, automation — built around how you actually sell.", href: "/services/revenue-systems" },
  { name: "Operations Systems", desc: "Connected workflows that eliminate manual handoffs between teams and tools.", href: "/services/operations-systems" },
  { name: "Customer Systems", desc: "One source of truth for every customer interaction across sales, support and success.", href: "/services/customer-systems" },
  { name: "Business Intelligence", desc: "Real dashboards, real metrics, real-time — visibility leadership can trust.", href: "/services/business-intelligence" },
  { name: "AI Operations", desc: "AI agents and copilots embedded inside business systems that remove operational work.", href: "/services/ai-operations" },
  { name: "Digital Experience", desc: "Web, portals and product surfaces wired into the same operational fabric.", href: "/services/digital-experience" },
];

const ladder = [
  { name: "Operational Assessment", duration: "60 min · Free", desc: "Map where revenue, time and visibility are leaking. Best first step.", href: "/contact" },
  { name: "AI Readiness Assessment", duration: "90 min", desc: "Where AI will actually move business metrics — and where it won't.", href: "/assessments#ai-readiness" },
  { name: "Workflow Audit", duration: "2 weeks", desc: "Deep dive on one workflow that's costing you hours, revenue or NPS.", href: "/assessments#workflow-audit" },
  { name: "Revenue Systems Assessment", duration: "2 weeks", desc: "Pipeline, CRM, lead-to-cash and reporting reviewed end-to-end.", href: "/assessments#revenue-systems" },
  { name: "Executive Strategy Session", duration: "Half day", desc: "Working session with your leadership team to align operations and growth.", href: "/assessments#executive-strategy" },
];

const pillars = [
  "Operational Intelligence",
  "AI Operations",
  "Business Systems",
  "Process Engineering",
  "Workflow Architecture",
  "Revenue Systems",
  "Customer Systems",
  "Business Intelligence",
  "Decision Intelligence",
  "AI Governance",
  "Operational KPIs",
];

const faqs = [
  {
    q: "How is Operational Intelligence different from RevOps or AI consulting?",
    a: "RevOps owns sales & marketing. AI consultants own models. Operational Intelligence owns the operating model of the whole business — how revenue, delivery, customer experience and decision-making fit together as one connected system. We use AI, CRM, automation and BI as ingredients, not as the headline.",
  },
  {
    q: "Is this a methodology, a platform, or services?",
    a: "All three. We have a framework (Capture → Connect → Automate → Intelligence → Optimize), we ship working systems on the platforms you already use, and we operate them with you. The deliverable is a business that runs better, not a deck.",
  },
  {
    q: "Do we need to be 'AI-ready' to start?",
    a: "No. Most teams aren't, and that's normal. We start with the operational problem; AI gets introduced only where it produces a measurable outcome. If the system needs better data and cleaner workflows first, we say so.",
  },
  {
    q: "What's the smallest engagement that still produces value?",
    a: "A single Workflow Audit or a focused Operational Assessment. Both produce a concrete map and a recommended next step you can act on with or without us.",
  },
  {
    q: "Do you replace existing tools?",
    a: "Only when the tool is genuinely the blocker. Usually we make existing tools — HubSpot, Salesforce, Zoho, Microsoft, Google, your finance and operations stack — work harder together.",
  },
  {
    q: "Who is this for?",
    a: "Growing companies that are outgrowing spreadsheets, juggling disconnected software, and ready to invest in an operating model that scales without doubling headcount.",
  },
];
---

<MainLayout
  title="Operational Intelligence — The Operating System for Modern Businesses | GlobalTechSignal"
  description="Operational Intelligence is the practice of designing, connecting, automating and continuously improving how your business operates — using AI, integrated systems and live data."
>
  <!-- HERO -->
  <Section id="oi-hero">
    <div class="pt-10 pb-20">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7 space-y-7">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-dark/10 bg-gray text-xs font-mono uppercase tracking-widest text-dark">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
            Category · Operational Intelligence
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-tight">
            The <span class="text-accent">operating system</span> for modern businesses.
          </h1>
          <p class="text-lg text-dark/70 leading-relaxed max-w-2xl">
            Most companies don't have a software problem. They have an <strong>operating model</strong> problem — disconnected tools, manual handoffs, AI demos that never reach production, and leadership flying blind on real-time data.
          </p>
          <p class="text-base text-dark/60 leading-relaxed max-w-2xl">
            Operational Intelligence is how we fix it: a connected, intelligent operating system that compounds revenue, customer experience and decision-making instead of fragmenting them.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 pt-2">
            <a href="/contact" class="px-8 py-4 bg-dark hover:bg-accent rounded-xl text-center text-white text-base font-medium transition-colors">
              Operational Assessment
            </a>
            <a href="#framework" class="px-8 py-4 bg-white hover:bg-dark hover:text-white rounded-xl text-center text-dark border border-dark/20 text-base font-medium transition-colors inline-flex items-center justify-center gap-2">
              See the framework
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>

        <!-- Hero visual: stacked layers -->
        <div class="lg:col-span-5">
          <div class="relative">
            <div class="absolute inset-0 bg-accent/5 blur-3xl rounded-[45px]"></div>
            <div class="relative space-y-3">
              {framework.map((f, idx) => (
                <div class={`oi-float-card flex items-center gap-4 p-4 md:p-5 rounded-2xl border border-dark shadow-[0px_4px_0px_#191a23] ${idx === 3 ? 'bg-dark text-white' : idx === 4 ? 'bg-accent text-white' : 'bg-white text-dark'}`} style={`animation-delay: ${idx * 0.15}s;`}>
                  <span class={`font-mono text-xs ${idx >= 3 ? 'text-white/60' : 'text-dark/50'} shrink-0`}>{f.n}</span>
                  <span class="font-bold text-base md:text-lg tracking-tight">{f.name}</span>
                  <div class={`ml-auto h-2 w-2 rounded-full ${idx === 4 ? 'bg-white animate-pulse' : idx >= 3 ? 'bg-accent' : 'bg-dark/20'}`}></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- DEFINITION -->
  <Section id="oi-definition">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-gray border border-dark/10 p-8 md:p-14 overflow-hidden">
        <div class="absolute top-0 right-0 h-48 w-48 bg-accent/10 rounded-bl-[120px]"></div>
        <div class="relative grid lg:grid-cols-12 gap-10 items-start">
          <div class="lg:col-span-4">
            <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Definition</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              What is <span class="text-accent">{definition.title}</span>?
            </h2>
          </div>
          <div class="lg:col-span-8">
            <p class="text-xl md:text-2xl leading-[1.4] text-dark font-medium">
              {definition.blurb}
            </p>
            <div class="mt-6 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-dark text-white text-xs font-mono uppercase tracking-widest">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              Not a tool. Not a service. An operating model.
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- POSITIONING vs CATEGORIES -->
  <Section id="oi-positioning">
    <div class="pb-24">
      <div class="max-w-3xl mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">The landscape</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
          Everyone owns <span class="text-accent">one slice</span>. We own how they connect.
        </h2>
        <p class="mt-5 text-lg text-dark/70 leading-relaxed">
          Most partners are organized around a single tool, a single function or a single technology trend. That's useful — until the work crosses a boundary, which it always does.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {competitors.map((c) => (
          <div class="rounded-[28px] border border-dark/10 bg-white p-7 hover:-translate-y-1 transition-transform duration-300 shadow-[0px_4px_0px_#191a23]">
            <span class="inline-block px-2.5 py-1 rounded-full bg-dark/5 text-[10px] font-mono uppercase tracking-widest text-dark mb-4">{c.tag}</span>
            <div class="space-y-3">
              <div>
                <span class="text-[11px] font-mono uppercase tracking-widest text-dark/50">Owns</span>
                <p class="text-base text-dark font-semibold mt-1">{c.owns}</p>
              </div>
              <div class="h-px bg-dark/10"></div>
              <div>
                <span class="text-[11px] font-mono uppercase tracking-widest text-red">Misses</span>
                <p class="text-base text-dark/70 mt-1">{c.missing}</p>
              </div>
            </div>
          </div>
        ))}
        <div class="md:col-span-2 rounded-[32px] bg-dark text-white p-8 md:p-10 relative overflow-hidden border border-dark shadow-[0px_5px_0px_#191a23]">
          <div class="absolute -top-10 -right-10 h-48 w-48 rounded-full bg-accent/20 blur-3xl"></div>
          <div class="relative grid md:grid-cols-12 gap-8 items-center">
            <div class="md:col-span-3">
              <span class="inline-block px-2.5 py-1 rounded-full bg-accent/20 text-accent text-[10px] font-mono uppercase tracking-widest mb-4">Global Tech Signal</span>
              <p class="text-2xl md:text-3xl font-extrabold leading-tight">Owns the <span class="text-accent">operating model</span>.</p>
            </div>
            <div class="md:col-span-9">
              <p class="text-lg text-white/80 leading-relaxed">
                We design how revenue, delivery, customer experience and decision-making fit together as one connected system. AI, CRM, automation and analytics are ingredients — not categories we live inside. That's why an Operational Intelligence partner outlasts any single tool, trend or function.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- FRAMEWORK -->
  <Section id="framework">
    <div class="pb-24">
      <div class="max-w-3xl mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">The framework</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
          The <span class="text-accent">Operational Intelligence</span> framework.
        </h2>
        <p class="mt-5 text-lg text-dark/70 leading-relaxed">
          Five layers that turn a collection of tools into an operating system. We run an engagement through all five — or only the layers you need next.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-4">
        {framework.map((f, idx) => (
          <div class={`relative rounded-[24px] p-6 border border-dark shadow-[0px_4px_0px_#191a23] ${idx === 4 ? 'bg-accent text-white' : idx === 3 ? 'bg-dark text-white' : 'bg-gray text-dark'}`}>
            <div class={`font-mono text-xs ${idx >= 3 ? 'text-white/60' : 'text-dark/50'} mb-3`}>{f.n}</div>
            <h3 class="text-xl font-extrabold tracking-tight mb-3">{f.name}</h3>
            <p class={`text-sm leading-relaxed ${idx >= 3 ? 'text-white/80' : 'text-dark/70'}`}>{f.desc}</p>
            {idx < 4 && (
              <div class="hidden lg:flex absolute top-1/2 -right-3 -translate-y-1/2 items-center justify-center h-6 w-6 rounded-full bg-white border border-dark/20 z-10">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-dark"><polyline points="9 18 15 12 9 6"/></svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- SIX SYSTEMS -->
  <Section id="oi-systems">
    <div class="pb-24">
      <div class="grid lg:grid-cols-12 gap-10 mb-12">
        <div class="lg:col-span-5">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">The six systems</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
            What you actually <span class="text-accent">ship</span>.
          </h2>
        </div>
        <div class="lg:col-span-7">
          <p class="text-lg text-dark/70 leading-relaxed">
            Operational Intelligence is delivered as six connected business systems. We rarely build all of them at once — we start with the system that unlocks the most value, then extend.
          </p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {systems.map((s, idx) => (
          <a href={s.href} class="group rounded-[24px] bg-white border border-dark/10 p-7 hover:-translate-y-1 hover:border-dark transition-all duration-300 shadow-[0px_4px_0px_#191a23]">
            <div class="flex items-center justify-between mb-4">
              <span class="font-mono text-xs text-dark/50">{String(idx + 1).padStart(2, '0')}</span>
              <span class="h-8 w-8 rounded-full bg-accent/10 group-hover:bg-accent transition-colors flex items-center justify-center">
                <svg class="w-4 h-4 text-accent group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </div>
            <h3 class="text-xl font-extrabold tracking-tight mb-2">{s.name}</h3>
            <p class="text-sm text-dark/70 leading-relaxed">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </Section>

  <!-- ADVISORY LADDER -->
  <Section id="oi-ladder">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-gray border border-dark/10 p-8 md:p-14 overflow-hidden">
        <div class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative grid lg:grid-cols-12 gap-10">
          <div class="lg:col-span-5">
            <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Five ways to start</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              Choose the <span class="text-accent">entry point</span> that fits.
            </h2>
            <p class="mt-5 text-base text-dark/70 leading-relaxed">
              You don't have to be ready to commit to a full transformation to start. Each entry point produces a concrete output you can act on — with or without us.
            </p>
            <a href="/assessments" class="mt-7 inline-flex items-center gap-2 px-6 py-3 bg-dark text-white rounded-xl hover:bg-accent transition-colors font-medium text-sm">
              See all assessments
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="/scorecard" class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-dark hover:text-accent transition-colors">
              Or take the 2-min self-serve scorecard
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="lg:col-span-7 space-y-3">
            {ladder.map((l, idx) => (
              <a href={l.href} class="group flex items-start gap-4 p-5 rounded-2xl bg-white border border-dark/10 hover:border-dark hover:-translate-y-0.5 transition-all duration-300">
                <span class="flex items-center justify-center h-9 w-9 rounded-xl bg-dark text-white text-xs font-mono shrink-0">{String(idx + 1).padStart(2, '0')}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <h3 class="text-lg font-extrabold tracking-tight">{l.name}</h3>
                    <span class="text-[11px] font-mono uppercase tracking-widest text-dark/50">{l.duration}</span>
                  </div>
                  <p class="mt-1 text-sm text-dark/70 leading-relaxed">{l.desc}</p>
                </div>
                <svg class="w-5 h-5 text-dark/30 group-hover:text-accent group-hover:translate-x-1 transition-all shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- CONTENT PILLARS -->
  <Section id="oi-pillars">
    <div class="pb-24">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Library</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
            We publish what we <span class="text-accent">build</span>.
          </h2>
          <p class="mt-5 text-lg text-dark/70 leading-relaxed">
            Operational Intelligence is an emerging category. We're writing it forward — practitioner-level essays on AI, CRM, integrations, BI, governance and the operating model itself.
          </p>
          <a href="/articles" class="mt-7 inline-flex items-center gap-2 px-6 py-3 bg-dark text-white rounded-xl hover:bg-accent transition-colors font-medium text-sm">
            Browse insights
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="lg:col-span-7">
          <div class="flex flex-wrap gap-2.5">
            {pillars.map((p, i) => (
              <span class={`inline-flex items-center px-4 py-2.5 rounded-full text-sm font-medium border ${i % 3 === 0 ? 'bg-dark text-white border-dark' : i % 3 === 1 ? 'bg-accent text-white border-accent' : 'bg-white text-dark border-dark/15'}`}>{p}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- FAQ -->
  <Section id="oi-faq">
    <div class="pb-24">
      <div class="max-w-3xl mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">FAQ</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">Common questions.</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-5">
        {faqs.map((f) => (
          <details class="group rounded-2xl bg-gray border border-dark/10 p-6 open:bg-white open:border-dark/30 transition-all">
            <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
              <span class="text-lg font-extrabold tracking-tight text-dark">{f.q}</span>
              <span class="shrink-0 mt-1 h-7 w-7 rounded-full bg-dark text-white flex items-center justify-center group-open:bg-accent transition-colors">
                <svg class="w-3.5 h-3.5 group-open:rotate-45 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base text-dark/70 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section id="oi-cta">
    <div class="pb-28">
      <div class="relative rounded-[32px] bg-dark text-white p-10 md:p-16 text-center overflow-hidden shadow-[0px_5px_0px_#191a23] border border-dark">
        <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative max-w-2xl mx-auto">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/15 text-xs font-mono uppercase tracking-widest text-white/70 mb-6">
            <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
            Start where it makes sense
          </span>
          <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-5">
            Ready to build an <span class="text-accent">operating system</span>?
          </h2>
          <p class="text-lg text-white/70 mb-8">
            Start with a free Operational Assessment, or pick a focused entry point. Either way, you walk out with a concrete map and a recommended next step.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">Operational Assessment</a>
            <a href="/assessments" class="inline-flex items-center justify-center px-8 py-4 bg-transparent text-white border border-white/30 rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">See all assessments</a>
          </div>
        </div>
      </div>
    </div>
  </Section>
</MainLayout>

<style>
  @keyframes oi-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .oi-float-card {
    animation: oi-float 5s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .oi-float-card { animation: none; }
  }
</style>
