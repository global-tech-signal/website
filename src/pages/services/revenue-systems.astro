---
import MainLayout from "../../layouts/MainLayout.astro";
import Section from "../../components/sections/Section.astro";

const system = {
  num: "01",
  label: "Business System · Revenue",
  title: "Revenue Systems",
  blurb:
    "CRM, lead management and sales automation built around how your team actually wins business — not how a SaaS demo says it should work.",
  long:
    "Lost leads, slow follow-up and pipelines nobody trusts are operational problems, not CRM problems. Revenue Systems is the layer of Operational Intelligence that turns sales into a predictable, observable process — by designing pipelines around your real sales motion, automating capture, scoring and routing, and feeding clean data into reporting your leadership can actually trust.",
};

const broken = [
  { t: "Pipelines nobody trusts", d: "Stages mean different things to different reps. Forecast accuracy collapses." },
  { t: "Leads land and decay", d: "Inbound enters a tool, sits unscored, and rots before anyone touches it." },
  { t: "Follow-up is manual", d: "Sequences live in heads, calendars and sticky notes — not in the system." },
  { t: "Reporting takes a week", d: "Pulling pipeline numbers means stitching exports together every Monday." },
];

const ship = [
  { t: "Pipelines that match how you actually sell", d: "Stages, exit criteria and forecasts modeled on the deals you really close." },
  { t: "Lead capture, scoring and routing", d: "Inbound from web, ads, partners and referrals lands, gets scored and routed in seconds." },
  { t: "Sales automation & sequences", d: "Templated outreach, reminders and stage-driven actions that run themselves." },
  { t: "Revenue dashboards leadership trusts", d: "Live pipeline, conversion, velocity and rep performance — one shared view." },
  { t: "Quote, proposal & approval flows", d: "Stop running proposals through email threads. Document automation in the same system." },
  { t: "Clean handoff to delivery", d: "Closed-won doesn't go to a folder — it kicks off onboarding in the next system." },
];

const stack = ["HubSpot", "Salesforce", "Pipedrive", "Zoho CRM", "Custom CRM", "Apollo", "Lemlist", "Outreach", "Calendly", "PandaDoc", "DocuSign", "Segment"];

const layer = {
  pos: 1,
  name: "Capture & Automate",
  desc: "Revenue Systems sit at the front of the Operational Intelligence stack — they own how demand enters the business and how it moves through the pipeline.",
};

const ladder = [
  { name: "Revenue Systems Assessment", duration: "2 weeks", desc: "Pipeline, CRM, lead-to-cash and reporting reviewed end-to-end. Output: gap map + ranked roadmap.", href: "/contact?type=revenue-systems" },
  { name: "Workflow Audit", duration: "2 weeks", desc: "Deep dive on a single sales workflow — lead routing, follow-up, handoff — that's costing you revenue.", href: "/contact?type=workflow-audit" },
  { name: "Operational Assessment", duration: "60 min · Free", desc: "Map where revenue, time and visibility are leaking across the whole operating model.", href: "/contact?type=operational-assessment" },
];

const industries = [
  { name: "Real Estate", href: "/industries/real-estate" },
  { name: "Insurance", href: "/industries/insurance" },
  { name: "Legal", href: "/industries/legal" },
  { name: "Agencies", href: "/industries/agencies" },
  { name: "Finance", href: "/industries/finance" },
  { name: "Roofing", href: "/industries/roofing" },
];

const faqs = [
  { q: "Do you replace our CRM?", a: "Only if it's genuinely the blocker. More often the CRM is fine — what's missing is the data model, automation and reporting around it. We make HubSpot, Salesforce, Pipedrive or Zoho work harder before we suggest replacing them." },
  { q: "Can you build a custom CRM instead?", a: "Yes, when off-the-shelf forces compromises that hurt the business — unusual sales motions, multi-tenant complexity, deeply industry-specific workflows. We build custom CRMs on modern stacks and integrate them with the rest of your tools." },
  { q: "How quickly do we see something live?", a: "First working system in 4–8 weeks for most engagements. We scope to ship value early, then extend — not big-bang launches." },
  { q: "Will this work with our existing data?", a: "We start by mapping what you have, what's clean, what's duplicated and what's missing. Migration and de-duplication are part of the engagement, not an afterthought." },
];
---

<MainLayout
  title="Revenue Systems — CRM, Lead Management & Sales Automation | GlobalTechSignal"
  description="Custom CRM, lead capture, scoring, routing and sales automation built around how your team actually wins business. Part of the Operational Intelligence operating model."
>
  <!-- HERO -->
  <Section id="sys-hero">
    <div class="pt-10 pb-20">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7 space-y-7">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-dark/10 bg-gray text-xs font-mono uppercase tracking-widest text-dark">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
            {system.label}
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-tight">
            Pipelines, leads and follow-up that <span class="text-accent">actually run</span>.
          </h1>
          <p class="text-lg text-dark/70 leading-relaxed max-w-2xl">{system.blurb}</p>
          <div class="flex flex-col sm:flex-row gap-4 pt-2">
            <a href="/contact?type=revenue-systems" class="px-8 py-4 bg-dark hover:bg-accent rounded-xl text-center text-white text-base font-medium transition-colors">Revenue Systems Assessment</a>
            <a href="#what-you-ship" class="px-8 py-4 bg-white hover:bg-dark hover:text-white rounded-xl text-center text-dark border border-dark/20 text-base font-medium transition-colors inline-flex items-center justify-center gap-2">
              See what you ship
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
        <div class="lg:col-span-5">
          <div class="relative">
            <div class="absolute inset-0 bg-accent/5 blur-3xl rounded-[45px]"></div>
            <div class="relative grid grid-cols-2 gap-3">
              <div class="sys-float-card col-span-2 p-5 rounded-2xl bg-dark text-white border border-dark shadow-[0px_4px_0px_#191a23]" style="animation-delay:0s;">
                <div class="font-mono text-[11px] text-white/50 mb-1">PIPELINE</div>
                <div class="text-2xl font-extrabold">$1.2M · 47 deals</div>
              </div>
              <div class="sys-float-card p-4 rounded-2xl bg-white border border-dark/10 shadow-[0px_4px_0px_#191a23]" style="animation-delay:.15s;">
                <div class="font-mono text-[10px] text-dark/50 mb-1">NEW LEAD</div>
                <div class="text-sm font-semibold">Scored · Routed in 4s</div>
              </div>
              <div class="sys-float-card p-4 rounded-2xl bg-accent text-white border border-accent shadow-[0px_4px_0px_#191a23]" style="animation-delay:.3s;">
                <div class="font-mono text-[10px] text-white/70 mb-1">SEQUENCE</div>
                <div class="text-sm font-semibold">Day 1 → Day 14 active</div>
              </div>
              <div class="sys-float-card col-span-2 p-4 rounded-2xl bg-white border border-dark/10 shadow-[0px_4px_0px_#191a23]" style="animation-delay:.45s;">
                <div class="flex items-center justify-between">
                  <div>
                    <div class="font-mono text-[10px] text-dark/50">FORECAST</div>
                    <div class="text-base font-extrabold">Q3 · 92% confidence</div>
                  </div>
                  <div class="h-2 w-20 rounded-full bg-dark/10 overflow-hidden">
                    <div class="h-full w-[92%] bg-accent rounded-full"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- DEFINITION -->
  <Section id="sys-definition">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-gray border border-dark/10 p-8 md:p-14 overflow-hidden">
        <div class="absolute top-0 right-0 h-48 w-48 bg-accent/10 rounded-bl-[120px]"></div>
        <div class="relative grid lg:grid-cols-12 gap-10 items-start">
          <div class="lg:col-span-4">
            <span class="text-xs font-mono uppercase tracking-widest text-dark/50">What it is</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              The system that turns demand into <span class="text-accent">revenue</span>.
            </h2>
          </div>
          <div class="lg:col-span-8">
            <p class="text-xl md:text-2xl leading-[1.4] text-dark font-medium">{system.long}</p>
            <div class="mt-6 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-dark text-white text-xs font-mono uppercase tracking-widest">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              Part of Operational Intelligence
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- WHAT BREAKS -->
  <Section id="sys-broken">
    <div class="pb-24">
      <div class="max-w-3xl mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">What breaks without it</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
          The four symptoms of a <span class="text-accent">broken revenue layer</span>.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {broken.map((b, i) => (
          <div class="rounded-[24px] bg-white border border-dark/10 p-6 shadow-[0px_4px_0px_#191a23]">
            <span class="font-mono text-xs text-red mb-3 block">0{i + 1}</span>
            <h3 class="text-lg font-extrabold tracking-tight mb-2">{b.t}</h3>
            <p class="text-sm text-dark/70 leading-relaxed">{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- WHAT YOU SHIP -->
  <Section id="what-you-ship">
    <div class="pb-24">
      <div class="grid lg:grid-cols-12 gap-10 mb-12">
        <div class="lg:col-span-5">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">What you ship</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
            Six things a real revenue system <span class="text-accent">does</span>.
          </h2>
        </div>
        <div class="lg:col-span-7">
          <p class="text-lg text-dark/70 leading-relaxed">
            We don't deliver "a CRM project." We ship a connected layer: data model, automation, integrations, reporting and the operational discipline around them.
          </p>
        </div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {ship.map((s, i) => (
          <div class={`rounded-[24px] p-7 border border-dark shadow-[0px_4px_0px_#191a23] ${i === 0 ? 'bg-accent text-white' : i === 3 ? 'bg-dark text-white' : 'bg-white text-dark'}`}>
            <span class={`font-mono text-xs ${i === 0 || i === 3 ? 'text-white/60' : 'text-dark/50'} mb-3 block`}>{String(i + 1).padStart(2, '0')}</span>
            <h3 class="text-xl font-extrabold tracking-tight mb-2">{s.t}</h3>
            <p class={`text-sm leading-relaxed ${i === 0 || i === 3 ? 'text-white/80' : 'text-dark/70'}`}>{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- HOW IT CONNECTS -->
  <Section id="sys-layer">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-dark text-white p-8 md:p-14 overflow-hidden border border-dark shadow-[0px_5px_0px_#191a23]">
        <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="relative grid lg:grid-cols-12 gap-10 items-center">
          <div class="lg:col-span-5">
            <span class="text-xs font-mono uppercase tracking-widest text-white/50">Where it fits</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              The <span class="text-accent">first layer</span> of Operational Intelligence.
            </h2>
            <p class="mt-5 text-base text-white/70 leading-relaxed">{layer.desc}</p>
            <a href="/operational-intelligence" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-accent hover:text-white transition-colors">
              See the full operating model
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="lg:col-span-7">
            <div class="grid grid-cols-5 gap-2">
              {["Capture", "Connect", "Automate", "Intelligence", "Optimize"].map((n, i) => (
                <div class={`p-3 rounded-xl text-center border ${(i === 0 || i === 2) ? 'bg-accent text-white border-accent' : 'bg-white/5 text-white/50 border-white/10'}`}>
                  <div class="font-mono text-[10px] mb-1 opacity-70">0{i + 1}</div>
                  <div class="text-xs font-bold">{n}</div>
                </div>
              ))}
            </div>
            <p class="mt-4 text-xs font-mono uppercase tracking-widest text-white/40 text-center">Revenue Systems primarily live in Capture + Automate</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- STACK -->
  <Section id="sys-stack">
    <div class="pb-24">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Stack</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
            We wire <span class="text-accent">into</span> what you already run.
          </h2>
          <p class="mt-5 text-base text-dark/70 leading-relaxed">
            Tools, integrations and platforms we use most often inside revenue systems. We connect the stack you already have rather than push one of our own.
          </p>
        </div>
        <div class="lg:col-span-7">
          <div class="flex flex-wrap gap-2.5">
            {stack.map((s, i) => (
              <span class={`inline-flex items-center px-4 py-2.5 rounded-full text-sm font-medium border ${i % 3 === 0 ? 'bg-dark text-white border-dark' : i % 3 === 1 ? 'bg-accent text-white border-accent' : 'bg-white text-dark border-dark/15'}`}>{s}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- INDUSTRIES -->
  <Section id="sys-industries">
    <div class="pb-24">
      <div class="max-w-3xl mb-10">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Where it lands hardest</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
          Industries where revenue systems <span class="text-accent">change the math</span>.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {industries.map((ind) => (
          <a href={ind.href} class="group flex items-center justify-between p-5 rounded-2xl bg-gray border border-dark/10 hover:border-dark hover:bg-white transition-all">
            <span class="text-base font-extrabold tracking-tight">{ind.name}</span>
            <svg class="w-4 h-4 text-dark/30 group-hover:text-accent group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        ))}
      </div>
    </div>
  </Section>

  <!-- LADDER -->
  <Section id="sys-ladder">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-gray border border-dark/10 p-8 md:p-14 overflow-hidden">
        <div class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative grid lg:grid-cols-12 gap-10">
          <div class="lg:col-span-5">
            <span class="text-xs font-mono uppercase tracking-widest text-dark/50">How to start</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              Three ways to engage on <span class="text-accent">revenue systems</span>.
            </h2>
            <p class="mt-5 text-base text-dark/70 leading-relaxed">
              Each entry point produces a concrete artifact you can act on — with or without us.
            </p>
            <a href="/assessments" class="mt-7 inline-flex items-center gap-2 px-6 py-3 bg-dark text-white rounded-xl hover:bg-accent transition-colors font-medium text-sm">
              See all assessments
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="lg:col-span-7 space-y-3">
            {ladder.map((l, idx) => (
              <a href={l.href} class="group flex items-start gap-4 p-5 rounded-2xl bg-white border border-dark/10 hover:border-dark hover:-translate-y-0.5 transition-all duration-300">
                <span class="flex items-center justify-center h-9 w-9 rounded-xl bg-dark text-white text-xs font-mono shrink-0">{String(idx + 1).padStart(2, '0')}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <h3 class="text-lg font-extrabold tracking-tight">{l.name}</h3>
                    <span class="text-[11px] font-mono uppercase tracking-widest text-dark/50">{l.duration}</span>
                  </div>
                  <p class="mt-1 text-sm text-dark/70 leading-relaxed">{l.desc}</p>
                </div>
                <svg class="w-5 h-5 text-dark/30 group-hover:text-accent group-hover:translate-x-1 transition-all shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- FAQ -->
  <Section id="sys-faq">
    <div class="pb-24">
      <div class="max-w-3xl mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">FAQ</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">Revenue Systems, answered.</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-5">
        {faqs.map((f) => (
          <details class="group rounded-2xl bg-gray border border-dark/10 p-6 open:bg-white open:border-dark/30 transition-all">
            <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
              <span class="text-lg font-extrabold tracking-tight text-dark">{f.q}</span>
              <span class="shrink-0 mt-1 h-7 w-7 rounded-full bg-dark text-white flex items-center justify-center group-open:bg-accent transition-colors">
                <svg class="w-3.5 h-3.5 group-open:rotate-45 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base text-dark/70 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section id="sys-cta">
    <div class="pb-28">
      <div class="relative rounded-[32px] bg-dark text-white p-10 md:p-16 text-center overflow-hidden shadow-[0px_5px_0px_#191a23] border border-dark">
        <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative max-w-2xl mx-auto">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/15 text-xs font-mono uppercase tracking-widest text-white/70 mb-6">
            <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
            Start with revenue
          </span>
          <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-5">
            Make your <span class="text-accent">pipeline</span> run itself.
          </h2>
          <p class="text-lg text-white/70 mb-8">
            Book a Revenue Systems Assessment and walk out with a gap map, a ranked roadmap and a real cost-of-inaction estimate.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/contact?type=revenue-systems" class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">Revenue Systems Assessment</a>
            <a href="/scorecard" class="inline-flex items-center justify-center px-8 py-4 bg-transparent text-white border border-white/30 rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">Take the Business Operations Index™</a>
          </div>
        </div>
      </div>
    </div>
  </Section>
</MainLayout>

<style>
  @keyframes sys-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .sys-float-card {
    animation: sys-float 5s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .sys-float-card { animation: none; }
  }
</style>
