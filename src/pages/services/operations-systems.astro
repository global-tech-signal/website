---
import MainLayout from "../../layouts/MainLayout.astro";
import Section from "../../components/sections/Section.astro";

const system = {
  num: "02",
  label: "Business System · Operations",
  title: "Operations Systems",
  blurb:
    "Connected workflows that replace manual handoffs across the tools you already use — so your team stops being the integration layer.",
  long:
    "When CRM, email, billing, ops tools and spreadsheets don't talk, the humans become the glue. Operations Systems is the layer of Operational Intelligence that designs the workflows in between — automation, internal tooling and integrations — so processes run end-to-end, observable and ownable, instead of living in heads and inboxes.",
};

const broken = [
  { t: "Humans as the integration", d: "Someone manually copies data from CRM into spreadsheets, then into a finance tool. Every day." },
  { t: "Handoffs go silent", d: "Sales closes a deal. Delivery finds out three days later, from a Slack mention." },
  { t: "Onboarding takes weeks", d: "New hires spend a month learning where things live and who to ask, not doing the job." },
  { t: "Nothing is observable", d: "When a workflow breaks, you only know because a customer complains." },
];

const ship = [
  { t: "End-to-end workflow automation", d: "Multi-step processes that span CRM, ops, finance and comms — running without human ticking lists." },
  { t: "Internal tools your team trusts", d: "Custom apps and admin UIs that wrap messy backends into clean, single-purpose interfaces." },
  { t: "Cross-tool integrations", d: "API and webhook plumbing between the platforms you already run — bidirectional, observable, recoverable." },
  { t: "Operational runbooks in code", d: "The way work moves becomes a system, not folklore. New hires inherit the playbook." },
  { t: "Error handling & alerting", d: "When something does break, the system notices first and routes to the right human." },
  { t: "Audit trails for every action", d: "Who did what, when, and to which record — visible without filing a support ticket." },
];

const stack = ["Zapier", "Make", "n8n", "Workato", "Tray.io", "Retool", "Internal.io", "Custom Apps", "Node.js", "Python", "Webhooks", "REST · GraphQL APIs"];

const layer = {
  desc: "Operations Systems sit in the center of the Operational Intelligence stack — they own how information and work move between the tools you already use.",
};

const ladder = [
  { name: "Workflow Audit", duration: "2 weeks", desc: "Deep dive on one workflow that's costing you hours or revenue. Output: process map + automation plan.", href: "/contact?type=workflow-audit" },
  { name: "Operational Assessment", duration: "60 min · Free", desc: "Map where time, errors and visibility are leaking across the operating model.", href: "/contact?type=operational-assessment" },
  { name: "Executive Strategy Session", duration: "Half day", desc: "Align leadership on which workflows to systemize first — and which not to.", href: "/contact?type=executive-strategy" },
];

const industries = [
  { name: "Construction", href: "/industries/construction" },
  { name: "Logistics", href: "/industries/logistics" },
  { name: "Home Services", href: "/industries/home-services" },
  { name: "Agencies", href: "/industries/agencies" },
  { name: "Roofing", href: "/industries/roofing" },
  { name: "E-Commerce", href: "/industries/ecommerce" },
];

const faqs = [
  { q: "Do you build custom internal tools or use no-code?", a: "Both. We start from the workflow, not the platform. Simple, fast-changing processes often land on Zapier, Make or n8n. Higher-volume or business-critical workflows usually warrant custom internal apps in Retool or React/Node — where we own error handling, observability and security." },
  { q: "How is this different from buying an iPaaS license?", a: "An iPaaS is a tool. Operations Systems is a discipline — process design, ownership, error handling, alerting and instrumentation around the automation. The license is the easy part; the engineering and governance are where most teams get stuck." },
  { q: "Will automation cause more chaos than it solves?", a: "If you automate a broken process, yes. We map the workflow first, fix the obvious breaks, then automate the steady-state. Every automation has an owner and an observable failure mode." },
  { q: "What's the smallest unit of work?", a: "A single workflow — usually 4–6 weeks. We deliver it instrumented, documented and handed over to an owner on your side." },
];
---

<MainLayout
  title="Operations Systems — Workflow Automation & Internal Tools | GlobalTechSignal"
  description="Connected workflows, custom internal tools and cross-platform integrations that eliminate manual handoffs. Part of the Operational Intelligence operating model."
>
  <Section id="sys-hero">
    <div class="pt-10 pb-20">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7 space-y-7">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-dark/10 bg-gray text-xs font-mono uppercase tracking-widest text-dark">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
            {system.label}
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-tight">
            Stop being the <span class="text-accent">integration layer</span>.
          </h1>
          <p class="text-lg text-dark/70 leading-relaxed max-w-2xl">{system.blurb}</p>
          <div class="flex flex-col sm:flex-row gap-4 pt-2">
            <a href="/contact?type=workflow-audit" class="px-8 py-4 bg-dark hover:bg-accent rounded-xl text-center text-white text-base font-medium transition-colors">Workflow Audit</a>
            <a href="#what-you-ship" class="px-8 py-4 bg-white hover:bg-dark hover:text-white rounded-xl text-center text-dark border border-dark/20 text-base font-medium transition-colors inline-flex items-center justify-center gap-2">
              See what you ship
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
        <div class="lg:col-span-5">
          <div class="relative">
            <div class="absolute inset-0 bg-accent/5 blur-3xl rounded-[45px]"></div>
            <div class="relative space-y-3">
              <div class="sys-float-card flex items-center gap-3 p-4 rounded-2xl bg-white border border-dark/10 shadow-[0px_4px_0px_#191a23]" style="animation-delay:0s;">
                <span class="font-mono text-[10px] text-dark/50">CRM</span>
                <div class="flex-1 h-px bg-dark/20"></div>
                <span class="text-xs font-semibold">Deal won</span>
              </div>
              <div class="sys-float-card flex items-center gap-3 p-4 rounded-2xl bg-accent text-white border border-accent shadow-[0px_4px_0px_#191a23]" style="animation-delay:.15s;">
                <span class="font-mono text-[10px] text-white/60">WORKFLOW</span>
                <div class="flex-1 h-px bg-white/30"></div>
                <span class="text-xs font-semibold">Auto-triggered</span>
              </div>
              <div class="sys-float-card flex items-center gap-3 p-4 rounded-2xl bg-white border border-dark/10 shadow-[0px_4px_0px_#191a23]" style="animation-delay:.3s;">
                <span class="font-mono text-[10px] text-dark/50">DELIVERY</span>
                <div class="flex-1 h-px bg-dark/20"></div>
                <span class="text-xs font-semibold">Project created</span>
              </div>
              <div class="sys-float-card flex items-center gap-3 p-4 rounded-2xl bg-white border border-dark/10 shadow-[0px_4px_0px_#191a23]" style="animation-delay:.45s;">
                <span class="font-mono text-[10px] text-dark/50">FINANCE</span>
                <div class="flex-1 h-px bg-dark/20"></div>
                <span class="text-xs font-semibold">Invoice scheduled</span>
              </div>
              <div class="sys-float-card flex items-center gap-3 p-4 rounded-2xl bg-dark text-white border border-dark shadow-[0px_4px_0px_#191a23]" style="animation-delay:.6s;">
                <span class="font-mono text-[10px] text-white/50">SLACK</span>
                <div class="flex-1 h-px bg-white/30"></div>
                <span class="text-xs font-semibold">Team notified</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="sys-definition">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-gray border border-dark/10 p-8 md:p-14 overflow-hidden">
        <div class="absolute top-0 right-0 h-48 w-48 bg-accent/10 rounded-bl-[120px]"></div>
        <div class="relative grid lg:grid-cols-12 gap-10 items-start">
          <div class="lg:col-span-4">
            <span class="text-xs font-mono uppercase tracking-widest text-dark/50">What it is</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              The system that moves <span class="text-accent">work</span> between systems.
            </h2>
          </div>
          <div class="lg:col-span-8">
            <p class="text-xl md:text-2xl leading-[1.4] text-dark font-medium">{system.long}</p>
            <div class="mt-6 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-dark text-white text-xs font-mono uppercase tracking-widest">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              Part of Operational Intelligence
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="sys-broken">
    <div class="pb-24">
      <div class="max-w-3xl mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">What breaks without it</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
          The four symptoms of <span class="text-accent">human-as-glue</span>.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {broken.map((b, i) => (
          <div class="rounded-[24px] bg-white border border-dark/10 p-6 shadow-[0px_4px_0px_#191a23]">
            <span class="font-mono text-xs text-red mb-3 block">0{i + 1}</span>
            <h3 class="text-lg font-extrabold tracking-tight mb-2">{b.t}</h3>
            <p class="text-sm text-dark/70 leading-relaxed">{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section id="what-you-ship">
    <div class="pb-24">
      <div class="grid lg:grid-cols-12 gap-10 mb-12">
        <div class="lg:col-span-5">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">What you ship</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
            Six things a real operations system <span class="text-accent">does</span>.
          </h2>
        </div>
        <div class="lg:col-span-7">
          <p class="text-lg text-dark/70 leading-relaxed">
            We don't sell "automation." We ship designed, instrumented, owned workflows — and the internal tools that make them inspectable by humans.
          </p>
        </div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {ship.map((s, i) => (
          <div class={`rounded-[24px] p-7 border border-dark shadow-[0px_4px_0px_#191a23] ${i === 0 ? 'bg-accent text-white' : i === 3 ? 'bg-dark text-white' : 'bg-white text-dark'}`}>
            <span class={`font-mono text-xs ${i === 0 || i === 3 ? 'text-white/60' : 'text-dark/50'} mb-3 block`}>{String(i + 1).padStart(2, '0')}</span>
            <h3 class="text-xl font-extrabold tracking-tight mb-2">{s.t}</h3>
            <p class={`text-sm leading-relaxed ${i === 0 || i === 3 ? 'text-white/80' : 'text-dark/70'}`}>{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section id="sys-layer">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-dark text-white p-8 md:p-14 overflow-hidden border border-dark shadow-[0px_5px_0px_#191a23]">
        <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="relative grid lg:grid-cols-12 gap-10 items-center">
          <div class="lg:col-span-5">
            <span class="text-xs font-mono uppercase tracking-widest text-white/50">Where it fits</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              The <span class="text-accent">middle layer</span> of Operational Intelligence.
            </h2>
            <p class="mt-5 text-base text-white/70 leading-relaxed">{layer.desc}</p>
            <a href="/operational-intelligence" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-accent hover:text-white transition-colors">
              See the full operating model
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="lg:col-span-7">
            <div class="grid grid-cols-5 gap-2">
              {["Capture", "Connect", "Automate", "Intelligence", "Optimize"].map((n, i) => (
                <div class={`p-3 rounded-xl text-center border ${(i === 1 || i === 2) ? 'bg-accent text-white border-accent' : 'bg-white/5 text-white/50 border-white/10'}`}>
                  <div class="font-mono text-[10px] mb-1 opacity-70">0{i + 1}</div>
                  <div class="text-xs font-bold">{n}</div>
                </div>
              ))}
            </div>
            <p class="mt-4 text-xs font-mono uppercase tracking-widest text-white/40 text-center">Operations Systems primarily live in Connect + Automate</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="sys-stack">
    <div class="pb-24">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Stack</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
            Automation that <span class="text-accent">fits</span> your stack.
          </h2>
          <p class="mt-5 text-base text-dark/70 leading-relaxed">
            Tools, platforms and runtimes we use most often inside operations systems. The platform is a means — the design and discipline around it is what matters.
          </p>
        </div>
        <div class="lg:col-span-7">
          <div class="flex flex-wrap gap-2.5">
            {stack.map((s, i) => (
              <span class={`inline-flex items-center px-4 py-2.5 rounded-full text-sm font-medium border ${i % 3 === 0 ? 'bg-dark text-white border-dark' : i % 3 === 1 ? 'bg-accent text-white border-accent' : 'bg-white text-dark border-dark/15'}`}>{s}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="sys-industries">
    <div class="pb-24">
      <div class="max-w-3xl mb-10">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Where it lands hardest</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
          Industries where operations systems <span class="text-accent">unlock weeks</span>.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {industries.map((ind) => (
          <a href={ind.href} class="group flex items-center justify-between p-5 rounded-2xl bg-gray border border-dark/10 hover:border-dark hover:bg-white transition-all">
            <span class="text-base font-extrabold tracking-tight">{ind.name}</span>
            <svg class="w-4 h-4 text-dark/30 group-hover:text-accent group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        ))}
      </div>
    </div>
  </Section>

  <Section id="sys-ladder">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-gray border border-dark/10 p-8 md:p-14 overflow-hidden">
        <div class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative grid lg:grid-cols-12 gap-10">
          <div class="lg:col-span-5">
            <span class="text-xs font-mono uppercase tracking-widest text-dark/50">How to start</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              Three ways to engage on <span class="text-accent">operations systems</span>.
            </h2>
            <p class="mt-5 text-base text-dark/70 leading-relaxed">
              Each entry point produces a concrete artifact you can act on — with or without us.
            </p>
            <a href="/assessments" class="mt-7 inline-flex items-center gap-2 px-6 py-3 bg-dark text-white rounded-xl hover:bg-accent transition-colors font-medium text-sm">
              See all assessments
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="lg:col-span-7 space-y-3">
            {ladder.map((l, idx) => (
              <a href={l.href} class="group flex items-start gap-4 p-5 rounded-2xl bg-white border border-dark/10 hover:border-dark hover:-translate-y-0.5 transition-all duration-300">
                <span class="flex items-center justify-center h-9 w-9 rounded-xl bg-dark text-white text-xs font-mono shrink-0">{String(idx + 1).padStart(2, '0')}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <h3 class="text-lg font-extrabold tracking-tight">{l.name}</h3>
                    <span class="text-[11px] font-mono uppercase tracking-widest text-dark/50">{l.duration}</span>
                  </div>
                  <p class="mt-1 text-sm text-dark/70 leading-relaxed">{l.desc}</p>
                </div>
                <svg class="w-5 h-5 text-dark/30 group-hover:text-accent group-hover:translate-x-1 transition-all shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="sys-faq">
    <div class="pb-24">
      <div class="max-w-3xl mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">FAQ</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">Operations Systems, answered.</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-5">
        {faqs.map((f) => (
          <details class="group rounded-2xl bg-gray border border-dark/10 p-6 open:bg-white open:border-dark/30 transition-all">
            <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
              <span class="text-lg font-extrabold tracking-tight text-dark">{f.q}</span>
              <span class="shrink-0 mt-1 h-7 w-7 rounded-full bg-dark text-white flex items-center justify-center group-open:bg-accent transition-colors">
                <svg class="w-3.5 h-3.5 group-open:rotate-45 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base text-dark/70 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </Section>

  <Section id="sys-cta">
    <div class="pb-28">
      <div class="relative rounded-[32px] bg-dark text-white p-10 md:p-16 text-center overflow-hidden shadow-[0px_5px_0px_#191a23] border border-dark">
        <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative max-w-2xl mx-auto">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/15 text-xs font-mono uppercase tracking-widest text-white/70 mb-6">
            <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
            Start with one workflow
          </span>
          <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-5">
            Reclaim the hours <span class="text-accent">your team loses</span> every week.
          </h2>
          <p class="text-lg text-white/70 mb-8">
            Book a Workflow Audit. We pick a single broken process, map it, quantify the cost, and design the system that replaces it.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/contact?type=workflow-audit" class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">Workflow Audit</a>
            <a href="/scorecard" class="inline-flex items-center justify-center px-8 py-4 bg-transparent text-white border border-white/30 rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">Take the Business Operations Index™</a>
          </div>
        </div>
      </div>
    </div>
  </Section>
</MainLayout>

<style>
  @keyframes sys-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .sys-float-card { animation: sys-float 5s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) {
    .sys-float-card { animation: none; }
  }
</style>
