---
import MainLayout from "../../layouts/MainLayout.astro";
import Section from "../../components/sections/Section.astro";

const system = {
  label: "Business System · Digital Experience",
  blurb:
    "High-performance websites, portals and product surfaces engineered for conversion — and wired into your business systems from day one.",
  long:
    "Your website and product UI are the front of your operations. Digital Experience is the layer of Operational Intelligence that designs them as part of the operating model — not as a separate marketing project — so every lead, signup, support request and customer action lands inside your CRM, your data warehouse and your workflows, instrumented from the first click.",
};

const broken = [
  { t: "Marketing site disconnected from CRM", d: "Forms drop into an inbox. Someone copies them into HubSpot a day later. Attribution is a guess." },
  { t: "Product UI bolted on the side", d: "Customer portal lives in a tool that doesn't know who the customer is in any other system." },
  { t: "Slow, bloated, hurting conversion", d: "Core Web Vitals fail, mobile feels heavy, marketing teams can't ship without an engineer." },
  { t: "Analytics nobody trusts", d: "GA4 says one thing. The CRM says another. The product tool says a third. Nobody can call a decision." },
];

const ship = [
  { t: "High-performance marketing sites", d: "Astro / Next.js builds with excellent Core Web Vitals — fast on mobile, fast on emerging markets, fast under load." },
  { t: "Product UI & SaaS frontends", d: "Application-grade interfaces — auth, multi-tenancy, billing, admin — built to ship and built to scale." },
  { t: "Customer portals & self-service", d: "Account, support, document and onboarding surfaces wired into the same customer record every other team sees." },
  { t: "CRM-native lead capture", d: "Every form, CTA and conversion lands in CRM with full source, UTM and behavioral context — not in an email." },
  { t: "Analytics & experimentation baked in", d: "Product analytics, server-side events, A/B testing — instrumented from launch, not added six months later." },
  { t: "CMS your team can actually use", d: "Editorial surfaces that don't require engineers — so content velocity isn't gated by your dev team's calendar." },
];

const stack = ["Astro", "Next.js", "React", "TypeScript", "Tailwind CSS", "Sanity", "Storyblok", "Contentful", "Vercel", "Netlify", "Cloudflare", "Stripe"];

const layer = {
  desc: "Digital Experience sits at the very edge of the Operational Intelligence stack — it's the surface customers and prospects actually touch. Done right, it's how your operating model becomes legible to the outside world.",
};

const ladder = [
  { name: "Operational Assessment", duration: "60 min · Free", desc: "Map where digital surfaces are leaking demand, breaking instrumentation or sitting disconnected from the operating model.", href: "/contact?type=operational-assessment" },
  { name: "Workflow Audit", duration: "2 weeks", desc: "Deep dive on a single conversion or product surface — lead capture, signup, portal — that's underperforming.", href: "/contact?type=workflow-audit" },
  { name: "Executive Strategy Session", duration: "Half day", desc: "Align on what your web, product and portal surfaces should do for the business — not just how they should look.", href: "/contact?type=executive-strategy" },
];

const industries = [
  { name: "E-Commerce", href: "/industries/ecommerce" },
  { name: "Agencies", href: "/industries/agencies" },
  { name: "Education", href: "/industries/education" },
  { name: "Real Estate", href: "/industries/real-estate" },
  { name: "Clinics", href: "/industries/clinics" },
  { name: "Home Services", href: "/industries/home-services" },
];

const faqs = [
  { q: "Do you do marketing sites, product UI, or both?", a: "Both. The patterns and stacks overlap — and treating them as one team produces tighter instrumentation, consistent design and shorter build cycles than splitting them across vendors." },
  { q: "Which framework do you use?", a: "Astro for content-heavy marketing sites that need to be very fast. Next.js for application UIs that need richer interactivity, auth, multi-tenancy or server-side logic. We choose based on the workload, not the trend." },
  { q: "Will my marketing team be able to edit content?", a: "Yes — that's a hard requirement, not an afterthought. We use modern headless CMSs (Sanity, Storyblok, Contentful) with editorial UIs designed for non-engineers, and we wire them up so content updates don't require a deploy." },
  { q: "How does this integrate with our CRM and analytics?", a: "Tightly. Forms land directly in CRM with full source context. Conversion events fire to your warehouse and product analytics. We instrument from launch — so attribution and experimentation work on day one, not eventually." },
];
---

<MainLayout
  title="Digital Experience — Websites, Portals & SaaS Product UI | GlobalTechSignal"
  description="High-performance websites and SaaS product surfaces engineered for conversion and wired into your business systems. Part of the Operational Intelligence operating model."
>
  <Section id="sys-hero">
    <div class="pt-10 pb-20">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7 space-y-7">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-dark/10 bg-gray text-xs font-mono uppercase tracking-widest text-dark">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
            {system.label}
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-tight">
            The <span class="text-accent">front</span> of your operations.
          </h1>
          <p class="text-lg text-dark/70 leading-relaxed max-w-2xl">{system.blurb}</p>
          <div class="flex flex-col sm:flex-row gap-4 pt-2">
            <a href="/contact?type=operational-assessment" class="px-8 py-4 bg-dark hover:bg-accent rounded-xl text-center text-white text-base font-medium transition-colors">Operational Assessment</a>
            <a href="#what-you-ship" class="px-8 py-4 bg-white hover:bg-dark hover:text-white rounded-xl text-center text-dark border border-dark/20 text-base font-medium transition-colors inline-flex items-center justify-center gap-2">
              See what you ship
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
        <div class="lg:col-span-5">
          <div class="relative">
            <div class="absolute inset-0 bg-accent/5 blur-3xl rounded-[45px]"></div>
            <div class="relative grid grid-cols-2 gap-3">
              <div class="sys-float-card col-span-2 p-5 rounded-2xl bg-white border border-dark shadow-[0px_4px_0px_#191a23]" style="animation-delay:0s;">
                <div class="flex items-center justify-between mb-3">
                  <div class="flex gap-1.5">
                    <span class="h-2.5 w-2.5 rounded-full bg-red"></span>
                    <span class="h-2.5 w-2.5 rounded-full bg-dark/20"></span>
                    <span class="h-2.5 w-2.5 rounded-full bg-accent"></span>
                  </div>
                  <span class="font-mono text-[10px] text-dark/50">yourbrand.com</span>
                </div>
                <div class="h-3 w-1/2 bg-dark rounded-full mb-2"></div>
                <div class="h-2 w-3/4 bg-dark/20 rounded-full mb-1.5"></div>
                <div class="h-2 w-2/3 bg-dark/20 rounded-full"></div>
              </div>
              <div class="sys-float-card p-4 rounded-2xl bg-accent text-white border border-accent shadow-[0px_4px_0px_#191a23]" style="animation-delay:.15s;">
                <div class="font-mono text-[10px] text-white/70 mb-1">LCP</div>
                <div class="text-xl font-extrabold">1.1s</div>
              </div>
              <div class="sys-float-card p-4 rounded-2xl bg-dark text-white border border-dark shadow-[0px_4px_0px_#191a23]" style="animation-delay:.3s;">
                <div class="font-mono text-[10px] text-white/60 mb-1">CONVERSION</div>
                <div class="text-xl font-extrabold">5.8%</div>
              </div>
              <div class="sys-float-card col-span-2 p-3 rounded-2xl bg-white border border-dark/10 shadow-[0px_4px_0px_#191a23] flex items-center gap-3" style="animation-delay:.45s;">
                <span class="h-2 w-2 rounded-full bg-accent animate-pulse"></span>
                <span class="text-xs font-semibold">Form → CRM → Slack — synced 240ms</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="sys-definition">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-gray border border-dark/10 p-8 md:p-14 overflow-hidden">
        <div class="absolute top-0 right-0 h-48 w-48 bg-accent/10 rounded-bl-[120px]"></div>
        <div class="relative grid lg:grid-cols-12 gap-10 items-start">
          <div class="lg:col-span-4">
            <span class="text-xs font-mono uppercase tracking-widest text-dark/50">What it is</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              Web and product surfaces, <span class="text-accent">wired in</span>.
            </h2>
          </div>
          <div class="lg:col-span-8">
            <p class="text-xl md:text-2xl leading-[1.4] text-dark font-medium">{system.long}</p>
            <div class="mt-6 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-dark text-white text-xs font-mono uppercase tracking-widest">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              Part of Operational Intelligence
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="sys-broken">
    <div class="pb-24">
      <div class="max-w-3xl mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">What breaks without it</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
          The four symptoms of a <span class="text-accent">disconnected front-end</span>.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {broken.map((b, i) => (
          <div class="rounded-[24px] bg-white border border-dark/10 p-6 shadow-[0px_4px_0px_#191a23]">
            <span class="font-mono text-xs text-red mb-3 block">0{i + 1}</span>
            <h3 class="text-lg font-extrabold tracking-tight mb-2">{b.t}</h3>
            <p class="text-sm text-dark/70 leading-relaxed">{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section id="what-you-ship">
    <div class="pb-24">
      <div class="grid lg:grid-cols-12 gap-10 mb-12">
        <div class="lg:col-span-5">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">What you ship</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
            Six things a real Digital Experience <span class="text-accent">does</span>.
          </h2>
        </div>
        <div class="lg:col-span-7">
          <p class="text-lg text-dark/70 leading-relaxed">
            We don't ship "a website." We ship a connected surface — fast, instrumented, editable, integrated — engineered to work as part of your operating model from day one.
          </p>
        </div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {ship.map((s, i) => (
          <div class={`rounded-[24px] p-7 border border-dark shadow-[0px_4px_0px_#191a23] ${i === 0 ? 'bg-accent text-white' : i === 3 ? 'bg-dark text-white' : 'bg-white text-dark'}`}>
            <span class={`font-mono text-xs ${i === 0 || i === 3 ? 'text-white/60' : 'text-dark/50'} mb-3 block`}>{String(i + 1).padStart(2, '0')}</span>
            <h3 class="text-xl font-extrabold tracking-tight mb-2">{s.t}</h3>
            <p class={`text-sm leading-relaxed ${i === 0 || i === 3 ? 'text-white/80' : 'text-dark/70'}`}>{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section id="sys-layer">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-dark text-white p-8 md:p-14 overflow-hidden border border-dark shadow-[0px_5px_0px_#191a23]">
        <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="relative grid lg:grid-cols-12 gap-10 items-center">
          <div class="lg:col-span-5">
            <span class="text-xs font-mono uppercase tracking-widest text-white/50">Where it fits</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              The <span class="text-accent">surface</span> of the operating model.
            </h2>
            <p class="mt-5 text-base text-white/70 leading-relaxed">{layer.desc}</p>
            <a href="/operational-intelligence" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-accent hover:text-white transition-colors">
              See the full operating model
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="lg:col-span-7">
            <div class="grid grid-cols-5 gap-2">
              {["Capture", "Connect", "Automate", "Intelligence", "Optimize"].map((n, i) => (
                <div class={`p-3 rounded-xl text-center border ${(i === 0 || i === 1) ? 'bg-accent text-white border-accent' : 'bg-white/5 text-white/50 border-white/10'}`}>
                  <div class="font-mono text-[10px] mb-1 opacity-70">0{i + 1}</div>
                  <div class="text-xs font-bold">{n}</div>
                </div>
              ))}
            </div>
            <p class="mt-4 text-xs font-mono uppercase tracking-widest text-white/40 text-center">Digital Experience primarily lives in Capture + Connect</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="sys-stack">
    <div class="pb-24">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5">
          <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Stack</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
            Modern web, modern <span class="text-accent">CMS</span>.
          </h2>
          <p class="mt-5 text-base text-dark/70 leading-relaxed">
            Frameworks, CMSs and hosting platforms we use most often inside digital experience engagements. We pick what fits the workload, the editorial team and the integration profile.
          </p>
        </div>
        <div class="lg:col-span-7">
          <div class="flex flex-wrap gap-2.5">
            {stack.map((s, i) => (
              <span class={`inline-flex items-center px-4 py-2.5 rounded-full text-sm font-medium border ${i % 3 === 0 ? 'bg-dark text-white border-dark' : i % 3 === 1 ? 'bg-accent text-white border-accent' : 'bg-white text-dark border-dark/15'}`}>{s}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="sys-industries">
    <div class="pb-24">
      <div class="max-w-3xl mb-10">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">Where it lands hardest</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
          Industries where digital experience <span class="text-accent">is the front door</span>.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {industries.map((ind) => (
          <a href={ind.href} class="group flex items-center justify-between p-5 rounded-2xl bg-gray border border-dark/10 hover:border-dark hover:bg-white transition-all">
            <span class="text-base font-extrabold tracking-tight">{ind.name}</span>
            <svg class="w-4 h-4 text-dark/30 group-hover:text-accent group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        ))}
      </div>
    </div>
  </Section>

  <Section id="sys-ladder">
    <div class="pb-24">
      <div class="relative rounded-[32px] bg-gray border border-dark/10 p-8 md:p-14 overflow-hidden">
        <div class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative grid lg:grid-cols-12 gap-10">
          <div class="lg:col-span-5">
            <span class="text-xs font-mono uppercase tracking-widest text-dark/50">How to start</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-[1.1]">
              Three ways to engage on <span class="text-accent">digital experience</span>.
            </h2>
            <p class="mt-5 text-base text-dark/70 leading-relaxed">
              Each entry point produces a concrete artifact you can act on — with or without us.
            </p>
            <a href="/assessments" class="mt-7 inline-flex items-center gap-2 px-6 py-3 bg-dark text-white rounded-xl hover:bg-accent transition-colors font-medium text-sm">
              See all assessments
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="lg:col-span-7 space-y-3">
            {ladder.map((l, idx) => (
              <a href={l.href} class="group flex items-start gap-4 p-5 rounded-2xl bg-white border border-dark/10 hover:border-dark hover:-translate-y-0.5 transition-all duration-300">
                <span class="flex items-center justify-center h-9 w-9 rounded-xl bg-dark text-white text-xs font-mono shrink-0">{String(idx + 1).padStart(2, '0')}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <h3 class="text-lg font-extrabold tracking-tight">{l.name}</h3>
                    <span class="text-[11px] font-mono uppercase tracking-widest text-dark/50">{l.duration}</span>
                  </div>
                  <p class="mt-1 text-sm text-dark/70 leading-relaxed">{l.desc}</p>
                </div>
                <svg class="w-5 h-5 text-dark/30 group-hover:text-accent group-hover:translate-x-1 transition-all shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="sys-faq">
    <div class="pb-24">
      <div class="max-w-3xl mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-dark/50">FAQ</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">Digital Experience, answered.</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-5">
        {faqs.map((f) => (
          <details class="group rounded-2xl bg-gray border border-dark/10 p-6 open:bg-white open:border-dark/30 transition-all">
            <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
              <span class="text-lg font-extrabold tracking-tight text-dark">{f.q}</span>
              <span class="shrink-0 mt-1 h-7 w-7 rounded-full bg-dark text-white flex items-center justify-center group-open:bg-accent transition-colors">
                <svg class="w-3.5 h-3.5 group-open:rotate-45 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-base text-dark/70 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </Section>

  <Section id="sys-cta">
    <div class="pb-28">
      <div class="relative rounded-[32px] bg-dark text-white p-10 md:p-16 text-center overflow-hidden shadow-[0px_5px_0px_#191a23] border border-dark">
        <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative max-w-2xl mx-auto">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/15 text-xs font-mono uppercase tracking-widest text-white/70 mb-6">
            <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
            Start with the surface
          </span>
          <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-5">
            Make your web and product surfaces <span class="text-accent">part of the operation</span>.
          </h2>
          <p class="text-lg text-white/70 mb-8">
            Book a free Operational Assessment. We map where your digital surfaces are leaking value and what to rebuild — instrumented, integrated, fast.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/contact?type=operational-assessment" class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">Operational Assessment</a>
            <a href="/scorecard" class="inline-flex items-center justify-center px-8 py-4 bg-transparent text-white border border-white/30 rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">Take the Business Operations Index™</a>
          </div>
        </div>
      </div>
    </div>
  </Section>
</MainLayout>

<style>
  @keyframes sys-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .sys-float-card { animation: sys-float 5s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) {
    .sys-float-card { animation: none; }
  }
</style>
