---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout
  title="AI Operations | GlobalTechSignal"
  description="AI agents, copilots and intelligent automations embedded inside business systems — designed to remove operational work and deliver measurable outcomes."
>
  <div class="py-16 px-4 mx-auto max-w-screen-xl lg:py-24 lg:px-6">
    {/* HERO — two-column with AI-themed visual */}
    <section class="relative mb-20">
      <div class="absolute -top-24 -left-24 w-[460px] h-[460px] rounded-full bg-accent/[0.06] blur-3xl pointer-events-none"></div>
      <div class="absolute top-20 -right-24 w-[380px] h-[380px] rounded-full bg-accent/[0.04] blur-3xl pointer-events-none"></div>

      <div class="relative grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        {/* Left — copy */}
        <div class="lg:col-span-7 flex flex-col gap-7">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-dark/10 bg-white text-xs font-medium text-dark shadow-[0px_2px_0px_rgba(0,0,0,0.06)] w-fit">
            <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
            <span class="font-mono uppercase tracking-widest">AI Operations</span>
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold leading-[1.05] tracking-tight">
            Put AI to work inside the
            <span class="text-accent">business system</span>.
          </h1>
          <p class="text-lg font-normal leading-8 text-dark/70 max-w-2xl">
            Most AI projects fail because they're built as demos, not systems. We embed AI inside your business operations — qualifying leads, processing documents, summarizing meetings and surfacing operational insight — so it produces measurable outcomes, not just dashboards full of promise.
          </p>

          {/* Friction → AI Operation flow chip */}
          <div class="relative w-fit max-w-xl">
            <div class="absolute -inset-3 bg-accent/10 blur-2xl rounded-full pointer-events-none"></div>
            <div class="relative flex flex-wrap items-center gap-3 px-4 py-3 rounded-xl bg-white border border-dark shadow-[0px_4px_0px_#191a23]">
              <span class="text-[11px] font-mono uppercase tracking-widest text-dark/40">Today</span>
              <span class="h-4 w-px bg-dark/15"></span>
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-dark">
                <span class="h-2 w-2 rounded-full bg-red"></span>
                Manual triage & paperwork
              </span>
              <svg class="w-4 h-4 text-dark/30" fill="currentColor" viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-dark">
                <span class="h-2 w-2 rounded-full bg-accent"></span>
                AI inside the system
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 pt-1">
            <a href="/contact" class="px-8 py-4 bg-dark hover:bg-accent text-white rounded-xl text-base font-medium transition-all duration-300 text-center hover:-translate-y-0.5 shadow-[0px_4px_0px_#191a23] hover:shadow-[0px_6px_0px_#191a23]">
              Operational Assessment
            </a>
            <a href="/services" class="px-8 py-4 bg-white text-dark border border-dark/15 rounded-xl text-base font-medium hover:bg-dark hover:text-white transition-colors text-center">
              All Business Systems
            </a>
          </div>
        </div>

        {/* Right — AI operations preview stack */}
        <div class="lg:col-span-5 relative">
          <div class="relative flex flex-col gap-5 max-w-md mx-auto lg:max-w-none">
            {/* Card 1 — AI agent thinking */}
            <div class="ai-float-card relative bg-dark text-white rounded-[28px] p-6 border border-dark shadow-[0px_5px_0px_#191a23]">
              <div class="flex items-center justify-between mb-4">
                <span class="text-[10px] font-mono uppercase tracking-widest text-white/40">AI Operations · Agent</span>
                <span class="inline-flex items-center gap-1.5 text-[10px] font-mono uppercase tracking-widest text-accent">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
                  Live
                </span>
              </div>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <span class="inline-flex items-center justify-center h-7 w-7 rounded-full bg-white/10 shrink-0 text-[10px] font-mono uppercase">In</span>
                  <p class="text-sm text-white/80 leading-snug">"New lead — 18-unit duplex, 92% score, asking about financing."</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="inline-flex items-center justify-center h-7 w-7 rounded-full bg-accent text-white shrink-0">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                    </svg>
                  </span>
                  <p class="text-sm text-white leading-snug">
                    Qualified · Routed to Sarah · Drafted reply with 3 financing options
                  </p>
                </div>
              </div>
            </div>

            {/* Card 2 — Capabilities */}
            <div class="ai-float-card relative bg-white rounded-[28px] p-6 border border-dark shadow-[0px_5px_0px_#191a23]" style="animation-delay: 0.4s;">
              <div class="flex items-center gap-2 mb-4">
                <span class="h-2 w-2 rounded-full bg-accent"></span>
                <span class="text-[11px] font-mono uppercase tracking-widest text-dark/60">Where AI works</span>
              </div>
              <ul class="space-y-2.5">
                {[
                  'Lead qualification & routing',
                  'Document extraction & generation',
                  'Operational copilots on your SOPs',
                  'Meeting & ticket summarization',
                ].map((cap) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 inline-flex items-center justify-center h-5 w-5 rounded-full bg-accent/10 text-accent shrink-0">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                    <span class="text-sm text-dark/85 leading-snug">{cap}</span>
                  </li>
                ))}
              </ul>
            </div>

            {/* Card 3 — Stack */}
            <div class="ai-float-card relative bg-gray rounded-[28px] p-5 border border-dark shadow-[0px_5px_0px_#191a23]" style="animation-delay: 0.8s;">
              <div class="flex items-center gap-2 mb-3">
                <span class="h-2 w-2 rounded-full bg-accent"></span>
                <span class="text-[11px] font-mono uppercase tracking-widest text-dark/60">Stack</span>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {['LLM Agents', 'OpenAI', 'Anthropic', 'Vector DB', 'RAG', 'Workflows'].map((t) => (
                  <span class="text-[10px] font-mono uppercase tracking-wider px-2.5 py-1 rounded-full bg-white border border-dark/15 text-dark">{t}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* WHERE AI FITS — flow diagram */}
    <section class="mb-20">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <span class="inline-flex items-center gap-2 text-sm font-medium mb-4">
          <span class="h-2 w-2 rounded-full bg-red"></span>
          <span class="font-mono uppercase tracking-widest text-xs text-dark/60">Where AI fits</span>
        </span>
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
          AI lives <span class="text-accent">inside</span> the business system &mdash; not next to it.
        </h2>
      </div>

      <div class="relative rounded-[32px] bg-gray border border-dark p-8 md:p-12 shadow-[0px_5px_0px_#191a23] overflow-hidden">
        <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-accent/10 blur-3xl pointer-events-none"></div>

        <div class="relative grid md:grid-cols-3 gap-5 md:gap-3 items-stretch">
          {/* Step 1 */}
          <div class="relative flex flex-col p-6 rounded-2xl bg-white border border-dark shadow-[0px_4px_0px_#191a23]">
            <span class="text-[10px] font-mono uppercase tracking-widest text-dark/40 mb-3">Step 01 &middot; Input</span>
            <div class="flex items-center gap-2.5 mb-2">
              <span class="h-2.5 w-2.5 rounded-full bg-red"></span>
              <span class="font-extrabold text-dark">Signal arrives</span>
            </div>
            <p class="text-sm text-dark/65 leading-snug">Lead form, ticket, document, voicemail, email &mdash; anywhere a customer touches you.</p>
          </div>

          {/* Connector */}
          <div class="hidden md:flex absolute inset-y-0 left-1/3 -ml-3 items-center justify-center pointer-events-none">
            <svg class="w-6 h-6 text-dark/30" fill="currentColor" viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
          </div>

          {/* Step 2 */}
          <div class="relative flex flex-col p-6 rounded-2xl bg-dark text-white border border-dark shadow-[0px_4px_0px_#191a23]">
            <span class="text-[10px] font-mono uppercase tracking-widest text-white/40 mb-3">Step 02 &middot; AI inside</span>
            <div class="flex items-center gap-2.5 mb-2">
              <span class="inline-flex items-center gap-1.5 text-[10px] font-mono uppercase tracking-widest text-accent">
                <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
                Live
              </span>
              <span class="font-extrabold text-white">AI agent works</span>
            </div>
            <p class="text-sm text-white/70 leading-snug">Qualifies, extracts, summarizes, routes &mdash; using your data, rules and brand voice.</p>
          </div>

          {/* Connector */}
          <div class="hidden md:flex absolute inset-y-0 left-2/3 -ml-3 items-center justify-center pointer-events-none">
            <svg class="w-6 h-6 text-dark/30" fill="currentColor" viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
          </div>

          {/* Step 3 */}
          <div class="relative flex flex-col p-6 rounded-2xl bg-red-soft border border-dark shadow-[0px_4px_0px_#191a23]">
            <span class="text-[10px] font-mono uppercase tracking-widest text-dark/40 mb-3">Step 03 &middot; Outcome</span>
            <div class="flex items-center gap-2.5 mb-2">
              <span class="h-2.5 w-2.5 rounded-full bg-accent"></span>
              <span class="font-extrabold text-dark">Business moves</span>
            </div>
            <p class="text-sm text-dark/70 leading-snug">Right person notified, CRM updated, draft reply ready, dashboard reflects truth.</p>
          </div>
        </div>
      </div>
    </section>

    {/* CAPABILITIES — numbered cards */}
    <section class="mb-20">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
        <div class="max-w-2xl">
          <span class="inline-flex items-center gap-2 text-sm font-medium mb-4 w-fit">
            <span class="h-2 w-2 rounded-full bg-red"></span>
            <span class="font-mono uppercase tracking-widest text-xs text-dark/60">Capabilities</span>
          </span>
          <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
            Three places AI <span class="text-accent">earns its keep</span>.
          </h2>
        </div>
        <p class="lg:max-w-sm text-base sm:text-lg text-dark/70">
          We build AI where it removes operational work, not where it looks impressive in a demo.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        <div class="group relative p-7 rounded-[28px] bg-white border border-dark shadow-[0px_4px_0px_#191a23] hover:-translate-y-1 transition-all duration-300 overflow-hidden">
          <div class="absolute top-0 left-0 h-1 w-16 bg-accent rounded-br-full group-hover:w-28 transition-all duration-300"></div>
          <div class="flex items-center justify-between mb-5">
            <span class="text-sm font-mono text-dark/40">01</span>
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent group-hover:bg-accent group-hover:text-white transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </span>
          </div>
          <h3 class="text-xl font-extrabold tracking-tight text-dark mb-2">Operations copilots</h3>
          <p class="text-sm text-dark/65 leading-snug mb-5">AI assistants trained on your SOPs, docs and CRM data &mdash; so your team gets answers in seconds, not hours.</p>
          <div class="pt-4 border-t border-dark/10 flex items-center gap-2 text-xs text-dark/60">
            <svg class="w-3.5 h-3.5 text-red" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            <span>Removes: Slack-thread decision delays</span>
          </div>
        </div>

        <div class="group relative p-7 rounded-[28px] bg-gray border border-dark shadow-[0px_4px_0px_#191a23] hover:-translate-y-1 transition-all duration-300 overflow-hidden">
          <div class="absolute top-0 left-0 h-1 w-16 bg-accent rounded-br-full group-hover:w-28 transition-all duration-300"></div>
          <div class="flex items-center justify-between mb-5">
            <span class="text-sm font-mono text-dark/40">02</span>
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent group-hover:bg-accent group-hover:text-white transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </span>
          </div>
          <h3 class="text-xl font-extrabold tracking-tight text-dark mb-2">Lead &amp; ticket triage</h3>
          <p class="text-sm text-dark/65 leading-snug mb-5">Classifiers and routers that qualify leads, summarize tickets and hand off to the right human in real time.</p>
          <div class="pt-4 border-t border-dark/10 flex items-center gap-2 text-xs text-dark/60">
            <svg class="w-3.5 h-3.5 text-red" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            <span>Removes: Slow speed-to-customer</span>
          </div>
        </div>

        <div class="group relative p-7 rounded-[28px] bg-white border border-dark shadow-[0px_4px_0px_#191a23] hover:-translate-y-1 transition-all duration-300 overflow-hidden">
          <div class="absolute top-0 left-0 h-1 w-16 bg-accent rounded-br-full group-hover:w-28 transition-all duration-300"></div>
          <div class="flex items-center justify-between mb-5">
            <span class="text-sm font-mono text-dark/40">03</span>
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent group-hover:bg-accent group-hover:text-white transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </span>
          </div>
          <h3 class="text-xl font-extrabold tracking-tight text-dark mb-2">Document workflows</h3>
          <p class="text-sm text-dark/65 leading-snug mb-5">Extract, validate and generate quotes, contracts, intake forms and reports &mdash; days of paperwork become hours of review.</p>
          <div class="pt-4 border-t border-dark/10 flex items-center gap-2 text-xs text-dark/60">
            <svg class="w-3.5 h-3.5 text-red" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            <span>Removes: Repeated copy-paste &amp; PDF wrangling</span>
          </div>
        </div>
      </div>
    </section>

    {/* WHY MOST AI FAILS — quick proof bar */}
    <section class="mb-20">
      <div class="grid md:grid-cols-3 gap-3">
        <div class="p-5 rounded-2xl bg-red-soft border border-dark">
          <div class="text-[10px] font-mono uppercase tracking-widest text-dark/40 mb-2">Most AI projects</div>
          <div class="text-2xl font-extrabold text-dark leading-tight">~80% fail</div>
          <p class="text-xs text-dark/65 mt-1 leading-snug">Built as demos, not systems &mdash; no path to production.</p>
        </div>
        <div class="p-5 rounded-2xl bg-white border border-dark">
          <div class="text-[10px] font-mono uppercase tracking-widest text-dark/40 mb-2">Our approach</div>
          <div class="text-2xl font-extrabold text-dark leading-tight">Inside the system</div>
          <p class="text-xs text-dark/65 mt-1 leading-snug">Wired into CRM, ops, data &mdash; with humans in the loop.</p>
        </div>
        <div class="p-5 rounded-2xl bg-dark text-white border border-dark">
          <div class="text-[10px] font-mono uppercase tracking-widest text-white/40 mb-2">Result</div>
          <div class="text-2xl font-extrabold leading-tight"><span class="text-accent">Measurable</span> outcomes</div>
          <p class="text-xs text-white/65 mt-1 leading-snug">Hours saved, deals routed, decisions accelerated.</p>
        </div>
      </div>
    </section>

    {/* CTA */}
    <section>
      <div class="rounded-[32px] bg-dark text-white p-10 md:p-16 text-center relative overflow-hidden shadow-[0px_5px_0px_#191a23] border border-dark">
        <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-72 h-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative max-w-2xl mx-auto">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/15 text-xs font-mono uppercase tracking-widest text-white/70 mb-6">
            <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
            AI Operations Assessment
          </span>
          <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-5">
            Where would AI move the needle <span class="text-accent">for your business</span>?
          </h2>
          <p class="text-lg text-white/70 mb-7">
            Book an operational assessment. We'll review where AI fits inside your business systems and what outcomes it can realistically deliver.
          </p>

          <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 mb-8 text-xs text-white/60 font-mono uppercase tracking-widest">
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              60-min call
            </span>
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              AI fit-check
            </span>
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Honest answer
            </span>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/contact?type=ai-readiness" class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">AI Readiness Assessment</a>
            <a href="/operational-intelligence" class="inline-flex items-center justify-center px-8 py-4 bg-transparent text-white border border-white/30 rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">Read the operating model</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  @keyframes ai-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .ai-float-card {
    animation: ai-float 5s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .ai-float-card { animation: none; }
  }
</style>
