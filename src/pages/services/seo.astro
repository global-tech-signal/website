---
import MainLayout from "../../layouts/MainLayout.astro";
import Card from "../../components/ui/Card.astro";
---

<MainLayout
  title="AI Automation | GlobalTechSignal"
  description="Custom AI automation, agents and LLM-powered workflows engineered by GlobalTechSignal."
>
  <div class="py-16 px-4 mx-auto max-w-screen-xl lg:py-24 lg:px-6">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-gray text-xs font-medium text-dark mb-6">
        <span class="w-2 h-2 rounded-full bg-accent"></span>
        AI Automation
      </span>
      <h1 class="mb-4 text-4xl font-medium leading-tight tracking-tight md:text-6xl">
        Ship AI workflows that <span class="text-accent">actually work in production</span>.
      </h1>
      <p class="text-lg font-normal leading-7 text-dark/70 mt-6">
        We design, build and operate LLM-powered automations, agents and copilots that remove repetitive work from your team — without the demo-ware.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center mt-8">
        <a href="/contact" class="px-8 py-4 bg-dark hover:bg-accent text-white rounded-xl text-base font-medium transition-colors">Book a Demo</a>
        <a href="/services" class="px-8 py-4 bg-white hover:bg-dark hover:text-white text-dark border border-dark/20 rounded-xl text-base font-medium transition-colors">All services</a>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <Card>
        <div class="p-8">
          <h3 class="text-xl font-medium mb-3">Operations copilots</h3>
          <p class="text-dark/70">Custom AI assistants trained on your SOPs, docs and CRM data — so your team gets answers in seconds, not hours.</p>
        </div>
      </Card>
      <Card>
        <div class="p-8">
          <h3 class="text-xl font-medium mb-3">Lead & ticket triage</h3>
          <p class="text-dark/70">LLM classifiers and routers that qualify leads, summarize tickets and hand off to the right human in real time.</p>
        </div>
      </Card>
      <Card>
        <div class="p-8">
          <h3 class="text-xl font-medium mb-3">Document workflows</h3>
          <p class="text-dark/70">Extract, validate and generate documents at scale — quotes, contracts, intake forms and reports.</p>
        </div>
      </Card>
    </div>

    <div class="mt-24 text-center">
      <Card>
        <div class="p-10 md:p-16">
          <h2 class="text-3xl md:text-4xl font-medium mb-6 tracking-tight">Need custom software for your business?</h2>
          <p class="mb-10 text-lg max-w-2xl mx-auto text-dark/70">
            Tell us about the workflow you want to automate. We usually reply within one business day.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="inline-flex items-center justify-center px-10 py-5 bg-dark text-white rounded-xl hover:bg-accent transition-colors font-medium text-lg">Book a Demo</a>
            <a href="/contact" class="inline-flex items-center justify-center px-10 py-5 bg-white text-dark border border-dark/20 rounded-xl hover:bg-dark hover:text-white transition-colors font-medium text-lg">Start a Project</a>
          </div>
        </div>
      </Card>
    </div>
  </div>
</MainLayout>
