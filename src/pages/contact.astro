---
import MainLayout from "../layouts/MainLayout.astro";
import Form from "../components/ui/Form.astro";
---

<MainLayout
  title="Contact | GlobalTechSignal"
  description="Get in touch with GlobalTechSignal. Tell us about your product, automation or CRM project — we usually reply within one business day."
>
  <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-3">
    <div class="relative flex flex-col items-center">
      <div class="row items-center py-5 md:pb-20 md:pt-10">
        <div class="text-center space-y-8 max-w-3xl mx-auto">
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-gray text-xs font-medium text-dark">
            <span class="w-2 h-2 rounded-full bg-accent"></span>
            Contact
          </span>
          <h1 class="text-4xl font-medium leading-tight md:text-6xl tracking-tight">
            Let's build <span class="redhead">something</span>.
          </h1>
          <p class="text-lg font-normal leading-7 text-dark/70">
            Tell us about your product, automation or CRM project — we usually reply within one business day.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-10 max-w-6xl mx-auto">
      <Form />
    </div>

    <div class="grid md:grid-cols-3 gap-6 mt-16 max-w-4xl mx-auto">
      <div class="p-8 bg-gray rounded-2xl border border-dark/5 text-center">
        <h3 class="text-xl font-medium mb-2">Email</h3>
        <p class="text-dark/70">hello@globaltechsignal.com</p>
      </div>
      <div class="p-8 bg-gray rounded-2xl border border-dark/5 text-center">
        <h3 class="text-xl font-medium mb-2">Response time</h3>
        <p class="text-dark/70">Within 1 business day</p>
      </div>
      <div class="p-8 bg-gray rounded-2xl border border-dark/5 text-center">
        <h3 class="text-xl font-medium mb-2">Based in</h3>
        <p class="text-dark/70">Remote — global clients</p>
      </div>
    </div>
  </div>
</MainLayout>
