---
import MainLayout from "../layouts/MainLayout.astro";

const caseStudies = [
  {
    id: "ai-lead-routing-roofing",
    headlineMetric: "Reduced lead response time by 92%",
    title: "From hours-long lead response to under 2 minutes — and 38% more booked inspections",
    client: "Regional Roofing Company",
    system: "Revenue System · AI Operations",
    summary:
      "A regional roofing company was losing inbound leads to slow follow-up and spreadsheet handoffs. We replaced the manual process with a connected revenue system that captures, scores and routes every inbound lead in under 60 seconds — and the operational outcome was immediate.",
    problem:
      "The team relied on manual lead assignment and spreadsheet tracking. Response times averaged 4–6 hours, leads slipped between reps, and the owner had no visibility into what was happening day-to-day.",
    impact:
      "Slow follow-up was directly suppressing booked inspections, and competitors were winning deals on speed alone. Adding headcount wasn't fixing the underlying operational problem.",
    system_solution:
      "We designed an intake → scoring → routing → notification system on top of their CRM, with AI handling first-pass qualification and the workflow assigning leads to the nearest available rep instantly.",
    technologies: ["AI Automation", "CRM", "Lead Routing", "Workflow Automation"],
    results: [
      "Response time reduced from hours to under 2 minutes",
      "Booked inspections up 38%",
      "Lead leakage eliminated",
      "Zero added headcount",
    ],
  },
  {
    id: "saas-scheduling-clinic",
    headlineMetric: "27% fewer no-shows · 15+ hours/week recovered",
    title: "Recovering $40K/month in lost revenue with a unified scheduling and intake system",
    client: "Multi-Location Clinic Group",
    system: "Operations System · Customer System",
    summary:
      "Five clinic locations were using different scheduling tools and manual reminder calls. We unified them under one operations system that automated reminders, digitized intake and gave leadership real-time visibility across every location.",
    problem:
      "Each location used a different scheduling tool. Reminders were manual, intake was paper-based, and no two locations could see each other's availability or capacity.",
    impact:
      "No-shows were costing the group $40K+ per month, the front-desk team was burning hours on reminder calls, and patients were experiencing inconsistent service across locations.",
    system_solution:
      "We built a unified scheduling platform with automated SMS/email reminders, digital intake forms, real-time availability sync across all five clinics, and a single dashboard for leadership.",
    technologies: ["SaaS Platform", "Workflow Automation", "Customer Data"],
    results: [
      "No-shows reduced by 27%",
      "Front-desk team saved 15+ hours/week",
      "Patient intake time cut in half",
      "Unified dashboard across 5 locations",
    ],
  },
  {
    id: "lead-enrichment-real-estate",
    headlineMetric: "Doubled qualified pipeline with zero added headcount",
    title: "From hours of manual research to a self-running revenue and customer system",
    client: "B2B Real-Estate Firm",
    system: "Revenue System · Customer System · AI Operations",
    summary:
      "The sales team was drowning in manual research and disconnected tools. We built a customer system that enriches, scores and syncs every lead the moment it enters the funnel — doubling qualified opportunities without adding a single hire.",
    problem:
      "Reps spent hours manually researching leads and copying data between CRM, email sequences and spreadsheets. Qualified pipeline was stagnant despite steady inbound volume.",
    impact:
      "Selling time was being consumed by data entry and research, so reps were touching fewer accounts and missing follow-ups. Leadership couldn't trust pipeline reports.",
    system_solution:
      "We built a lead enrichment engine that pulls firmographic and intent data at ingestion, scores every lead and keeps CRM, email sequences and pipeline state in sync in real time.",
    technologies: ["AI Enrichment", "CRM", "Workflow Automation", "Lead Scoring"],
    results: [
      "Qualified opportunities doubled",
      "Manual research hours eliminated",
      "CRM and email always in sync",
      "No additional headcount required",
    ],
  },
];
---

<MainLayout
  title="Case Studies | GlobalTechSignal"
  description="Measurable business outcomes from intelligent business systems — revenue, time and visibility recovered for growing companies."
>
  <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-3">
    <div class="relative flex flex-col items-center">
      <div class="row items-center py-5 md:pb-20 md:pt-10">
        <div class="text-center space-y-8 max-w-3xl mx-auto">
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-gray text-xs font-medium text-dark">
            <span class="w-2 h-2 rounded-full bg-accent"></span>
            Case Studies
          </span>
          <h1 class="text-4xl font-medium leading-tight md:text-6xl tracking-tight">
            Real outcomes, <span class="redhead">real systems</span>
          </h1>
          <p class="text-lg font-normal leading-7 text-dark/70">
            Each case study below leads with the business outcome — then walks through the operational problem, the system we designed and the technology underneath. Outcomes first, technology second.
          </p>
        </div>
      </div>
    </div>

    <div class="space-y-12 mt-10">
      {caseStudies.map((study) => (
        <article id={study.id} class="p-8 md:p-12 bg-dark text-white rounded-[30px]">
          <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent mb-4">
            <span class="h-2 w-2 rounded-full bg-accent"></span>
            {study.headlineMetric}
          </span>
          <h2 class="text-2xl md:text-3xl font-medium mb-2">{study.title}</h2>
          <p class="text-white/60 text-sm mb-6">{study.client} · {study.system}</p>
          <p class="text-white/80 text-lg mb-8">{study.summary}</p>

          <div class="grid md:grid-cols-3 gap-8 mb-8">
            <div>
              <h3 class="text-red font-medium mb-2">Operational Problem</h3>
              <p class="text-white/70">{study.problem}</p>
            </div>
            <div>
              <h3 class="text-red font-medium mb-2">Business Impact</h3>
              <p class="text-white/70">{study.impact}</p>
            </div>
            <div>
              <h3 class="text-red font-medium mb-2">Business System</h3>
              <p class="text-white/70">{study.system_solution}</p>
            </div>
          </div>

          <div class="mb-8">
            <h3 class="text-red font-medium mb-3">Enabling Technology</h3>
            <div class="flex flex-wrap gap-2">
              {study.technologies.map((t) => (
                <span class="text-xs px-3 py-1.5 rounded-full bg-white/10 text-white/80 border border-white/10">{t}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-red font-medium mb-3">Measurable Results</h3>
            <ul class="grid sm:grid-cols-2 gap-3">
              {study.results.map((result) => (
                <li class="flex items-start gap-2 text-white/80">
                  <span class="mt-1.5 w-2 h-2 rounded-full bg-red shrink-0"></span>
                  {result}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-16">
      <a href="/contact" class="px-8 py-4 bg-dark hover:bg-accent text-white rounded-xl text-base font-medium transition-colors inline-block">
        Book an Operational Assessment
      </a>
    </div>
  </div>
</MainLayout>
