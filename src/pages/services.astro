---
import MainLayout from "../layouts/MainLayout.astro";

const services = [
  {
    id: "revenue-systems",
    num: "01",
    title: "Revenue Systems",
    tagline: "CRM, lead management and sales automation built around how your team actually wins business.",
    description:
      "Lost leads, slow follow-up and pipelines nobody trusts are operational problems, not CRM problems. We design connected revenue systems — custom CRM, integrations with HubSpot/Salesforce/Pipedrive, automated lead capture, scoring and routing — so your sales motion becomes predictable, observable and ready to scale.",
    benefits: [
      "Pipelines that match your real sales process",
      "Lead capture, scoring & routing in seconds",
      "Sales automation, sequences and follow-ups",
      "Revenue dashboards leadership can trust",
    ],
    includes: ["Custom CRM", "HubSpot · Salesforce · Pipedrive", "Lead Management", "Sales Automation"],
    cta: "Assess my revenue system",
  },
  {
    id: "operations-systems",
    num: "02",
    title: "Operations Systems",
    tagline: "Connected workflows that replace manual handoffs across the tools you already use.",
    description:
      "When CRM, email, billing, ops tools and spreadsheets don't talk to each other, your team becomes the integration. We build operations systems — workflow automation, API integrations and internal tooling — so processes run end-to-end without human glue.",
    benefits: [
      "Single source of truth across tools",
      "Automated handoffs between teams",
      "Reliable, observable workflows",
      "Faster onboarding for new hires",
    ],
    includes: ["Workflow Automation", "Internal Tools", "API Integrations", "Zapier · n8n · Make · Custom"],
    cta: "Map my operations",
  },
  {
    id: "customer-systems",
    num: "03",
    title: "Customer Systems",
    tagline: "A single source of truth for every customer interaction — from first touch to ongoing success.",
    description:
      "When customer information lives across CRM, support tools, chat, email and spreadsheets, nobody owns the relationship. We design customer systems that unify the customer record, automate onboarding and retention, and give every team the same view.",
    benefits: [
      "Unified customer record across the stack",
      "Onboarding & retention automation",
      "Support and success operations",
      "Customer health & churn signals",
    ],
    includes: ["Customer Data Platform", "Support Ops", "Onboarding Automation", "Retention Workflows"],
    cta: "Unify my customer data",
  },
  {
    id: "business-intelligence",
    num: "04",
    title: "Business Intelligence",
    tagline: "Dashboards and reporting leadership can actually trust — in real time, not after a week of spreadsheet wrangling.",
    description:
      "If reporting takes days, decisions slow down. We design business intelligence layers on top of your operational systems so revenue, pipeline, retention and operational KPIs are live, trusted and shared across the org.",
    benefits: [
      "Executive dashboards in real time",
      "Operational KPIs and SLAs",
      "Revenue & pipeline analytics",
      "Self-service reporting for teams",
    ],
    includes: ["Executive Dashboards", "Operational KPIs", "Data Warehousing", "Custom Reporting"],
    cta: "Light up my dashboards",
  },
  {
    id: "ai-operations",
    num: "05",
    title: "AI Operations",
    tagline: "AI agents, copilots and intelligent automations embedded in how your business actually runs.",
    description:
      "Most AI projects fail because they're built as demos, not systems. We embed AI inside business systems — qualifying leads, processing documents, summarizing meetings, drafting communications and surfacing operational insight — so it produces measurable outcomes instead of dashboards full of promise.",
    benefits: [
      "AI copilots trained on your SOPs & data",
      "LLM workflows for documents & tickets",
      "Lead qualification & support triage",
      "Operational intelligence & next-best-actions",
    ],
    includes: ["AI Automation", "LLM Workflows", "Internal AI Copilots", "Document Processing"],
    cta: "Apply AI to a workflow",
  },
  {
    id: "digital-experience",
    num: "06",
    title: "Digital Experience",
    tagline: "High-performance websites and product surfaces engineered for conversion and wired into your business systems.",
    description:
      "Your website and product UI are the front of your operations. We build digital experiences — marketing sites, SaaS platforms and customer-facing portals — that capture demand, integrate with your CRM and analytics from day one, and scale with you.",
    benefits: [
      "Excellent Core Web Vitals out of the box",
      "Tight CRM and analytics integration",
      "SaaS product UI and portals",
      "Easy for your team to update",
    ],
    includes: ["Custom Websites", "SaaS Development", "Astro · Next.js", "Multi-tenant Platforms"],
    cta: "Plan my digital experience",
  },
];

const industries = [
  "Roofing",
  "Clinics",
  "Construction",
  "Real Estate",
  "Legal",
  "Insurance",
  "Home Services",
  "E-Commerce",
  "Logistics",
  "Finance",
  "Education",
  "Agencies",
];
---

<MainLayout
  title="Business Systems | GlobalTechSignal"
  description="Revenue, operations, customer, intelligence, AI and digital experience systems — designed by GlobalTechSignal to eliminate operational friction and help growing businesses scale."
>
  <div class="py-16 px-4 mx-auto max-w-screen-xl lg:py-24 lg:px-6">
    <!-- Hero -->
    <div class="text-center mb-14 max-w-5xl mx-auto">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-gray text-xs font-medium text-dark mb-6">
        <span class="w-2 h-2 rounded-full bg-accent"></span>
        Business Systems
      </span>
      <h1 class="mb-4 text-4xl font-medium leading-tight tracking-tight md:text-6xl">
        Connected systems for <br/> <span class="redhead">operational impact</span>.
      </h1>
      <p class="text-lg font-normal leading-7 text-dark/70 mt-6">
        We design six categories of intelligent business systems — each combining CRM, automation, integrations, AI and custom software around the operational outcome you need.
      </p>
    </div>

    <!-- Service quick-nav -->
    <nav class="mb-20 md:sticky top-4 z-30">
      <div class="mx-auto max-w-fit flex flex-wrap justify-center gap-2 p-2 rounded-md md:rounded-full bg-white/70 backdrop-blur-md border border-dark/10 shadow-[0px_2px_0px_rgba(0,0,0,0.06)]">
        {services.map((s) => (
          <a
            href={`#${s.id}`}
            class="text-xs sm:text-sm px-3 sm:px-4 py-2 rounded-full text-dark/70 hover:text-white hover:bg-dark transition-colors"
          >
            {s.title}
          </a>
        ))}
      </div>
    </nav>

    <!-- Services list -->
    <div class="space-y-16 md:space-y-24">
      {services.map((service, i) => (
        <section id={service.id} class="scroll-mt-32 group">
          <div class="grid md:grid-cols-12 gap-8 md:gap-10 items-start">
            <!-- Index column -->
            <div class={`md:col-span-4 ${i % 2 === 1 ? 'md:order-2' : ''}`}>
              <div class="flex md:flex-col items-baseline md:items-start gap-4 md:gap-2">
                <span class="text-5xl md:text-7xl font-extrabold text-accent leading-none">{service.num}</span>
                <div class="h-px md:w-16 w-full bg-dark/10 md:mt-3"></div>
              </div>
              <h2 class="mt-3 md:mt-6 text-3xl md:text-4xl font-medium tracking-tight">{service.title}</h2>
              <p class="mt-3 text-dark/60">{service.tagline}</p>
              <a href="/contact" class="mt-6 inline-flex items-center gap-2 text-dark font-medium border-b border-dark/30 pb-1 hover:text-accent hover:border-accent transition-colors">
                {service.cta}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </a>
            </div>

            <!-- Content column -->
            <div class={`md:col-span-8 ${i % 2 === 1 ? 'md:order-1' : ''}`}>
              <p class="text-dark/80 text-lg leading-8 mb-6">{service.description}</p>
              <div class="flex flex-wrap gap-2 mb-8">
                {service.includes.map((tech) => (
                  <span class="text-xs px-3 py-1.5 rounded-full border border-dark/15 text-dark/70 bg-white">{tech}</span>
                ))}
              </div>
              <ul class="grid sm:grid-cols-2 gap-3">
                {service.benefits.map((benefit) => (
                  <li class="flex items-start gap-3 p-4 rounded-xl bg-gray/60 border border-dark/5">
                    <span class="flex items-center justify-center h-5 w-5 rounded-full bg-accent/10 mt-0.5 shrink-0">
                      <svg class="w-3 h-3 text-accent" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                      </svg>
                    </span>
                    <span class="text-sm text-dark/80 leading-snug">{benefit}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- Industries -->
    <div class="mt-28">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-medium tracking-tight">Industries we serve</h2>
        <p class="text-dark/60 mt-3 max-w-xl mx-auto">Business systems tailored to operational realities — not generic agency playbooks.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-2 max-w-3xl mx-auto">
        {industries.map((industry) => (
          <span class="text-sm px-4 py-2 rounded-full bg-white border border-dark/10 text-dark/80 hover:border-accent hover:text-accent transition-colors cursor-default">
            {industry}
          </span>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-24">
      <div class="relative overflow-hidden rounded-[36px] bg-dark text-white p-10 md:p-16 text-center">
        <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-72 h-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative">
          <h2 class="text-3xl md:text-4xl font-medium mb-5 tracking-tight">Not sure which system you need?</h2>
          <p class="mb-8 text-lg max-w-2xl mx-auto text-white/70">
            Start with an operational assessment. We'll review your stack, map the friction and recommend the system that solves it.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">
              Operational Assessment
            </a>
            <a href="/solutions/outgrowing-spreadsheets" class="inline-flex items-center justify-center px-8 py-4 bg-transparent text-white border border-white/30 rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">
              Explore Solutions
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
