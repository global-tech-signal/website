---
import MainLayout from "../layouts/MainLayout.astro";

const services = [
  {
    id: "ai-automation",
    num: "01",
    title: "AI Automation",
    tagline: "Replace repetitive operations with intelligent agents.",
    description:
      "We use LLMs, agents and workflow tooling to automate repetitive operations: lead qualification, document processing, support triage, internal copilots and back-office tasks. Fewer manual steps, faster cycles, leaner teams.",
    benefits: [
      "Hours saved per week per employee",
      "Faster lead and ticket response times",
      "Reduced manual data entry and errors",
      "AI copilots tailored to your workflows",
    ],
    cta: "Automate a workflow",
  },
  {
    id: "crm",
    num: "02",
    title: "CRM Systems",
    tagline: "Pipelines built around how your team actually sells.",
    description:
      "Custom CRM platforms and deep integrations with HubSpot, Salesforce and Pipedrive — built around how your business actually sells. Pipelines, automations, scoring and reporting that match your real funnel.",
    benefits: [
      "Pipelines that match your real sales process",
      "Automated lead routing and follow-up",
      "Clean data and dashboards leadership trust",
      "Native integrations with your stack",
    ],
    cta: "Design my CRM",
  },
  {
    id: "saas",
    num: "03",
    title: "SaaS Development",
    tagline: "Production-grade SaaS, from MVP to multi-tenant scale.",
    description:
      "End-to-end SaaS engineering: architecture, multi-tenant data models, billing, auth, dashboards, APIs and DevOps. We build SaaS products founders can actually scale and maintain.",
    benefits: [
      "Production-grade architecture from day one",
      "Multi-tenant data, billing and auth",
      "CI/CD, monitoring and observability",
      "Code your team can own and extend",
    ],
    cta: "Build my SaaS",
  },
  {
    id: "workflow",
    num: "04",
    title: "Workflow Automation",
    tagline: "One automated flow across the tools you already use.",
    description:
      "Connect the tools you already use — CRM, email, billing, ops — into one automated workflow. We build with Zapier, n8n, Make, custom APIs and serverless functions, depending on what fits.",
    benefits: [
      "Single source of truth across tools",
      "Automated handoffs between teams",
      "Reliable, observable workflows",
      "Faster onboarding for new hires",
    ],
    cta: "Automate my ops",
  },
  {
    id: "websites",
    num: "05",
    title: "Custom Websites",
    tagline: "Fast, SEO-ready sites wired into your stack.",
    description:
      "High-performance marketing sites and product surfaces built with modern stacks (Astro, Next.js, Tailwind). Fast, SEO-friendly, and wired into your CRM and analytics from launch.",
    benefits: [
      "Excellent Core Web Vitals out of the box",
      "Tight CRM and analytics integration",
      "SEO-ready content architecture",
      "Easy for your team to update",
    ],
    cta: "Plan my site",
  },
  {
    id: "lead-management",
    num: "06",
    title: "Lead Management Systems",
    tagline: "From web form to closed deal — automatically.",
    description:
      "Capture, enrich, score and route leads automatically — from web form to closed deal. Purpose-built for service businesses where speed-to-lead and follow-up discipline drive revenue.",
    benefits: [
      "Speed-to-lead measured in seconds",
      "Automatic enrichment and scoring",
      "Round-robin or rules-based routing",
      "Clear pipeline visibility for leadership",
    ],
    cta: "Capture more leads",
  },
];

const industries = [
  "Roofing",
  "Clinics",
  "Construction",
  "Real Estate",
  "Legal",
  "Insurance",
  "Home Services",
  "E-Commerce",
  "Logistics",
  "Finance",
  "Education",
  "Agencies",
];
---

<MainLayout
  title="Engineering Services | GlobalTechSignal"
  description="AI automation, CRM systems, SaaS development, custom business software and lead management — engineered by GlobalTechSignal."
>
  <div class="py-16 px-4 mx-auto max-w-screen-xl lg:py-24 lg:px-6">
    <!-- Hero -->
    <div class="text-center mb-14 max-w-5xl mx-auto">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-gray text-xs font-medium text-dark mb-6">
        <span class="w-2 h-2 rounded-full bg-accent"></span>
        Engineering Services
      </span>
      <h1 class="mb-4 text-4xl font-medium leading-tight tracking-tight md:text-6xl">
        Software, AI and automation <br/> built for <span class="redhead">operational impact</span>.
      </h1>
      <p class="text-lg font-normal leading-7 text-dark/70 mt-6">
        Custom CRM systems, SaaS platforms, AI automations and lead management software — engineered for modern businesses.
      </p>
    </div>

    <!-- Service quick-nav -->
    <nav class="mb-20 md:sticky top-4 z-30">
      <div class="mx-auto max-w-fit flex flex-wrap justify-center gap-2 p-2 rounded-md md:rounded-full bg-white/70 backdrop-blur-md border border-dark/10 shadow-[0px_2px_0px_rgba(0,0,0,0.06)]">
        {services.map((s) => (
          <a
            href={`#${s.id}`}
            class="text-xs sm:text-sm px-3 sm:px-4 py-2 rounded-full text-dark/70 hover:text-white hover:bg-dark transition-colors"
          >
            {s.title}
          </a>
        ))}
      </div>
    </nav>

    <!-- Services list -->
    <div class="space-y-16 md:space-y-24">
      {services.map((service, i) => (
        <section id={service.id} class="scroll-mt-32 group">
          <div class="grid md:grid-cols-12 gap-8 md:gap-10 items-start">
            <!-- Index column -->
            <div class={`md:col-span-4 ${i % 2 === 1 ? 'md:order-2' : ''}`}>
              <div class="flex md:flex-col items-baseline md:items-start gap-4 md:gap-2">
                <span class="text-5xl md:text-7xl font-extrabold text-accent leading-none">{service.num}</span>
                <div class="h-px md:w-16 w-full bg-dark/10 md:mt-3"></div>
              </div>
              <h2 class="mt-3 md:mt-6 text-3xl md:text-4xl font-medium tracking-tight">{service.title}</h2>
              <p class="mt-3 text-dark/60">{service.tagline}</p>
              <a href="/contact" class="mt-6 inline-flex items-center gap-2 text-dark font-medium border-b border-dark/30 pb-1 hover:text-accent hover:border-accent transition-colors">
                {service.cta}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </a>
            </div>

            <!-- Content column -->
            <div class={`md:col-span-8 ${i % 2 === 1 ? 'md:order-1' : ''}`}>
              <p class="text-dark/80 text-lg leading-8 mb-8">{service.description}</p>
              <ul class="grid sm:grid-cols-2 gap-3">
                {service.benefits.map((benefit) => (
                  <li class="flex items-start gap-3 p-4 rounded-xl bg-gray/60 border border-dark/5">
                    <span class="flex items-center justify-center h-5 w-5 rounded-full bg-accent/10 mt-0.5 shrink-0">
                      <svg class="w-3 h-3 text-accent" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                      </svg>
                    </span>
                    <span class="text-sm text-dark/80 leading-snug">{benefit}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- Industries -->
    <div class="mt-28">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-medium tracking-tight">Industries we serve</h2>
        <p class="text-dark/60 mt-3 max-w-xl mx-auto">Engineering tailored to operational realities — not generic agency playbooks.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-2 max-w-3xl mx-auto">
        {industries.map((industry) => (
          <span class="text-sm px-4 py-2 rounded-full bg-white border border-dark/10 text-dark/80 hover:border-accent hover:text-accent transition-colors cursor-default">
            {industry}
          </span>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-24">
      <div class="relative overflow-hidden rounded-[36px] bg-dark text-white p-10 md:p-16 text-center">
        <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-72 h-72 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="relative">
          <h2 class="text-3xl md:text-4xl font-medium mb-5 tracking-tight">Need custom software for your business?</h2>
          <p class="mb-8 text-lg max-w-2xl mx-auto text-white/70">
            Tell us about your CRM, SaaS or AI automation project. We usually reply within one business day.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">
              Book a Demo
            </a>
            <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-transparent text-white border border-white/30 rounded-xl hover:bg-white hover:text-dark transition-colors font-medium">
              Start a Project
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
