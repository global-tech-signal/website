---
import MainLayout from "../layouts/MainLayout.astro";
import priceData from "../data/priceDats.json";
import Card from "../components/ui/Card.astro";
---

<MainLayout title="Business System Packages | GlobalTechSignal" description="Three packaged business systems — from a foundational revenue setup to a fully connected operational intelligence platform.">
	<main class="space-y-20">
        <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-3">
            <div class="relative flex flex-col items-center">
                <div class="row items-center py-5 md:pb-20 md:pt-10">
                    <div class="text-center space-y-8 max-w-3xl mx-auto">
                        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-dark/10 bg-gray text-xs font-medium text-dark">
                            <span class="w-2 h-2 rounded-full bg-accent"></span>
                            Packages
                        </span>
                        <h1 class="text-4xl font-medium leading-tight md:text-6xl tracking-tight">
                            Business systems packaged for <span class="redhead">where you are today</span>
                        </h1>
                        <p class="text-lg font-normal leading-7 text-dark/70">
                            Three system tiers — from a foundational revenue setup to a fully connected operational intelligence platform — scoped around the operational outcomes you need next.
                        </p>
                    </div>
                </div>
            </div>
            <div class="space-y-8 lg:grid lg:grid-cols-3 sm:gap-6 xl:gap-10 lg:space-y-0">
                {
                priceData.map((item) => (
                <Card isUnderline={true}>
                <div class="relative flex flex-col p-6 mx-auto max-w-lg text-center">
                    {item.badge && (
                        <span class="absolute top-0 right-0 bg-red text-white text-xs font-semibold px-3 py-1 rounded-bl-lg rounded-tr-lg">{item.badge}</span>
                    )}
                    <h3 class="mb-4 text-2xl font-semibold">{item.name}</h3>
                    <p class="font-light text-gray-500 sm:text-lg">{item.best_for}</p>
                    <div class="flex justify-center items-baseline my-8">
                        {item.starting_from && <span class="text-gray-500 text-sm mr-1">from</span>}
                        <span class="mr-2 text-5xl font-extrabold">${item.price_usd.toLocaleString()}</span>
                    </div>
                    <ul role="list" class="mb-8 space-y-4 text-left">
                        {item.features.map((feature) => (
                        <li class="flex items-center space-x-3">
                            <svg class="flex-shrink-0 w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                            <span>{feature}</span>
                        </li>
                        ))}
                    </ul>
                    <a href="/contact" class="text-white hover:text-white bg-red hover:bg-black focus:ring-4 focus:ring-red-200 font-medium rounded-lg text-sm px-5 py-2.5 text-center">Get Started</a>
                </div>
                </Card>
                )) 
                }
            </div>
        </div>
	</main>
</MainLayout>